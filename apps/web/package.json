    "format": "prettier --write src/"
  },
  "dependencies": {
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vue-tsc": "^2.2.12"
  }
}
