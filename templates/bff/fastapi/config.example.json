{
  "harnessos_base_url": "http://127.0.0.1:8000",
  "harnessos_capability_token_env": "HARNESSOS_CAPABILITY_TOKEN",
  "allowed_origins": ["http://localhost:5173"],
  "allow_credentials": true,
  "demo_identity_mode": true,
  "identity_scope": {
    "app_id": "reference_app",
    "project_id": "demo",
    "workspace_id": "local"
  },
  "demo_capabilities": [
    "sessions",
    "turns",
    "events",
    "artifacts.read",
    "artifacts.write",
    "jobs",
    "approvals",
    "packs.read",
    "connectors.read"
  ]
}
