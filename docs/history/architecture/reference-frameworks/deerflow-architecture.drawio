<mxfile host="embed.diagrams.net">
  <diagram id="deerflow-architecture" name="DeerFlow 2.0架构">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="1) DeerFlow 2.0 架构图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=18;fontStyle=1;" vertex="1">
          <mxGeometry x="200" y="10" width="400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="deer_channel" value="Browser / IM Channels&#xa;Web UI / Slack / Telegram / Feishu / WeChat" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1">
          <mxGeometry x="200" y="50" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="deer_nginx" value="Nginx / Unified Entry (Port 2026)&#xa;/api/langgraph/* → LangGraph Server&#xa;/api/* → Gateway API&#xa;/* → Frontend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1">
          <mxGeometry x="200" y="100" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="deer_langgraph" value="LangGraph Server&#xa;Agent Runtime&#xa;make_lead_agent()&#xa;SSE Streaming" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1">
          <mxGeometry x="80" y="170" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="deer_gateway" value="Gateway API&#xa;Control Plane&#xa;Models / MCP / Skills&#xa;Uploads / Artifacts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1">
          <mxGeometry x="230" y="170" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="deer_middleware" value="lead_agent Middleware&#xa;ThreadData → Uploads → Sandbox&#xa;→ Summarization → Title&#xa;TodoList → Memory → ViewImage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1">
          <mxGeometry x="80" y="250" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="deer_tools" value="Tools + MCP&#xa;builtin/config" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1">
          <mxGeometry x="80" y="320" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="deer_subagents" value="Subagents&#xa;Task Exec&#xa;Concurrent Delegation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1">
          <mxGeometry x="220" y="320" width="140" height="40" as="geometry" />
        </mxCell>
        <mxCell id="deer_sandbox" value="Sandbox / Thread Data / Memory&#xa;/mnt/user-data/{workspace,uploads,outputs}&#xa;LocalSandbox | AioSandbox(Docker/K8s)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1">
          <mxGeometry x="80" y="380" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="deer_e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="deer_channel" target="deer_nginx">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="deer_e2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;endArrow=classic;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="deer_nginx" target="deer_langgraph">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="deer_e3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;endArrow=classic;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="deer_nginx" target="deer_gateway">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="deer_e4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="deer_langgraph" target="deer_middleware">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="deer_e5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="deer_gateway" target="deer_middleware">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="deer_e6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;endArrow=classic;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0;entryDx=0;entryDy=0;" edge="1" source="deer_middleware" target="deer_tools">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="deer_e7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;endArrow=classic;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0;entryDx=0;entryDy=0;" edge="1" source="deer_middleware" target="deer_subagents">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="deer_e8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="deer_tools" target="deer_sandbox">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="deer_e9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#666666;endArrow=classic;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="deer_subagents" target="deer_sandbox">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="deer_key" value="核心: lead_agent + middleware + thread_state&#xa;长任务 + 文件工件 + 线程隔离" style="text;html=1;strokeColor=#b85450;fillColor=#fff2cc;fontSize=9;align=center;" vertex="1">
          <mxGeometry x="380" y="200" width="150" height="40" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
