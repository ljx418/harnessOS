<mxfile host="app.diagrams.net" modified="2026-04-30T17:20:00.000Z" agent="codex" version="24.7.17">
  <diagram id="code-review-cleanup-checklist-v2" name="Code Review Cleanup Checklist">
    <mxGraphModel dx="1600" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="harnessOS V2 代码检视清单 / Review Cleanup Gate" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=26;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="30" width="1640" height="50" as="geometry" />
        </mxCell>
        <mxCell id="rule" value="维护规则&lt;br&gt;&lt;br&gt;• 每次大阶段完成后必须更新本清单&lt;br&gt;• 2026-04-30 Review Cleanup Gate 已完成本批次 P0/P1 清理&lt;br&gt;• 测试前必须完成 Second Review Gate&lt;br&gt;• 新增 P0/P1 问题时停止验收并回到清理&lt;br&gt;• 状态：✅ verified / ⏭ deferred / 🟢 passed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#2563EB;align=left;spacingLeft=14;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="80" y="110" width="1640" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p0" value="P0 安全闭环：本批次状态&lt;br&gt;&lt;br&gt;✅ CR-P0-01 移除 approved=True 绕过&lt;br&gt;✅ CR-P0-02 approval_id 绑定 session/source turn/工具/动作/输入 hash&lt;br&gt;✅ CR-P0-03 Simple + OpenHarness 工具执行接入 policy guard&lt;br&gt;✅ CR-P0-04 artifact 注册/读取限制托管或允许根目录&lt;br&gt;⏭ CR-P0-05 完整用户/租户 owner 边界延期到 Phase 6；本批次已关闭 session path 与 approval cross-session 复用&lt;br&gt;✅ CR-P0-06 session_id 路径安全&lt;br&gt;✅ CR-P0-07 Core/Gateway 持久化写入前脱敏" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#16A34A;align=left;spacingLeft=14;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="80" y="270" width="790" height="300" as="geometry" />
        </mxCell>
        <mxCell id="p1" value="P1 架构边界：集中延期项&lt;br&gt;&lt;br&gt;⏭ CR-P1-01 Meeting 兼容 RPC 收敛到 Pack/Core 治理路径：Phase 5-A&lt;br&gt;⏭ CR-P1-02 Domain workflow governed context：Phase 5-A / 5-C&lt;br&gt;⏭ CR-P1-03 GatewayRuntimePool 继续瘦身：Phase 5&lt;br&gt;⏭ CR-P1-04 Pack assembly 向 manifest/DSL/skill/policy bundle 迁移：Phase 5-A&lt;br&gt;⏭ CR-P1-05 Pack 不新增 Gateway 反向依赖：Phase 5-A&lt;br&gt;&lt;br&gt;本批次约束：不再向 Gateway 增加新的业务流程职责。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF7ED;strokeColor=#EA580C;align=left;spacingLeft=14;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="930" y="270" width="790" height="300" as="geometry" />
        </mxCell>
        <mxCell id="p2" value="P2 功能一致性：后续清理池&lt;br&gt;&lt;br&gt;⏭ CR-P2-01 稳定资源错误码&lt;br&gt;✅ CR-P2-02 工具执行层可创建 approval request，仍需继续扩展默认路径覆盖&lt;br&gt;⏭ CR-P2-03 retry 可执行 payload 与公开脱敏视图分离&lt;br&gt;⏭ CR-P2-04 团队标准真实音频 fixture/env gate&lt;br&gt;⏭ CR-P2-05 disabled/stub pack 显式 blocked&lt;br&gt;&lt;br&gt;本批次验收：Meeting lineage 已用本机真实音频通过。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFBEB;strokeColor=#D97706;align=left;spacingLeft=14;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="80" y="620" width="790" height="250" as="geometry" />
        </mxCell>
        <mxCell id="p3" value="P3 维护性：后续清理池&lt;br&gt;&lt;br&gt;⏭ CR-P3-01 GatewayService 继续拆分&lt;br&gt;⏭ CR-P3-02 新测试避免 sys.path mutation&lt;br&gt;⏭ CR-P3-03 OpenHarness duplicate tool package 后续兼容清理&lt;br&gt;&lt;br&gt;本批次原则：只处理阻塞 Phase 5-A 的 P0/P1，不展开大规模重构。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#64748B;align=left;spacingLeft=14;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="930" y="620" width="790" height="250" as="geometry" />
        </mxCell>
        <mxCell id="second_review" value="Second Review Gate：🟢 passed&lt;br&gt;&lt;br&gt;✅ 安全复检：修改代码未发现残留 P0/P1&lt;br&gt;✅ 测试复检：未发现 P0/P1 覆盖缺口&lt;br&gt;✅ 覆盖点：retry reservation、snapshot masking、OpenHarness approval propagation、source-turn retry binding、cross-session approval rejection&lt;br&gt;规则保持：后续新增 P0/P1 时停止验收，返回 cleanup" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0FDF4;strokeColor=#16A34A;align=left;spacingLeft=14;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="80" y="920" width="790" height="180" as="geometry" />
        </mxCell>
        <mxCell id="acceptance" value="Parallel Phase Acceptance：🟢 passed&lt;br&gt;&lt;br&gt;✅ 控制面：32 passed&lt;br&gt;✅ Meeting / Artifact / Workflow：25 passed&lt;br&gt;✅ Governance：33 passed&lt;br&gt;✅ Core / Runtime / Pack：22 passed&lt;br&gt;✅ HarnessOS tests：113 passed，1 skipped&lt;br&gt;✅ 用户态 Meeting lineage：transcript → analysis → result → minutes&lt;br&gt;✅ Draw.io XML 校验通过" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#059669;align=left;spacingLeft=14;fontSize=14" vertex="1" parent="1">
          <mxGeometry x="930" y="920" width="790" height="180" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
