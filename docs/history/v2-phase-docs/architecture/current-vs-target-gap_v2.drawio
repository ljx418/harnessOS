        <mxCell id="gap_protocol" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFBEB;strokeColor=#F59E0B;align=left;spacingLeft=12;fontSize=13" value="协议差距&lt;br&gt;&lt;br&gt;已完成：本地 RPC + FastAPI /v1/runs + SSE&lt;br&gt;已完成：artifact / trace / approval / policy / retry&lt;br&gt;已完成：Core protocol models + CoreAppService&lt;br&gt;已完成：Session / Thread / Turn / Item / Artifact / Trace / Approval / Retry 基础对象&lt;br&gt;已完成：session start/close Core-native mutation&lt;br&gt;已完成：turn/item Core-native mutation&lt;br&gt;已完成：session.get / thread.list / turn.get / turn.items&lt;br&gt;已完成：core.artifact.list / core.trace.list / core.approval.list / core.retry.list&lt;br&gt;需要补：Core-native RPC router" vertex="1">
          <mxGeometry height="220" width="400" x="600" y="190" as="geometry" />
