        <mxCell id="cur_runtime" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F9FF;strokeColor=#38BDF8;align=left;spacingLeft=12;fontSize=13" value="Runtime Adapter + Store&lt;br&gt;&lt;br&gt;• RuntimeHandle / RuntimeAdapter MVP&lt;br&gt;• SimpleRuntimeAdapter：invoke&lt;br&gt;• OpenHarnessRuntimeAdapter：stream / continue&lt;br&gt;• GatewayRuntimePool 通过 adapter start / close&lt;br&gt;• session.list/read/events/transcript Core 优先&lt;br&gt;• legacy snapshot + events.jsonl 保持兼容" vertex="1">
