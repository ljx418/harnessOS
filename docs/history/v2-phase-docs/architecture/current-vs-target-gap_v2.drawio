        <mxCell id="cur_gateway" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F9FF;strokeColor=#38BDF8;align=left;spacingLeft=12;fontSize=13" value="Gateway / 协议边界&lt;br&gt;&lt;br&gt;• apps/gateway 已去 ohmo 化&lt;br&gt;• RpcRequest / RpcResponse / GatewayEvent&lt;br&gt;• session.start/resume/list/read/transcript&lt;br&gt;• turn.start/continue/interrupt/retry&lt;br&gt;• artifact.register/list/get/read&lt;br&gt;• trace.list/get 已完成&lt;br&gt;• approval.request/list/get/approve/reject 已完成&lt;br&gt;• policy.evaluate 已完成&lt;br&gt;• pack.list/get 已完成&lt;br&gt;• connector.list/get/health 已完成&lt;br&gt;• job.list/get/cancel 已完成&lt;br&gt;• FastAPI app.state GatewayService + Depends&lt;br&gt;• /v1/runs + SSE + /v1/rpc&lt;br&gt;• stdio JSONL server" vertex="1">
          <mxGeometry height="252.5" width="400" x="70" y="317.5" as="geometry" />
