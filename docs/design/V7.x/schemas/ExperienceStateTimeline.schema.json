{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/ExperienceStateTimeline.schema.json",
  "title": "ExperienceStateTimeline",
  "type": "object",
  "additionalProperties": false,
  "required": ["timeline_id", "mission_id", "states", "source_refs", "created_at"],
  "properties": {
    "timeline_id": { "type": "string", "minLength": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["state", "status", "occurred_at", "source_ref"],
        "properties": {
          "state": { "enum": ["IntentCaptured", "SpecDrafted", "SchemaValidated", "DiffReady", "AwaitingConfirmation", "UserConfirmed", "RuntimeStarted", "RuntimeObserved", "EvidenceRecorded", "ReviewReady"] },
          "status": { "enum": ["pending", "active", "complete", "blocked"] },
          "occurred_at": { "type": "string", "format": "date-time" },
          "source_ref": { "type": "string", "minLength": 1 }
        }
      }
    },
    "source_refs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
