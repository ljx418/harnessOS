{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/NaturalLanguageGoal.schema.json",
  "title": "NaturalLanguageGoal",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "goal_id",
    "natural_language_goal",
    "source",
    "actor_type",
    "tenant_id",
    "workspace_id",
    "project_id",
    "app_id",
    "created_at",
    "correlation_id"
  ],
  "properties": {
    "goal_id": { "type": "string", "minLength": 1 },
    "natural_language_goal": { "type": "string", "minLength": 1 },
    "source": { "const": "mission_tui" },
    "actor_type": { "const": "human_user" },
    "tenant_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "app_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "correlation_id": { "type": "string", "minLength": 1 }
  }
}
