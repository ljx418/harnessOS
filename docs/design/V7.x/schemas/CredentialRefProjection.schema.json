{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/CredentialRefProjection.schema.json",
  "title": "CredentialRefProjection",
  "type": "object",
  "additionalProperties": false,
  "required": ["credential_ref", "tenant_id", "workspace_id", "app_id", "provider_profile_id", "status", "redaction_status", "audit_ref", "created_at"],
  "properties": {
    "credential_ref": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "app_id": { "type": "string", "minLength": 1 },
    "provider_profile_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["available", "denied", "expired", "revoked"] },
    "redaction_status": { "const": "no_raw_credential_material" },
    "audit_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
