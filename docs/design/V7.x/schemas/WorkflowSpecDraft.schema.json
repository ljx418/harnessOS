{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/WorkflowSpecDraft.schema.json",
  "title": "WorkflowSpecDraft",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metadata",
    "stations",
    "edges",
    "artifact_contracts",
    "quality_rules",
    "approval_points",
    "context_refs",
    "evidence_refs",
    "runtime_truth_boundary"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "workflow_spec_id",
        "schema_version",
        "goal_id",
        "workflow_kind",
        "created_by",
        "created_at",
        "source_refs"
      ],
      "properties": {
        "workflow_spec_id": { "type": "string", "minLength": 1 },
        "schema_version": { "type": "string", "minLength": 1 },
        "goal_id": { "type": "string", "minLength": 1 },
        "workflow_kind": { "const": "local_markdown_technical_document_summary" },
        "created_by": { "const": "mission_tui" },
        "created_at": { "type": "string", "format": "date-time" },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "stations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["station_id", "station_kind", "input_refs", "output_refs"],
        "properties": {
          "station_id": { "type": "string", "minLength": 1 },
          "station_kind": {
            "enum": [
              "folder_authorization",
              "markdown_scan",
              "per_folder_summary",
              "overview_summary",
              "quality_check",
              "runtime_report",
              "evidence_record"
            ]
          },
          "input_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "output_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from_station_id", "to_station_id"],
        "properties": {
          "from_station_id": { "type": "string", "minLength": 1 },
          "to_station_id": { "type": "string", "minLength": 1 }
        }
      }
    },
    "artifact_contracts": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "quality_rules": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "approval_points": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "context_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "runtime_truth_boundary": { "const": "workflow_spec_draft_is_not_runtime_truth" }
  }
}
