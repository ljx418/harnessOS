{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/WorkspaceInventory.schema.json",
  "title": "WorkspaceInventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["tenant_id", "workspace_id", "project_ids", "app_ids", "audit_ref", "created_at"],
  "properties": {
    "tenant_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "project_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "app_ids": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "audit_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
