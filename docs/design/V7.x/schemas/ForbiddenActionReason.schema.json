{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/ForbiddenActionReason.schema.json",
  "title": "ForbiddenActionReason",
  "type": "object",
  "additionalProperties": false,
  "required": ["reason_id", "mission_id", "operation", "source", "reason_code", "human_readable_summary", "policy_ref", "created_at"],
  "properties": {
    "reason_id": { "type": "string", "minLength": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "operation": { "type": "string", "minLength": 1 },
    "source": { "enum": ["agent", "mission_tui", "product_console", "approved_api"] },
    "reason_code": { "enum": ["requires_user_confirmation", "source_agent_denied", "missing_policy_decision", "missing_credential_ref", "out_of_scope", "runtime_truth_boundary"] },
    "human_readable_summary": { "type": "string", "minLength": 1 },
    "policy_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
