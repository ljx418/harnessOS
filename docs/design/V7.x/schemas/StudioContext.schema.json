{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/StudioContext.schema.json",
  "title": "StudioContext",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "studio_id",
    "tenant_id",
    "workspace_id",
    "project_ids",
    "app_ids",
    "created_at",
    "audit_ref",
    "runtime_truth_boundary"
  ],
  "properties": {
    "studio_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "project_ids": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
    "app_ids": { "type": "array", "items": { "type": "string", "minLength": 1 }, "minItems": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "audit_ref": { "type": "string", "minLength": 1 },
    "runtime_truth_boundary": {
      "const": "product_aggregation_only_no_runtime_truth_write"
    }
  }
}
