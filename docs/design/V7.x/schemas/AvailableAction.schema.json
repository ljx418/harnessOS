{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/AvailableAction.schema.json",
  "title": "AvailableAction",
  "type": "object",
  "additionalProperties": false,
  "required": ["action_id", "mission_id", "operation", "actor_type", "source", "requires_user_confirmation", "agent_executable", "policy_decision", "target_refs", "created_at"],
  "properties": {
    "action_id": { "type": "string", "minLength": 1 },
    "mission_id": { "type": "string", "minLength": 1 },
    "operation": { "enum": ["workflow.spec.generate", "workflow.patch.propose", "workflow.instance.start", "station.rerun", "evidence.show", "report.open", "drawio.open", "handoff.open"] },
    "actor_type": { "enum": ["human_user", "service_account_with_human_authorization"] },
    "source": { "enum": ["mission_tui", "product_console", "approved_api"] },
    "requires_user_confirmation": { "type": "boolean" },
    "agent_executable": { "const": false },
    "policy_decision": { "enum": ["allow", "deny", "needs_review"] },
    "target_refs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workflow_spec_id": { "type": "string", "minLength": 1 },
        "workflow_instance_id": { "type": "string", "minLength": 1 },
        "station_id": { "type": "string", "minLength": 1 },
        "station_run_id": { "type": "string", "minLength": 1 },
        "artifact_id": { "type": "string", "minLength": 1 },
        "evidence_id": { "type": "string", "minLength": 1 },
        "report_id": { "type": "string", "minLength": 1 },
        "handoff_id": { "type": "string", "minLength": 1 }
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
