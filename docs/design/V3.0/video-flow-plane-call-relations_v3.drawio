        <mxCell id="future_core" value="Core 扩展：&#xa;external artifact URI / preview / thumbnail / 大文件策略 / 长任务治理 / 失败恢复" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#64748B;fontSize=14;align=center" vertex="1" parent="1">
