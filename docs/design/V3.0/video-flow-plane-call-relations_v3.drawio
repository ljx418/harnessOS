        <mxCell id="future_input" value="输入：文生视频需求 / 长剧情 / 多角色 / 多镜头约束" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontSize=14;align=center" vertex="1" parent="1">
