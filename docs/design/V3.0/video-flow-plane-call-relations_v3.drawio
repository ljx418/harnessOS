        <mxCell id="future_connector" value="Connector 扩展：&#xa;remote_comfyui / TTS / FFmpeg / 素材检索 / 角色一致性模型&#xa;submit / poll / cancel / collect 真正闭环" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#64748B;fontSize=14;align=center" vertex="1" parent="1">
