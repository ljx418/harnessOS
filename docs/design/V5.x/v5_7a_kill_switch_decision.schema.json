{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v5_7a_kill_switch_decision.schema.json",
  "title": "V5-7A KillSwitchDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kill_switch_decision_id",
    "scope",
    "scope_ref",
    "decision",
    "reason",
    "checked_before_runtime_action",
    "checked_at",
    "checked_by",
    "policy_ref",
    "correlation_id",
    "created_at"
  ],
  "properties": {
    "kill_switch_decision_id": { "type": "string", "minLength": 1 },
    "scope": {
      "type": "string",
      "enum": ["tenant", "workspace", "app", "workflow_instance", "operation"]
    },
    "scope_ref": { "type": "string", "minLength": 1 },
    "decision": {
      "type": "string",
      "enum": ["allow", "deny"]
    },
    "reason": { "type": "string" },
    "checked_before_runtime_action": { "const": true },
    "checked_at": { "type": "string", "format": "date-time" },
    "checked_by": { "type": "string", "minLength": 1 },
    "policy_ref": { "type": "string", "minLength": 1 },
    "correlation_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
