{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v9/artifact_lineage_record.schema.json",
  "title": "V9 ArtifactLineageRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "lineage_record_id",
    "artifact_id",
    "producer_agent_id",
    "producer_attempt_id",
    "producer_station_id",
    "producer_station_run_id",
    "input_artifact_refs",
    "output_artifact_ref",
    "correlation_id",
    "request_id",
    "audit_ref",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "v9.0" },
    "lineage_record_id": { "type": "string", "minLength": 1 },
    "artifact_id": { "type": "string", "minLength": 1 },
    "producer_agent_id": { "type": "string", "minLength": 1 },
    "producer_attempt_id": { "type": "string", "minLength": 1 },
    "producer_station_id": { "type": "string", "minLength": 1 },
    "producer_station_run_id": { "type": "string", "minLength": 1 },
    "input_artifact_refs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "output_artifact_ref": { "type": "string", "minLength": 1 },
    "correlation_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "audit_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
