{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v9/agent_execution_envelope.schema.json",
  "title": "V9 AgentExecutionEnvelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "execution_envelope_id",
    "operation",
    "source",
    "actor_type",
    "actor_id",
    "agent_id",
    "station_id",
    "tenant_id",
    "workspace_id",
    "project_id",
    "app_id",
    "workflow_instance_id",
    "station_run_id",
    "target_refs",
    "payload_refs",
    "user_confirmed",
    "human_authorization_ref",
    "capability_decision_ref",
    "approval_gate_ref",
    "idempotency_key",
    "timeout_policy_ref",
    "kill_switch_policy_ref",
    "rollback_descriptor_ref",
    "correlation_id",
    "request_id",
    "audit_ref",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "v9.0" },
    "execution_envelope_id": { "type": "string", "minLength": 1 },
    "operation": { "$ref": "#/$defs/operation" },
    "source": { "enum": ["product_console", "approved_api", "mission_tui", "agent"] },
    "actor_type": { "enum": ["human_user", "service_account_with_human_authorization", "agent"] },
    "actor_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "station_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "app_id": { "type": "string", "minLength": 1 },
    "workflow_instance_id": { "type": "string", "minLength": 1 },
    "station_run_id": { "type": "string", "minLength": 1 },
    "target_refs": { "$ref": "#/$defs/target_refs" },
    "payload_refs": {
      "type": "array",
      "items": { "type": "string", "pattern": "^(artifact|prompt|context|diff|report|evidence)_ref:" },
      "uniqueItems": true
    },
    "user_confirmed": { "type": "boolean" },
    "human_authorization_ref": { "type": ["string", "null"], "minLength": 1 },
    "capability_decision_ref": { "type": "string", "minLength": 1 },
    "approval_gate_ref": { "type": ["string", "null"], "minLength": 1 },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "timeout_policy_ref": { "type": "string", "minLength": 1 },
    "kill_switch_policy_ref": { "type": "string", "minLength": 1 },
    "rollback_descriptor_ref": { "type": ["string", "null"], "minLength": 1 },
    "correlation_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "audit_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": { "properties": { "operation": { "const": "workflow.instance.start" } } },
      "then": { "properties": { "target_refs": { "required": ["workflow_instance_id"] } } }
    },
    {
      "if": { "properties": { "operation": { "const": "station.rerun" } } },
      "then": { "properties": { "target_refs": { "required": ["station_id", "station_run_id"] } } }
    },
    {
      "if": {
        "properties": {
          "operation": {
            "enum": ["workflow.instance.start", "station.rerun", "artifact.write", "quality.evaluation.create"]
          }
        }
      },
      "then": {
        "anyOf": [
          { "properties": { "user_confirmed": { "const": true } } },
          { "required": ["human_authorization_ref"], "properties": { "human_authorization_ref": { "type": "string", "minLength": 1 } } }
        ]
      }
    },
    {
      "if": { "properties": { "source": { "const": "agent" } } },
      "then": {
        "not": {
          "properties": {
            "operation": {
              "enum": ["workflow.instance.start", "station.rerun", "artifact.write", "quality.evaluation.create"]
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "operation": {
      "enum": ["workflow.instance.start", "station.rerun", "artifact.write", "quality.evaluation.create"]
    },
    "target_refs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "workflow_instance_id": { "type": "string", "minLength": 1 },
        "station_id": { "type": "string", "minLength": 1 },
        "station_run_id": { "type": "string", "minLength": 1 },
        "artifact_id": { "type": "string", "minLength": 1 },
        "quality_evaluation_id": { "type": "string", "minLength": 1 }
      },
      "minProperties": 1
    }
  }
}
