{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v9/kill_switch_decision.schema.json",
  "title": "V9 KillSwitchDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kill_switch_policy_ref",
    "operation",
    "checked_at",
    "checked_by",
    "allowed",
    "denial_reason",
    "correlation_id",
    "audit_ref"
  ],
  "properties": {
    "schema_version": { "const": "v9.0" },
    "kill_switch_policy_ref": { "type": "string", "minLength": 1 },
    "operation": { "type": "string", "minLength": 1 },
    "checked_at": { "type": "string", "format": "date-time" },
    "checked_by": { "type": "string", "minLength": 1 },
    "allowed": { "type": "boolean" },
    "denial_reason": { "type": ["string", "null"] },
    "correlation_id": { "type": "string", "minLength": 1 },
    "audit_ref": { "type": "string", "minLength": 1 }
  }
}
