{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v9_3_orchestration_run.schema.json",
  "title": "V9-3 OrchestrationRun",
  "type": "object",
  "required": [
    "schema_version",
    "orchestration_run_id",
    "workflow_instance_id",
    "status",
    "agent_ids",
    "station_ids",
    "branch_ids",
    "runtime_backed",
    "evidence_scope",
    "correlation_id",
    "request_id",
    "audit_ref",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "v9_3.orchestration_run.v1" },
    "orchestration_run_id": { "type": "string", "minLength": 1 },
    "workflow_instance_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["created", "running", "succeeded", "failed", "accepted_partial"] },
    "agent_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "station_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "branch_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "runtime_backed": { "const": true },
    "evidence_scope": { "enum": ["real_runtime_fixture", "real_runtime"] },
    "correlation_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "audit_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
