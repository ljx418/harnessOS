{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v9/orchestration_message.schema.json",
  "title": "V9 OrchestrationMessage",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "message_id",
    "orchestration_run_id",
    "sender_agent_id",
    "receiver_agent_id",
    "station_id",
    "station_run_id",
    "attempt_id",
    "branch_id",
    "message_kind",
    "payload_refs",
    "artifact_refs",
    "correlation_id",
    "request_id",
    "audit_ref",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "v9.0" },
    "message_id": { "type": "string", "minLength": 1 },
    "orchestration_run_id": { "type": "string", "minLength": 1 },
    "sender_agent_id": { "type": "string", "minLength": 1 },
    "receiver_agent_id": { "type": "string", "minLength": 1 },
    "station_id": { "type": "string", "minLength": 1 },
    "station_run_id": { "type": "string", "minLength": 1 },
    "attempt_id": { "type": "string", "minLength": 1 },
    "branch_id": { "type": "string", "minLength": 1 },
    "message_kind": { "enum": ["task", "result", "review", "synthesis", "conflict", "recovery"] },
    "payload_refs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "artifact_refs": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
    "correlation_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "audit_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
