{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v9_3_conflict_review_record.schema.json",
  "title": "V9-3 ConflictReviewRecord",
  "type": "object",
  "required": [
    "schema_version",
    "conflict_review_id",
    "orchestration_run_id",
    "input_artifact_refs",
    "conflict_summary_ref",
    "review_decision",
    "human_review_required",
    "audit_ref",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "v9_3.conflict_review_record.v1" },
    "conflict_review_id": { "type": "string", "minLength": 1 },
    "orchestration_run_id": { "type": "string", "minLength": 1 },
    "input_artifact_refs": { "type": "array", "minItems": 2, "items": { "type": "string", "minLength": 1 } },
    "conflict_summary_ref": { "type": "string", "minLength": 1 },
    "review_decision": { "enum": ["accept_one", "merge_with_attribution", "request_human_review", "block_join"] },
    "human_review_required": { "type": "boolean" },
    "audit_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
