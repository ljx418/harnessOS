{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v9_3_fan_in_join_decision.schema.json",
  "title": "V9-3 FanInJoinDecision",
  "type": "object",
  "required": [
    "schema_version",
    "join_decision_id",
    "orchestration_run_id",
    "target_branch_id",
    "input_branch_ids",
    "input_artifact_refs",
    "attribution_refs",
    "missing_input_refs",
    "conflict_review_ref",
    "decision",
    "synthesis_artifact_ref",
    "correlation_id",
    "request_id",
    "audit_ref",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "v9_3.fan_in_join_decision.v1" },
    "join_decision_id": { "type": "string", "minLength": 1 },
    "orchestration_run_id": { "type": "string", "minLength": 1 },
    "target_branch_id": { "type": "string", "minLength": 1 },
    "input_branch_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "input_artifact_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "attribution_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "missing_input_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "conflict_review_ref": { "type": ["string", "null"], "minLength": 1 },
    "decision": { "enum": ["ready_to_synthesize", "conflict_review_required", "accepted_partial", "blocked"] },
    "synthesis_artifact_ref": { "type": ["string", "null"], "minLength": 1 },
    "correlation_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "audit_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
