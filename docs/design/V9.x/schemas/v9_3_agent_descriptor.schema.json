{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v9_3_agent_descriptor.schema.json",
  "title": "V9-3 AgentDescriptor",
  "type": "object",
  "required": [
    "schema_version",
    "agent_id",
    "role",
    "goal",
    "memory_refs",
    "tool_refs",
    "skill_refs",
    "mcp_refs",
    "model_ref",
    "policy_ref",
    "credential_decision_ref",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "v9_3.agent_descriptor.v1" },
    "agent_id": { "type": "string", "minLength": 1 },
    "role": { "type": "string", "minLength": 1 },
    "goal": { "type": "string", "minLength": 1 },
    "memory_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "tool_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "skill_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "mcp_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "model_ref": { "type": "string", "minLength": 1 },
    "policy_ref": { "type": "string", "minLength": 1 },
    "credential_decision_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
