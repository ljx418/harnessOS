{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v9_3_fan_out_dispatch.schema.json",
  "title": "V9-3 FanOutDispatch",
  "type": "object",
  "required": [
    "schema_version",
    "dispatch_id",
    "orchestration_run_id",
    "source_branch_id",
    "target_branch_ids",
    "input_artifact_refs",
    "policy_decision_ref",
    "correlation_id",
    "request_id",
    "audit_ref",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "v9_3.fan_out_dispatch.v1" },
    "dispatch_id": { "type": "string", "minLength": 1 },
    "orchestration_run_id": { "type": "string", "minLength": 1 },
    "source_branch_id": { "type": "string", "minLength": 1 },
    "target_branch_ids": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "input_artifact_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "policy_decision_ref": { "type": "string", "minLength": 1 },
    "correlation_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "audit_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
