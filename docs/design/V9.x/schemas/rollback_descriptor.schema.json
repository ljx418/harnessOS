{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v9/rollback_descriptor.schema.json",
  "title": "V9 RollbackDescriptor",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "rollback_descriptor_ref",
    "operation",
    "rollback_strategy",
    "correction_artifact_required",
    "previous_state_ref",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "v9.0" },
    "rollback_descriptor_ref": { "type": "string", "minLength": 1 },
    "operation": { "type": "string", "minLength": 1 },
    "rollback_strategy": {
      "enum": ["append_correction", "retract_ref", "mark_failed", "return_prior_idempotency_ref"]
    },
    "correction_artifact_required": { "type": "boolean" },
    "previous_state_ref": { "type": ["string", "null"], "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
