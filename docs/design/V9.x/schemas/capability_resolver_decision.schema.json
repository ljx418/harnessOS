{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v9/capability_resolver_decision.schema.json",
  "title": "V9 CapabilityResolverDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "capability_decision_ref",
    "operation",
    "decision",
    "risk_level",
    "requires_user_confirmation",
    "requires_human_authorization_ref",
    "requires_approval_gate",
    "denial_reason",
    "policy_ref",
    "tenant_id",
    "workspace_id",
    "project_id",
    "app_id",
    "correlation_id",
    "request_id",
    "audit_ref",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "v9.0" },
    "capability_decision_ref": { "type": "string", "minLength": 1 },
    "operation": { "enum": ["workflow.instance.start", "station.rerun", "artifact.write", "quality.evaluation.create"] },
    "decision": { "enum": ["allow", "deny"] },
    "risk_level": { "enum": ["low", "medium", "high", "critical"] },
    "requires_user_confirmation": { "type": "boolean" },
    "requires_human_authorization_ref": { "type": "boolean" },
    "requires_approval_gate": { "type": "boolean" },
    "denial_reason": { "type": ["string", "null"] },
    "policy_ref": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "app_id": { "type": "string", "minLength": 1 },
    "correlation_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "audit_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
