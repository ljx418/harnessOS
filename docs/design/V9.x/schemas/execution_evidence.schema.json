{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v9/execution_evidence.schema.json",
  "title": "V9 ExecutionEvidence",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "execution_evidence_ref",
    "execution_envelope_id",
    "operation",
    "source",
    "actor_type",
    "agent_id",
    "station_id",
    "target_refs",
    "capability_decision_ref",
    "approval_gate_ref",
    "human_authorization_ref",
    "runtime_result_ref",
    "rollback_descriptor_ref",
    "redaction_status",
    "correlation_id",
    "request_id",
    "audit_ref",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "v9.0" },
    "execution_evidence_ref": { "type": "string", "minLength": 1 },
    "execution_envelope_id": { "type": "string", "minLength": 1 },
    "operation": { "type": "string", "minLength": 1 },
    "source": { "enum": ["product_console", "approved_api", "mission_tui", "agent"] },
    "actor_type": { "enum": ["human_user", "service_account_with_human_authorization", "agent"] },
    "agent_id": { "type": "string", "minLength": 1 },
    "station_id": { "type": "string", "minLength": 1 },
    "target_refs": { "type": "object", "minProperties": 1, "additionalProperties": { "type": "string" } },
    "capability_decision_ref": { "type": "string", "minLength": 1 },
    "approval_gate_ref": { "type": ["string", "null"], "minLength": 1 },
    "human_authorization_ref": { "type": ["string", "null"], "minLength": 1 },
    "runtime_result_ref": { "type": "string", "minLength": 1 },
    "rollback_descriptor_ref": { "type": ["string", "null"], "minLength": 1 },
    "redaction_status": { "enum": ["PASS", "FAIL"] },
    "correlation_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "audit_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
