{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v9_3_lost_worker_recovery_decision.schema.json",
  "title": "V9-3 LostWorkerRecoveryDecision",
  "type": "object",
  "required": [
    "schema_version",
    "recovery_decision_id",
    "orchestration_run_id",
    "failed_attempt_id",
    "replacement_attempt_id",
    "lost_worker_id",
    "replacement_worker_id",
    "previous_checkpoint_ref",
    "old_attempt_retained",
    "old_error_ref",
    "decision",
    "policy_decision_ref",
    "credential_decision_ref",
    "incident_timeline_ref",
    "correlation_id",
    "request_id",
    "audit_ref",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "v9_3.lost_worker_recovery_decision.v1" },
    "recovery_decision_id": { "type": "string", "minLength": 1 },
    "orchestration_run_id": { "type": "string", "minLength": 1 },
    "failed_attempt_id": { "type": "string", "minLength": 1 },
    "replacement_attempt_id": { "type": "string", "minLength": 1 },
    "lost_worker_id": { "type": "string", "minLength": 1 },
    "replacement_worker_id": { "type": "string", "minLength": 1 },
    "previous_checkpoint_ref": { "type": "string", "minLength": 1 },
    "old_attempt_retained": { "const": true },
    "old_error_ref": { "type": "string", "minLength": 1 },
    "decision": { "enum": ["retry", "recover", "mark_failed"] },
    "policy_decision_ref": { "type": "string", "minLength": 1 },
    "credential_decision_ref": { "type": "string", "minLength": 1 },
    "incident_timeline_ref": { "type": "string", "minLength": 1 },
    "correlation_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "audit_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
