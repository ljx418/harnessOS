{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v9_3_attempt_history_record.schema.json",
  "title": "V9-3 AttemptHistoryRecord",
  "type": "object",
  "required": [
    "schema_version",
    "attempt_id",
    "orchestration_run_id",
    "station_id",
    "station_run_id",
    "agent_id",
    "attempt_number",
    "previous_attempt_id",
    "status",
    "error_ref",
    "checkpoint_ref",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "v9_3.attempt_history_record.v1" },
    "attempt_id": { "type": "string", "minLength": 1 },
    "orchestration_run_id": { "type": "string", "minLength": 1 },
    "station_id": { "type": "string", "minLength": 1 },
    "station_run_id": { "type": "string", "minLength": 1 },
    "agent_id": { "type": "string", "minLength": 1 },
    "attempt_number": { "type": "integer", "minimum": 1 },
    "previous_attempt_id": { "type": ["string", "null"], "minLength": 1 },
    "status": { "enum": ["running", "succeeded", "failed", "recovered", "marked_failed"] },
    "error_ref": { "type": ["string", "null"], "minLength": 1 },
    "checkpoint_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "allOf": [
    {
      "if": { "properties": { "attempt_number": { "const": 1 } }, "required": ["attempt_number"] },
      "then": { "properties": { "previous_attempt_id": { "type": "null" } } }
    },
    {
      "if": { "properties": { "attempt_number": { "minimum": 2 } }, "required": ["attempt_number"] },
      "then": { "properties": { "previous_attempt_id": { "type": "string", "minLength": 1 } } }
    }
  ],
  "additionalProperties": false
}
