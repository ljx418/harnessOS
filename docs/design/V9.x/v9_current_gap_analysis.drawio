        <mxCell id="m3" value="M3 / V9-3&lt;br&gt;Orchestration&lt;br&gt;PASS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;" vertex="1" parent="1"><mxGeometry x="600" y="170" width="150" height="110" as="geometry"/></mxCell>
        <mxCell id="m4" value="M4 / V9-4&lt;br&gt;Coding Workflow&lt;br&gt;PASS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;" vertex="1" parent="1"><mxGeometry x="770" y="170" width="150" height="110" as="geometry"/></mxCell>
        <mxCell id="m5" value="M5 / V9-5&lt;br&gt;Terminal Worker&lt;br&gt;PASS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;" vertex="1" parent="1"><mxGeometry x="940" y="170" width="150" height="110" as="geometry"/></mxCell>
        <mxCell id="m6" value="M6 / V9-6&lt;br&gt;Studio&lt;br&gt;PASS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1110" y="170" width="150" height="110" as="geometry"/></mxCell>
        <mxCell id="m7" value="M7 / V9-7&lt;br&gt;Governance&lt;br&gt;PASS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1280" y="170" width="150" height="110" as="geometry"/></mxCell>
        <mxCell id="m8" value="M8 / V9-8&lt;br&gt;Final Acceptance&lt;br&gt;PASS with US-V9-08" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;" vertex="1" parent="1"><mxGeometry x="680" y="420" width="210" height="120" as="geometry"/></mxCell>
        <mxCell id="milestone-exit" value="最终出门条件&lt;br&gt;M0-M7 evidence packages exist&lt;br&gt;No FAIL / BLOCKED&lt;br&gt;high-risk decision refs exist&lt;br&gt;No False Green PASS&lt;br&gt;Redaction PASS&lt;br&gt;Drawio XML valid" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16;" vertex="1" parent="1"><mxGeometry x="440" y="650" width="720" height="170" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v9-acceptance" name="06 验收门槛">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title-6" value="V9 验收门槛：真实证据优先，文档不能冒充 runtime evidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=24;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="80" y="40" width="1440" height="70" as="geometry"/></mxCell>
        <mxCell id="gate-v92" value="V9-2 已通过门槛&lt;br&gt;policy / capability PASS&lt;br&gt;valid HAR 或 user_confirmed&lt;br&gt;approval for artifact/quality&lt;br&gt;kill switch / idempotency / timeout / rollback&lt;br&gt;redacted execution evidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;" vertex="1" parent="1"><mxGeometry x="120" y="170" width="380" height="210" as="geometry"/></mxCell>
        <mxCell id="gate-v93" value="V9-3 必须通过&lt;br&gt;schema parse PASS&lt;br&gt;fixture parse PASS&lt;br&gt;serial / parallel runtime evidence&lt;br&gt;fan-out / fan-in runtime evidence&lt;br&gt;failure + lost worker recovery&lt;br&gt;attempt history retained&lt;br&gt;artifact lineage producer_agent_id / producer_attempt_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cfe2f3;strokeColor=#3d85c6;fontSize=16;" vertex="1" parent="1"><mxGeometry x="610" y="170" width="380" height="210" as="geometry"/></mxCell>
        <mxCell id="gate-v94" value="V9-4 已通过门槛&lt;br&gt;diff proposal not patch apply&lt;br&gt;sandboxed test result&lt;br&gt;review summary not approval&lt;br&gt;fix-loop creates new proposal&lt;br&gt;no auto commit / push / deploy / patch apply" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;" vertex="1" parent="1"><mxGeometry x="1100" y="170" width="380" height="210" as="geometry"/></mxCell>
        <mxCell id="global-gates" value="全局验收硬门槛&lt;br&gt;source=agent default durable mutation always denied&lt;br&gt;durable mutation requires user_confirmed=true OR valid human_authorization_ref&lt;br&gt;Evidence Chain / Runtime Report read-only&lt;br&gt;raw secret / raw prompt / raw artifact content forbidden&lt;br&gt;No False Green claim scan PASS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16;" vertex="1" parent="1"><mxGeometry x="240" y="500" width="520" height="230" as="geometry"/></mxCell>
        <mxCell id="blocked-gates" value="阻断门槛&lt;br&gt;任何 forbidden claim 出现在正向完成语境&lt;br&gt;planning docs 被当作 runtime evidence&lt;br&gt;source=agent mutation 被允许&lt;br&gt;高风险阶段缺 human decision&lt;br&gt;证据缺失仍声明 complete" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=16;" vertex="1" parent="1"><mxGeometry x="850" y="500" width="520" height="230" as="geometry"/></mxCell>
        <mxCell id="user-scenario-gate" value="用户场景验收门槛 / V9-8 P0&lt;br&gt;每个阶段必须有可打开看板或报告&lt;br&gt;用户能看到目标、Agent 分工、运行状态、产物和证据链&lt;br&gt;runtime-backed 场景必须引用 real_runtime_fixture 或 real_runtime evidence&lt;br&gt;planning docs / transcript-only / report-only 不得满足 runtime-backed PASS&lt;br&gt;缺用户场景证据时 V9-8 BLOCKED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=16;" vertex="1" parent="1"><mxGeometry x="530" y="760" width="540" height="170" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v9-exit" name="07 出门条件与 No False Green">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title-7" value="V9 出门条件：只能声明 ready for review，不得升级为生产完成态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=24;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="80" y="40" width="1440" height="70" as="geometry"/></mxCell>
        <mxCell id="allowed" value="最终允许声明&lt;br&gt;V9 complete: high-risk Agent execution and workflow productization baseline ready for review.&lt;br&gt;&lt;br&gt;该声明需要：V9-0..V9-7 evidence packages、用户场景验收 PASS 或已记录 accepted PARTIAL、无 FAIL/BLOCKED、claim scan PASS、redaction PASS、drawio XML valid。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=16;" vertex="1" parent="1"><mxGeometry x="120" y="170" width="600" height="230" as="geometry"/></mxCell>
        <mxCell id="forbidden" value="禁止解释为&lt;br&gt;production ready&lt;br&gt;full production GA&lt;br&gt;Agent executor ready&lt;br&gt;controlled executor ready&lt;br&gt;production controlled executor ready&lt;br&gt;full multi-Agent orchestration ready&lt;br&gt;autonomous coding workflow ready&lt;br&gt;complete Workflow Studio ready&lt;br&gt;unrestricted terminal worker ready&lt;br&gt;production terminal automation ready" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=16;" vertex="1" parent="1"><mxGeometry x="880" y="170" width="600" height="300" as="geometry"/></mxCell>
        <mxCell id="review-paths" value="给外部审计的最小路径&lt;br&gt;00_README.md&lt;br&gt;v9_target_prd.md&lt;br&gt;v9_target_architecture.md&lt;br&gt;v9_current_gap_analysis.md / drawio&lt;br&gt;v9_development_and_acceptance_plan.md&lt;br&gt;v9_milestone_roadmap.md&lt;br&gt;v9_acceptance_gate_matrix.md&lt;br&gt;v9_document_audit_report.md&lt;br&gt;V9-1 / V9-2 evidence JSON" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=16;" vertex="1" parent="1"><mxGeometry x="170" y="570" width="510" height="260" as="geometry"/></mxCell>
        <mxCell id="final-blockers" value="V9-8 当前结论&lt;br&gt;final dashboard 已生成：status=PASS&lt;br&gt;US-V9-08 provider-backed image evidence recorded&lt;br&gt;4 张分镜图 artifact refs 与 sha256 已记录&lt;br&gt;claim / redaction / drawio gates PASS&lt;br&gt;允许 V9 ready-for-review final claim" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=16;" vertex="1" parent="1"><mxGeometry x="910" y="570" width="510" height="260" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v9-user-scenario-gate" name="08 用户场景验收门槛">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title-8" value="V9 用户场景验收门槛：当前能力、阶段目标体验、创意工作流验收" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=24;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="70" y="30" width="1460" height="60" as="geometry"/></mxCell>
        <mxCell id="current-capability" value="当前已能体验 / V9-2 PASS&lt;br&gt;打开 controlled runtime dashboard&lt;br&gt;审查 4 类受控动作：start / rerun / artifact.write / quality.evaluation.create&lt;br&gt;看到 policy、HumanAuthorizationRef、approval、kill switch、evidence chain&lt;br&gt;确认 source=agent durable mutation 被拒绝" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=15;" vertex="1" parent="1"><mxGeometry x="80" y="120" width="450" height="170" as="geometry"/></mxCell>
        <mxCell id="v93-target" value="V9-3 完成后的目标体验&lt;br&gt;自然语言触发多 Agent 编排 runtime slice&lt;br&gt;用户看到 station-bound Agents、串行/并行、fan-out/fan-in、attempt history、artifact lineage、失败恢复&lt;br&gt;输出 runtime dashboard + Evidence Chain" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#cfe2f3;strokeColor=#3d85c6;fontSize=15;" vertex="1" parent="1"><mxGeometry x="570" y="120" width="450" height="170" as="geometry"/></mxCell>
        <mxCell id="v9-final-target" value="V9 全阶段目标体验&lt;br&gt;目标输入 -&gt; 工作流/Agent 分工 -&gt; 用户确认 -&gt; 受控执行/协作 -&gt; 产物 -&gt; Studio/TUI 审计&lt;br&gt;最终只允许 ready for review，不是 production ready 或 complete Studio" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1060" y="120" width="450" height="170" as="geometry"/></mxCell>
        <mxCell id="us7" value="US-V9-07 / 罗马广场讨论&lt;br&gt;用户输入哲学话题&lt;br&gt;哲学家 / 工程师 / 历史学家 / 伦理学家多轮讨论&lt;br&gt;Moderator 合成共识与分歧&lt;br&gt;PASS 需要 message refs、attribution refs、Evidence Chain" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=15;" vertex="1" parent="1"><mxGeometry x="80" y="340" width="450" height="190" as="geometry"/></mxCell>
        <mxCell id="us8" value="US-V9-08 / 视频创作分镜工作流&lt;br&gt;用户输入 60 秒短视频点子&lt;br&gt;输出 brief、script、shot list、storyboard prompts、分镜图 artifact refs、review report&lt;br&gt;PASS 已记录 provider/model/invocation refs；无真实 provider artifacts 时只能 BLOCKED / fallback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=15;" vertex="1" parent="1"><mxGeometry x="570" y="340" width="450" height="190" as="geometry"/></mxCell>
        <mxCell id="us9" value="US-V9-09 / 自然语言优化工作流&lt;br&gt;用户说：减少 station、改变风格、增加安全审查 Agent&lt;br&gt;系统输出 WorkflowDiff proposal&lt;br&gt;用户确认前不得 durable mutation；source=agent 不得直接写 runtime truth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1060" y="340" width="450" height="190" as="geometry"/></mxCell>
        <mxCell id="core-scenarios" value="核心验收场景汇总&lt;br&gt;US-V9-01 受控执行审查：PASS&lt;br&gt;US-V9-02 多 Agent 技术评审：PASS&lt;br&gt;US-V9-03 代码工作流：PASS&lt;br&gt;US-V9-04 终端 worker：PASS&lt;br&gt;US-V9-05 Studio 审查：PASS&lt;br&gt;US-V9-06 最终看板：pending until US-V9-01..09 reviewed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=15;" vertex="1" parent="1"><mxGeometry x="100" y="590" width="660" height="230" as="geometry"/></mxCell>
        <mxCell id="us-rule" value="硬规则 / 防假绿&lt;br&gt;1. PASS 必须有 dashboard_or_report_ref 和 evidence_refs&lt;br&gt;2. runtime-backed 场景必须引用 real_runtime_fixture 或 real_runtime evidence&lt;br&gt;3. planning docs、transcript-only、report-only 不得满足 runtime-backed PASS&lt;br&gt;4. 分镜 placeholder 不得写成 provider-backed image generation&lt;br&gt;5. 自然语言优化必须先生成 Diff proposal；确认前不得 mutation&lt;br&gt;6. 任一必需场景 FAIL / BLOCKED / missing 且无人工 proceed decision，则 V9-8 BLOCKED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=15;" vertex="1" parent="1"><mxGeometry x="830" y="590" width="650" height="230" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
