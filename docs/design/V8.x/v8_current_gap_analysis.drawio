        <mxCell id="p1-experience-title" value="V8 用户体验主路径" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1f2937;fontColor=#ffffff;fontSize=20;fontStyle=1;strokeColor=#1f2937;" vertex="1" parent="1"><mxGeometry x="80" y="470" width="1440" height="50" as="geometry" /></mxCell>
        <mxCell id="p1-step1" value="1 输入目标&#xa;自然语言任务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="90" y="590" width="170" height="90" as="geometry" /></mxCell>
        <mxCell id="p1-step2" value="2 生成蓝图&#xa;WorkflowSpec + Agent 分配" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="310" y="590" width="190" height="90" as="geometry" /></mxCell>
