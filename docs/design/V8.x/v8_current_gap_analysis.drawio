        <mxCell id="p1-title" value="HarnessOS V8 目标：每个工位一个独立 Agent" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#111827;fontColor=#ffffff;fontSize=28;fontStyle=1;strokeColor=#111827;" vertex="1" parent="1"><mxGeometry x="50" y="40" width="1500" height="70" as="geometry" /></mxCell>
        <mxCell id="p1-v7" value="当前 V7 基线&#xa;小型工作室 + 可解释 TUI&#xa;自然语言可生成并运行本地文档工作流&#xa;但 station 不是独立 Agent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e5e7eb;strokeColor=#6b7280;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80" y="180" width="360" height="180" as="geometry" /></mxCell>
        <mxCell id="p1-v8" value="V8 目标&#xa;Station Agent Workflow Pilot&#xa;每个 station 有 AgentDescriptor&#xa;每个 Agent 有 role / goal / memory / model / tools / skills / MCP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="560" y="160" width="470" height="220" as="geometry" /></mxCell>
        <mxCell id="p1-high-risk" value="高风险后置能力&#xa;Codex CLI / Claude CLI / ChromeCLI&#xa;只能作为受控 worker / connector&#xa;必须有人类高风险确认" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1160" y="180" width="360" height="180" as="geometry" /></mxCell>
        <mxCell id="p1-a1" style="endArrow=block;html=1;strokeColor=#374151;strokeWidth=3;" edge="1" parent="1" source="p1-v7" target="p1-v8"><mxGeometry relative="1" as="geometry" /></mxCell>
