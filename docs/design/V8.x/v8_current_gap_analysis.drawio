        <mxCell id="p3-right-title" value="需要改造 / 高风险" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#b91c1c;fontColor=#ffffff;fontSize=20;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1110" y="150" width="400" height="50" as="geometry" /></mxCell>
        <mxCell id="p3-left" value="Small Studio Control Plane&#xa;Mission TUI&#xa;WorkflowSpec / Diff / Blueprint&#xa;Controlled Runtime Pilot&#xa;Runtime Report&#xa;Evidence Chain&#xa;V7 local Markdown real_runtime_fixture" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e5e7eb;strokeColor=#6b7280;fontSize=16;" vertex="1" parent="1"><mxGeometry x="80" y="240" width="360" height="360" as="geometry" /></mxCell>
        <mxCell id="p3-mid" value="StationAgentDescriptor&#xa;StationAgentRegistry&#xa;AgentRuntimeProfile&#xa;AgentMemoryPolicy&#xa;AgentSkillBinding&#xa;AgentMcpBinding&#xa;StationAgentContextEnvelope&#xa;WorkflowExplainerAgent&#xa;Agent run evidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="560" y="230" width="420" height="380" as="geometry" /></mxCell>
        <mxCell id="p3-right" value="固定 station 逻辑 -> Agent station&#xa;共享 provider adapter -> per-Agent model profile&#xa;普通 prompt -> scoped context envelope&#xa;Skill / MCP 从基础设施 -> per-Agent allowlist&#xa;Codex / Claude / ChromeCLI -> 高风险受控 worker&#xa;TUI 状态线 -> Agent 可解释面板" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1110" y="230" width="400" height="380" as="geometry" /></mxCell>
        <mxCell id="p3-a1" style="endArrow=block;html=1;strokeColor=#374151;strokeWidth=3;" edge="1" parent="1" source="p3-left" target="p3-mid"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3-a2" style="endArrow=block;html=1;strokeColor=#374151;strokeWidth=3;" edge="1" parent="1" source="p3-mid" target="p3-right"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p3-note" value="差异结论：V8 的核心不是再做一个 Web Studio，而是把 V7 工作流的每个 station 升级为可配置、可解释、可审计的独立 Agent。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="180" y="760" width="1240" height="90" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
