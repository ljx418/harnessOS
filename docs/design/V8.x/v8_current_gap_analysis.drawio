        <mxCell id="p4-s0" value="V8-0&#xa;规划门禁&#xa;已完成待审" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80" y="170" width="180" height="110" as="geometry" /></mxCell>
