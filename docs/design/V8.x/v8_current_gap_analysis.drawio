        <mxCell id="p4-s7" value="V8-7&#xa;多 Agent 项目工作流&#xa;bounded fixture PASS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="550" y="460" width="260" height="110" as="geometry" /></mxCell>
        <mxCell id="p4-s8" value="V8-8&#xa;Agent 可解释 TUI&#xa;read-model PASS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="890" y="460" width="250" height="110" as="geometry" /></mxCell>
        <mxCell id="p4-s9" value="V8-9&#xa;最终验收&#xa;bounded claim PASS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1220" y="460" width="230" height="110" as="geometry" /></mxCell>
        <mxCell id="p4-gate" value="阶段策略：V8-1~V8-4 已证明每站 Agent 基础与真实 LLM fixture；V8-6 完成只读 shell + handoff proposal fixture；V8-7 完成受限多 Agent 项目工作流 fixture；V8-8 完成只读解释 TUI；V8-9 只允许 bounded ready-for-review 声明。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=17;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="150" y="760" width="1300" height="90" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v8-page-5" name="05 验收门槛">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p5-title" value="V8 验收门槛与出门条件" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#111827;fontColor=#ffffff;fontSize=26;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="50" y="40" width="1500" height="70" as="geometry" /></mxCell>
        <mxCell id="p5-pass" value="必须证明的能力&#xa;1. 所有 station 都有 AgentDescriptor&#xa;2. 每个 Agent 有 role / goal / model / memory / skills / MCP / tools&#xa;3. 至少一个 WorkflowExplainerAgent&#xa;4. Agent context injection 有 evidence&#xa;5. Agent LLM invocation 有 provider/model evidence&#xa;6. Skill / MCP / Tool allowlist 生效&#xa;7. source=agent durable mutation 被拒绝" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="90" y="170" width="440" height="430" as="geometry" /></mxCell>
        <mxCell id="p5-stop" value="停止条件&#xa;1. Agent 直接 durable mutation&#xa;2. 绕过 user_confirmed=true&#xa;3. MCP / Tool 绕过 allowlist&#xa;4. raw secret / raw prompt / raw file content 泄露&#xa;5. terminal worker 越权执行&#xa;6. ChromeCLI 自动操作生产账号&#xa;7. 把 ready for review 写成 production ready" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="600" y="170" width="440" height="430" as="geometry" /></mxCell>
        <mxCell id="p5-claim" value="出门声明&#xa;允许：&#xa;V8 complete: station-agent workflow pilot ready for review.&#xa;&#xa;禁止：&#xa;Agent executor ready&#xa;autonomous coding workflow ready&#xa;full multi-Agent orchestration ready&#xa;complete Workflow Studio ready&#xa;unrestricted terminal worker ready" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1110" y="170" width="400" height="430" as="geometry" /></mxCell>
        <mxCell id="p5-cmd" value="验收命令规划&#xa;python -m pytest tests/test_v8_*.py -q&#xa;python -m pytest tests/test_v7_*.py -q&#xa;python -m pytest tests/test_v6_*.py -q&#xa;xmllint --noout docs/design/V8.x/v8_current_gap_analysis.drawio" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontSize=16;" vertex="1" parent="1"><mxGeometry x="230" y="720" width="1140" height="130" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v8-page-6" name="06 高风险边界">
