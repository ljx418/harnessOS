        <mxCell id="p2-title" value="V8 目标架构：Station Agent Operating Layer" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#111827;fontColor=#ffffff;fontSize=26;fontStyle=1;strokeColor=#111827;" vertex="1" parent="1"><mxGeometry x="50" y="40" width="1500" height="70" as="geometry" /></mxCell>
        <mxCell id="p2-head" value="交互入口&#xa;Mission TUI / Product Console" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80" y="170" width="230" height="90" as="geometry" /></mxCell>
