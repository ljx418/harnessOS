        <mxCell id="p1-legend" value="颜色规则：灰色=已有能力，绿色=V8 新增，黄色=需人工确认/治理，红色=高风险或禁止越界，蓝色=体验与证据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontSize=15;" vertex="1" parent="1"><mxGeometry x="180" y="810" width="1240" height="70" as="geometry" /></mxCell>
