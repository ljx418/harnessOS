        <mxCell id="p2-a2" style="endArrow=block;html=1;strokeColor=#374151;strokeWidth=2;" edge="1" parent="1" source="p2-spec" target="p2-registry"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-a3" style="endArrow=block;html=1;strokeColor=#374151;strokeWidth=2;" edge="1" parent="1" source="p2-registry" target="p2-runtime"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="p2-agent-layer" value="Station Agent Operating Layer" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#14532d;fontColor=#ffffff;fontSize=20;fontStyle=1;strokeColor=#14532d;" vertex="1" parent="1"><mxGeometry x="100" y="380" width="1400" height="50" as="geometry" /></mxCell>
        <mxCell id="p2-agent1" value="MissionAgent&#xa;捕获目标&#xa;解释入口状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="120" y="500" width="180" height="110" as="geometry" /></mxCell>
        <mxCell id="p2-agent2" value="PlannerAgent&#xa;生成 WorkflowSpec / Diff&#xa;不直接运行" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="340" y="500" width="200" height="110" as="geometry" /></mxCell>
        <mxCell id="p2-agent3" value="ScannerAgent&#xa;文件读取 MCP&#xa;只读授权路径" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="580" y="500" width="190" height="110" as="geometry" /></mxCell>
        <mxCell id="p2-agent4" value="SummaryAgent&#xa;LLM 总结&#xa;Skill: summarization" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="810" y="500" width="190" height="110" as="geometry" /></mxCell>
        <mxCell id="p2-agent5" value="QualityAgent&#xa;质量审查&#xa;artifact refs only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1040" y="500" width="190" height="110" as="geometry" /></mxCell>
        <mxCell id="p2-agent6" value="WorkflowExplainerAgent&#xa;解释流程 / 风险 / 证据&#xa;默认必有" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1270" y="500" width="220" height="110" as="geometry" /></mxCell>
        <mxCell id="p2-evidence" value="Evidence Chain / Runtime Report / Review Console&#xa;记录：Agent 身份、上下文、模型、Skill、MCP、工具调用、能力决策、产物、redaction&#xa;只读审计视图，不构造 runtime truth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="180" y="760" width="1240" height="120" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v8-page-3" name="03 当前差异">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
