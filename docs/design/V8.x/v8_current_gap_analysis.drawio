        <mxCell id="p3-left-title" value="V7 已有 / 可继承" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#4b5563;fontColor=#ffffff;fontSize=20;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80" y="150" width="360" height="50" as="geometry" /></mxCell>
