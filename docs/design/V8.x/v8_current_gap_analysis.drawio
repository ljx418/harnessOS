        <mxCell id="p2-runtime" value="运行与治理&#xa;Controlled Runtime&#xa;Terminal Worker Handoff&#xa;user_confirmed=true" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1190" y="150" width="300" height="130" as="geometry" /></mxCell>
