        <mxCell id="p4-s2" value="V8-2&#xa;上下文与记忆&#xa;已完成待审" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="540" y="170" width="180" height="110" as="geometry" /></mxCell>
        <mxCell id="p4-s3" value="V8-3&#xa;Skill / MCP / Tool&#xa;已完成待审" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="770" y="170" width="180" height="110" as="geometry" /></mxCell>
        <mxCell id="p4-s4" value="V8-4&#xa;Station Agent Runtime&#xa;真实 fixture PASS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1000" y="170" width="190" height="110" as="geometry" /></mxCell>
        <mxCell id="p4-s5" value="V8-5&#xa;Terminal Worker 设计门禁&#xa;完成待审 / runtime 未启用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1240" y="170" width="220" height="110" as="geometry" /></mxCell>
