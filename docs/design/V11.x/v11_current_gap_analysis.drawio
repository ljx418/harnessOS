        <mxCell id="before-title" value="当前体验问题" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#374151;fontColor=#ffffff;fontSize=22;fontStyle=1;strokeColor=#374151;" vertex="1" parent="1">
          <mxGeometry x="80" y="180" width="380" height="60" as="geometry" />
        </mxCell>
        <mxCell id="before1" value="用户输入后&lt;br&gt;TUI 可能无明显状态变化" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e5e7eb;strokeColor=#6b7280;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="80" y="290" width="380" height="110" as="geometry" />
        </mxCell>
        <mxCell id="before2" value="等待 provider / Gateway 时&lt;br&gt;缺少持续 running / heartbeat / elapsed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e5e7eb;strokeColor=#6b7280;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="80" y="450" width="380" height="110" as="geometry" />
        </mxCell>
        <mxCell id="before3" value="完成后展示结果&lt;br&gt;但用户难判断中间做了什么" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e5e7eb;strokeColor=#6b7280;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="80" y="610" width="380" height="110" as="geometry" />
        </mxCell>
        <mxCell id="after-title" value="V11 目标状态流" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#9a3412;fontColor=#ffffff;fontSize=22;fontStyle=1;strokeColor=#9a3412;" vertex="1" parent="1">
          <mxGeometry x="610" y="180" width="1180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="InputReceived&lt;br&gt;立即显示用户输入" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fed7aa;strokeColor=#ea580c;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="300" width="190" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="SessionReady&lt;br&gt;Gateway session ref 可见" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="850" y="300" width="190" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="TurnStarted&lt;br&gt;turn id / trace id 可见" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="1090" y="300" width="190" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="AgentRunning&lt;br&gt;运行中状态持续可见" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fed7aa;strokeColor=#ea580c;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1330" y="300" width="190" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s5" value="Streaming&lt;br&gt;assistant/tool/station events 可见" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fed7aa;strokeColor=#ea580c;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1570" y="300" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s6" value="ToolRunning&lt;br&gt;risk / sandbox / operation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="610" y="520" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s7" value="AwaitingConfirmation&lt;br&gt;confirm / revise / reject" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="890" y="520" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s8" value="RunningWorkflow&lt;br&gt;station progress / attempt refs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="1170" y="520" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="s9" value="EvidenceRecorded&lt;br&gt;runtime report / quality / evidence refs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="1450" y="520" width="250" height="90" as="geometry" />
        </mxCell>
        <mxCell id="fail" value="失败/阻断状态必须可见&lt;br&gt;ProviderFailed / ToolFailed / PolicyDenied / PermissionRequired / Timeout / Cancelled&lt;br&gt;turn.failed 不能算 completed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef2f2;strokeColor=#dc2626;fontColor=#991b1b;fontSize=17;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="790" width="1090" height="120" as="geometry" />
        </mxCell>
        <mxCell id="gate" value="V11 新增验收门槛：用户按回车后 1 个 repaint 周期内必须看到状态变化；运行中必须有 visible phase / trace / elapsed；失败必须有错误块和可追踪证据。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontSize=17;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="1070" width="1540" height="110" as="geometry" />
