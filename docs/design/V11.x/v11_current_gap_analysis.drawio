        </mxCell>
        <mxCell id="legend-gray" value="灰色：沿用已有" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e5e7eb;strokeColor=#6b7280;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="1150" y="40" width="250" height="72" as="geometry" />
        </mxCell>
        <mxCell id="legend-yellow" value="黄色：改造增强" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="1430" y="40" width="250" height="72" as="geometry" />
        </mxCell>
