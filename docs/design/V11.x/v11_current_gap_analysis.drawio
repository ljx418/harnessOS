  <diagram id="v11-target-state-flow" name="实时状态与事件流">
    <mxGraphModel dx="1422" dy="794" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1450" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="V11 关键变动：从静态报告式 TUI 到实时状态机 TUI" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#111827;fontColor=#ffffff;fontSize=30;fontStyle=1;strokeColor=#111827;" vertex="1" parent="1">
