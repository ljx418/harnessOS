        <mxCell id="df_e3" edge="1" parent="1" source="df3" target="df4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#475569;endArrow=block;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="df_e4" edge="1" parent="1" source="df4" target="df5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#475569;endArrow=block;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="df_now" value="当前状态&#xa;V6-7 已完成 / ready for review：repo-backed pilot runtime slice。&#xa;V6-8 已完成 / ready for review：Product Console projection。&#xa;V6-9 已完成 / ready for review：final acceptance aggregation。&#xa;V6 complete 只代表 production pilot baseline ready for review。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=16;fontStyle=1;align=left;spacing=12;" vertex="1" parent="1"><mxGeometry x="160" y="430" width="620" height="220" as="geometry"/></mxCell>
        <mxCell id="df_validation" value="每阶段统一验证&#xa;pytest tests/test_v6_*.py -q&#xa;pytest tests/test_v5_*.py -q&#xa;pytest tests/test_v4_u9_final_acceptance.py -q&#xa;xmllint --noout v6_current_gap_analysis.drawio&#xa;claim scan / redaction scan / PRD spec review" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#475569;fontSize=16;align=left;spacing=12;" vertex="1" parent="1"><mxGeometry x="850" y="430" width="560" height="260" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
