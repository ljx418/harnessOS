        <mxCell id="tp3" value="观测与审计导出平面&#xa;V6-3 已完成&#xa;AuditExportPackage / SecurityEventLog / IncidentTimeline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;" vertex="1" parent="1"><mxGeometry x="810" y="170" width="330" height="130" as="geometry"/></mxCell>
        <mxCell id="tp4" value="策略与能力平面&#xa;V6-4 已完成&#xa;PolicyDecision / risk flags / approval gate / source guard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;" vertex="1" parent="1"><mxGeometry x="1170" y="170" width="330" height="130" as="geometry"/></mxCell>
        <mxCell id="tp5" value="生产受控执行平面&#xa;V6-4 已完成&#xa;limited action set / idempotency / kill switch / evidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;" vertex="1" parent="1"><mxGeometry x="90" y="360" width="330" height="130" as="geometry"/></mxCell>
        <mxCell id="tp6" value="Agent 治理平面&#xa;V6-5 已完成&#xa;MiniMax intent / capability decision / handoff / mutation denial" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;" vertex="1" parent="1"><mxGeometry x="450" y="360" width="330" height="130" as="geometry"/></mxCell>
        <mxCell id="tp7" value="外部应用接入平面&#xa;V6-6 已完成&#xa;app registration / domain / origin / quota / offboarding / SDK guard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;" vertex="1" parent="1"><mxGeometry x="810" y="360" width="330" height="130" as="geometry"/></mxCell>
        <mxCell id="tp8" value="分布式运行时平面&#xa;V6-7 complete / ready for review&#xa;worker registry / checkpoint / attempt recovery / lineage&#xa;仍不等于 full orchestration ready" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;" vertex="1" parent="1"><mxGeometry x="1170" y="360" width="330" height="130" as="geometry"/></mxCell>
        <mxCell id="tp9" value="产品控制台平面&#xa;V6-8 complete / ready for review&#xa;Runtime Report / Evidence Review / Audit Export / Manual Confirmation UX&#xa;Full Workflow Studio 单独 PRD" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;" vertex="1" parent="1"><mxGeometry x="360" y="580" width="880" height="150" as="geometry"/></mxCell>
        <mxCell id="tp_truth" value="所有平面必须遵守同一治理边界：tenant-bound、credential-ref-only、audit-evidence-required、source=agent direct mutation denied、read models do not construct runtime truth。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#475569;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="170" y="820" width="1260" height="90" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v6_spec_matrix" name="04 功能规格矩阵">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="sm_title" value="V6 功能规格矩阵：能力、证据、边界" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="80" y="40" width="1440" height="70" as="geometry"/></mxCell>
        <mxCell id="sm_table" value="阶段 | 用户可感知能力 | 必备证据 | 禁止误报&#xa;&#xa;V6-1 | 生产用户 / 租户 / workspace / app 边界 | cross-tenant denial、actor refs、scope audit | enterprise auth ready&#xa;&#xa;V6-2 | 配置 provider / credential refs | lease、rotation、revocation、provider invocation evidence、redaction PASS | production secret lifecycle ready&#xa;&#xa;V6-3 | 审计导出、事件、incident timeline | export JSON、correlation coverage、source=agent export denial | production audit export ready&#xa;&#xa;V6-4 | 用户确认后执行有限 action set | envelope、approval、idempotency、kill switch、execution evidence | production controlled executor ready&#xa;&#xa;V6-5 | Agent 生成 intent 并 handoff | MiniMax evidence、capability decision、source=agent denial | Agent executor ready&#xa;&#xa;V6-6 | 外部应用按租户接入 | domain before origin、quota denial、offboarding revoke、SDK route guard | production-ready external app support&#xa;&#xa;V6-7A | 分布式运行时文档闭环 | state machine、I/O、worker lifecycle、recovery matrix | implementation ready&#xa;&#xa;V6-7B | 分布式运行时产品化 | worker recovery、attempt history、producer_attempt_id、tenant/policy boundary | full multi-Agent orchestration ready&#xa;&#xa;V6-8 | 产品控制台观察与确认 | read-only report / evidence review、manual confirmation UX | complete Workflow Studio ready&#xa;&#xa;V6-9 | 最终生产试点验收 | HTML dashboard、No False Green、redaction、drawio XML | full production GA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#475569;fontSize=15;align=left;spacing=14;" vertex="1" parent="1"><mxGeometry x="120" y="160" width="1360" height="740" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
