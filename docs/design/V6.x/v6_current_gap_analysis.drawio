        <mxCell id="df5" value="Completion Note&#xa;Allowed claim、forbidden claims、validation commands、next stage audit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;" vertex="1" parent="1"><mxGeometry x="1290" y="180" width="250" height="120" as="geometry"/></mxCell>
