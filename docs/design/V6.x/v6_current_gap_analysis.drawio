        <mxCell id="ms_title" value="V6 项目里程碑" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="80" y="40" width="1440" height="70" as="geometry"/></mxCell>
        <mxCell id="ms1" value="M1 规划冻结&#xa;V6-0 已完成&#xa;PRD / 架构 / gap / claim guard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80" y="180" width="240" height="150" as="geometry"/></mxCell>
        <mxCell id="ms2" value="M2 生产边界底座&#xa;V6-1 / V6-2 / V6-3 已完成&#xa;身份、凭证、审计" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="360" y="180" width="260" height="150" as="geometry"/></mxCell>
        <mxCell id="ms3" value="M3 受控执行与 Agent 治理&#xa;V6-4 / V6-5 已完成&#xa;有限执行 + Agent intent handoff" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="660" y="180" width="280" height="150" as="geometry"/></mxCell>
        <mxCell id="ms4" value="M4 产品与外部接入&#xa;V6-6 已完成；V6-8 已完成&#xa;外部应用 + Product Console" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="980" y="180" width="260" height="150" as="geometry"/></mxCell>
        <mxCell id="ms5" value="M5 分布式运行时产品化&#xa;V6-7 complete / ready for review&#xa;worker recovery + attempt history + lineage evidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1280" y="180" width="240" height="150" as="geometry"/></mxCell>
