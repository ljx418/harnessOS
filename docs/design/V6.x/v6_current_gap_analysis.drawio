<mxfile host="app.diagrams.net" modified="2026-06-03T00:00:00.000Z" agent="Codex" version="24.7.17" type="device">
  <diagram id="v6_reading_guide" name="01 阅读指南">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="rg_title" value="HarnessOS V6 生产试点图册&#xa;当前基线：V6 complete / production pilot baseline ready for review" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="100" y="50" width="1400" height="90" as="geometry"/></mxCell>
        <mxCell id="rg_scope" value="本图册用途&#xa;1. 对齐 V6 目标 PRD、目标架构、gap、里程碑和验收门槛&#xa;2. 标明当前已完成切片与剩余差距&#xa;3. 明确哪些能力仍禁止声明&#xa;4. 给 ChatGPT 外部审计提供可视入口" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfeff;strokeColor=#0891b2;fontSize=16;align=left;spacing=12;" vertex="1" parent="1"><mxGeometry x="120" y="210" width="620" height="260" as="geometry"/></mxCell>
        <mxCell id="rg_baseline" value="当前完成边界&#xa;V6-1：身份与租户 pilot slice&#xa;V6-2：凭证与供应商 pilot slice&#xa;V6-3：观测与审计导出 pilot slice&#xa;V6-4：有限生产受控执行 pilot slice&#xa;V6-5：MiniMax-backed AgentExecutionIntent pilot gate&#xa;V6-6：外部应用接入 pilot slice&#xa;&#xa;以上都只是 ready for review，不是完整生产 GA。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=16;align=left;spacing=12;" vertex="1" parent="1"><mxGeometry x="820" y="210" width="560" height="300" as="geometry"/></mxCell>
        <mxCell id="rg_next" value="V6 最终验收结果&#xa;V6-9：Final Production Pilot Acceptance 已完成 / ready for review&#xa;已汇总 V6-0 到 V6-8 evidence summary&#xa;No False Green、redaction 和 Drawio XML validation 均 PASS&#xa;&#xa;V6 complete 不等于 production ready 或 full production GA。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=16;align=left;spacing=12;" vertex="1" parent="1"><mxGeometry x="120" y="560" width="620" height="260" as="geometry"/></mxCell>
        <mxCell id="rg_forbidden" value="仍禁止完成声明&#xa;complete Workflow Studio ready&#xa;Agent executor ready&#xa;production controlled executor ready&#xa;production-ready external app support&#xa;full multi-Agent orchestration ready&#xa;distributed multi-Agent runtime ready&#xa;autonomous workflow editing ready" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=16;fontStyle=1;align=left;spacing=12;" vertex="1" parent="1"><mxGeometry x="820" y="560" width="560" height="280" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v6_current_target_delta" name="02 当前架构与目标架构差异">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="ct_title" value="当前架构与 V6 目标架构差异" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="90" y="50" width="1420" height="80" as="geometry"/></mxCell>
        <mxCell id="ct_v5" value="V5 / V4 继承输入&#xa;Headless Workflow Core&#xa;Mission Console&#xa;Workflow Blueprint / Drawio&#xa;Runtime Report&#xa;Review Console&#xa;Evidence Chain&#xa;Runtime Capability Matrix&#xa;WorkflowSpec Registry&#xa;bounded distributed runtime slice" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e5e7eb;strokeColor=#64748b;fontSize=15;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="80" y="210" width="360" height="410" as="geometry"/></mxCell>
        <mxCell id="ct_done" value="V6 已完成 pilot slice&#xa;V6-1 身份 / 租户边界&#xa;V6-2 凭证 / provider lifecycle&#xa;V6-3 观测 / 审计导出&#xa;V6-4 有限生产受控执行&#xa;V6-5 Agent 执行意图 / handoff&#xa;V6-6 外部应用接入&#xa;&#xa;证明：ready for review&#xa;不证明：完整生产 GA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=15;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="550" y="210" width="410" height="410" as="geometry"/></mxCell>
        <mxCell id="ct_remaining" value="V6 收口状态&#xa;V6-8 Product Console / Thin Web Console：已完成 / ready for review&#xa;V6-9 最终生产试点验收：已完成 / ready for review&#xa;&#xa;V6-7 已完成 pilot slice ready for review，但不证明 full multi-Agent orchestration ready。&#xa;&#xa;后续进入 V7 planning 时不得把 V6 反向升级成 production GA。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=15;align=left;spacing=10;" vertex="1" parent="1"><mxGeometry x="1070" y="210" width="430" height="410" as="geometry"/></mxCell>
        <mxCell id="ct_edge1" edge="1" parent="1" source="ct_v5" target="ct_done" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#64748b;endArrow=block;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ct_edge2" edge="1" parent="1" source="ct_done" target="ct_remaining" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeColor=#d97706;endArrow=block;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ct_boundary" value="Runtime Truth 边界&#xa;WorkflowSpec 不替代 WorkflowDraft / WorkflowVersion&#xa;Drawio / Blueprint 只读可视化&#xa;Runtime Report / Evidence Chain 只读&#xa;EventBridge 只 refresh&#xa;source=agent 不能直接 durable mutation&#xa;Product Console admin ops 不能构造 runtime truth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=16;fontStyle=1;align=left;spacing=12;" vertex="1" parent="1"><mxGeometry x="230" y="720" width="1140" height="180" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v6_target_planes" name="03 V6 目标架构平面">
