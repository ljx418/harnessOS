  <diagram id="v6_acceptance_gates" name="07 验收门槛">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="ag_title" value="V6 验收门槛：每阶段必须保留证据类型和边界说明" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="80" y="40" width="1440" height="70" as="geometry"/></mxCell>
        <mxCell id="ag_table" value="V6-0：canonical docs + Drawio XML valid + V5-8 handoff + claim guard PASS&#xa;V6-1：tenant / workspace / app / actor refs + cross-tenant denial + source=agent identity bypass denied&#xa;V6-2：CredentialLease tenant/app/audience/operation bound + no raw secret + revoke denial&#xa;V6-3：AuditExportPackage immutable/append-only + incident timeline read model + source=agent export denial&#xa;V6-4：limited actions only + user confirmation + approval gate + kill switch + idempotency + source=agent denial&#xa;V6-5：MiniMax-backed intent + policy/capability decision + human-confirmed handoff + no Agent executor claim&#xa;V6-6：DTO/schema + domain before origin + quota/rate denial + offboarding revoke + SDK no direct runtime route&#xa;V6-7：worker recovery + attempt history + producer_attempt_id + tenant-bound worker identity + claim scan PASS&#xa;V6-8：Runtime Report / Evidence Review read-only + manual confirmation UX + Full Studio separate PRD gate&#xa;V6-9：V6-0 到 V6-8 evidence exists + no FAIL/BLOCKED + claim scan PASS + redaction PASS + final HTML dashboard" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#475569;fontSize=15;align=left;spacing=13;" vertex="1" parent="1"><mxGeometry x="100" y="160" width="1400" height="620" as="geometry"/></mxCell>
        <mxCell id="ag_assertions" value="全局断言&#xa;source=agent 不能直接 durable mutation；durable mutation 必须 user confirmation / human_authorization_ref；Browser 不直连内部 runtime routes；raw secret / raw prompt / raw artifact content 不进入 evidence、HTML、JSON 或 logs。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="160" y="830" width="1280" height="100" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="v6_exit_stop" name="08 出门条件与停止条件">
    <mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="es_title" value="V6 出门条件与停止条件" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=22;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="80" y="40" width="1440" height="70" as="geometry"/></mxCell>
        <mxCell id="es_exit" value="V6-9 出门条件&#xa;V6-0 到 V6-8 均有 evidence summary，且 V6-6/7/8 evidence package exists&#xa;无 FAIL / BLOCKED&#xa;所有 PARTIAL 均有 proceed decision&#xa;No False Green scan PASS&#xa;redaction scan PASS&#xa;Drawio XML valid&#xa;最终 HTML 看板可打开&#xa;runtime truth 边界保持" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=16;align=left;spacing=12;" vertex="1" parent="1"><mxGeometry x="130" y="170" width="580" height="390" as="geometry"/></mxCell>
        <mxCell id="es_stop" value="立即停止条件&#xa;V6 文档把 V5/V6 slice 升级为 production-ready&#xa;source=agent durable mutation 成功&#xa;raw secret / raw prompt / raw artifact content 泄露&#xa;external app 绕过 tenant / credential / quota / origin boundary&#xa;worker 绕过 tenant / credential / policy boundary&#xa;Runtime Report / Evidence Chain 构造 runtime truth&#xa;Full Web Studio 成为默认 V6 前置&#xa;No False Green claim scan FAIL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=16;fontStyle=1;align=left;spacing=12;" vertex="1" parent="1"><mxGeometry x="870" y="170" width="580" height="430" as="geometry"/></mxCell>
        <mxCell id="es_chatgpt" value="给 ChatGPT 审计的重点&#xa;1. V6-7 是否只声明 pilot slice ready for review&#xa;2. V6-7 是否没有误报 full multi-Agent orchestration ready / Agent executor ready&#xa;3. V6-8 是否没有回到完整低代码 Studio 主线&#xa;4. V6-9 allowed claim 是否仍是 production pilot baseline ready for review&#xa;5. Drawio、PRD、架构、gap、里程碑和验收计划是否一致" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=16;fontStyle=1;align=left;spacing=12;" vertex="1" parent="1"><mxGeometry x="260" y="700" width="1080" height="180" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
