        <mxCell id="tp1" value="身份与租户控制面&#xa;V6-1 已完成&#xa;tenant / workspace / project / app / user / service_account refs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=14;" vertex="1" parent="1"><mxGeometry x="90" y="170" width="330" height="130" as="geometry"/></mxCell>
