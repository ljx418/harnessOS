{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v6_7_worker_assignment_schema.json",
  "title": "WorkerAssignment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "assignment_id",
    "worker_id",
    "tenant_id",
    "workspace_id",
    "project_id",
    "app_id",
    "workflow_instance_id",
    "station_id",
    "station_run_id",
    "attempt_id",
    "source",
    "credential_decision_ref",
    "policy_decision_ref",
    "checkpoint_ref",
    "correlation_id",
    "request_id",
    "audit_ref",
    "created_at"
  ],
  "properties": {
    "assignment_id": { "type": "string", "minLength": 1 },
    "worker_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "app_id": { "type": "string", "minLength": 1 },
    "workflow_instance_id": { "type": "string", "minLength": 1 },
    "station_id": { "type": "string", "minLength": 1 },
    "station_run_id": { "type": "string", "minLength": 1 },
    "attempt_id": { "type": "string", "minLength": 1 },
    "source": { "enum": ["product_console", "approved_api"] },
    "credential_decision_ref": { "type": "string", "minLength": 1 },
    "policy_decision_ref": { "type": "string", "minLength": 1 },
    "checkpoint_ref": { "type": "string", "minLength": 1 },
    "correlation_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "audit_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
