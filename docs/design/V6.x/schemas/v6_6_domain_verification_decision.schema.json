{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v6_6_domain_verification_decision.schema.json",
  "title": "DomainVerificationDecisionDTO",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tenant_id",
    "workspace_id",
    "app_id",
    "service_account_id",
    "actor_id",
    "request_id",
    "correlation_id",
    "audit_ref",
    "policy_decision",
    "created_at",
    "domain",
    "verification_method",
    "verification_status"
  ],
  "properties": {
    "tenant_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "app_id": { "type": "string", "minLength": 1 },
    "service_account_id": { "type": "string", "minLength": 1 },
    "actor_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "correlation_id": { "type": "string", "minLength": 1 },
    "audit_ref": { "type": "string", "minLength": 1 },
    "policy_decision": { "enum": ["allow", "deny", "needs_review"] },
    "created_at": { "type": "string", "format": "date-time" },
    "domain": { "type": "string", "minLength": 1 },
    "verification_method": { "enum": ["dns_txt", "http_file", "manual_review"] },
    "verification_status": { "enum": ["verified", "pending", "denied"] },
    "verified_at": { "type": ["string", "null"], "format": "date-time" },
    "denial_reason": { "type": ["string", "null"] }
  }
}
