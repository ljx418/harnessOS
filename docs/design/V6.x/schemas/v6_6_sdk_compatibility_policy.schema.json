{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v6_6_sdk_compatibility_policy.schema.json",
  "title": "SdkCompatibilityPolicyDTO",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "sdk_policy_id",
    "tenant_id",
    "workspace_id",
    "app_id",
    "service_account_id",
    "actor_id",
    "request_id",
    "correlation_id",
    "audit_ref",
    "policy_decision",
    "created_at",
    "allowed_bff_routes",
    "denied_internal_routes",
    "browser_direct_runtime_route_denied",
    "browser_direct_v1_rpc_denied",
    "browser_direct_v1_events_subscribe_denied"
  ],
  "properties": {
    "sdk_policy_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "app_id": { "type": "string", "minLength": 1 },
    "service_account_id": { "type": "string", "minLength": 1 },
    "actor_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "correlation_id": { "type": "string", "minLength": 1 },
    "audit_ref": { "type": "string", "minLength": 1 },
    "policy_decision": { "enum": ["allow", "deny", "needs_review"] },
    "created_at": { "type": "string", "format": "date-time" },
    "allowed_bff_routes": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "denied_internal_routes": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
    "browser_direct_runtime_route_denied": { "type": "boolean", "const": true },
    "browser_direct_v1_rpc_denied": { "type": "boolean", "const": true },
    "browser_direct_v1_events_subscribe_denied": { "type": "boolean", "const": true }
  }
}
