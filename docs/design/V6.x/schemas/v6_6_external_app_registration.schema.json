{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v6_6_external_app_registration.schema.json",
  "title": "ExternalAppRegistrationDTO",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registration_id",
    "tenant_id",
    "workspace_id",
    "app_id",
    "service_account_id",
    "actor_id",
    "request_id",
    "correlation_id",
    "audit_ref",
    "policy_decision",
    "created_at",
    "app_display_name",
    "domain_refs",
    "status"
  ],
  "properties": {
    "registration_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "app_id": { "type": "string", "minLength": 1 },
    "service_account_id": { "type": "string", "minLength": 1 },
    "actor_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "correlation_id": { "type": "string", "minLength": 1 },
    "audit_ref": { "type": "string", "minLength": 1 },
    "policy_decision": { "enum": ["allow", "deny", "needs_review"] },
    "created_at": { "type": "string", "format": "date-time" },
    "app_display_name": { "type": "string", "minLength": 1 },
    "domain_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
    "status": { "enum": ["registered", "pending_review", "denied", "offboarded"] }
  }
}
