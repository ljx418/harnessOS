{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v6_6_external_app_offboarding_evidence.schema.json",
  "title": "ExternalAppOffboardingEvidenceDTO",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "offboarding_id",
    "tenant_id",
    "workspace_id",
    "app_id",
    "service_account_id",
    "actor_id",
    "request_id",
    "correlation_id",
    "audit_ref",
    "policy_decision",
    "created_at",
    "revoked_app_credentials",
    "revoked_origin_allowlist",
    "revoked_active_sessions",
    "revoked_pending_capability_grants",
    "revocation_refs"
  ],
  "properties": {
    "offboarding_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "app_id": { "type": "string", "minLength": 1 },
    "service_account_id": { "type": "string", "minLength": 1 },
    "actor_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "correlation_id": { "type": "string", "minLength": 1 },
    "audit_ref": { "type": "string", "minLength": 1 },
    "policy_decision": { "enum": ["allow", "deny", "needs_review"] },
    "created_at": { "type": "string", "format": "date-time" },
    "revoked_app_credentials": { "type": "boolean", "const": true },
    "revoked_origin_allowlist": { "type": "boolean", "const": true },
    "revoked_active_sessions": { "type": "boolean", "const": true },
    "revoked_pending_capability_grants": { "type": "boolean", "const": true },
    "revocation_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  }
}
