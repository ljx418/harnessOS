{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v6_7_worker_recovery_decision_schema.json",
  "title": "WorkerRecoveryDecision",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recovery_decision_id",
    "distributed_run_id",
    "tenant_id",
    "workspace_id",
    "worker_id",
    "replacement_worker_id",
    "station_id",
    "station_run_id",
    "attempt_id",
    "failed_attempt_id",
    "failure_type",
    "decision",
    "recovery_strategy",
    "previous_checkpoint_ref",
    "policy_decision_ref",
    "credential_decision_ref",
    "old_attempt_retained",
    "created_at",
    "correlation_id",
    "request_id",
    "incident_timeline_ref",
    "audit_ref"
  ],
  "properties": {
    "recovery_decision_id": { "type": "string", "minLength": 1 },
    "distributed_run_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "worker_id": { "type": "string", "minLength": 1 },
    "replacement_worker_id": { "type": "string", "minLength": 1 },
    "station_id": { "type": "string", "minLength": 1 },
    "station_run_id": { "type": "string", "minLength": 1 },
    "attempt_id": { "type": "string", "minLength": 1 },
    "failed_attempt_id": { "type": "string", "minLength": 1 },
    "failure_type": { "enum": ["worker_lost", "timeout", "policy_denied", "credential_denied"] },
    "decision": { "enum": ["retry", "recover", "mark_failed"] },
    "recovery_strategy": { "enum": ["retry_same_worker", "retry_replacement_worker", "recover_from_checkpoint", "mark_failed"] },
    "previous_checkpoint_ref": { "type": "string", "minLength": 1 },
    "policy_decision_ref": { "type": "string", "minLength": 1 },
    "credential_decision_ref": { "type": "string", "minLength": 1 },
    "old_attempt_retained": { "type": "boolean", "const": true },
    "created_at": { "type": "string", "format": "date-time" },
    "correlation_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "incident_timeline_ref": { "type": "string", "minLength": 1 },
    "audit_ref": { "type": "string", "minLength": 1 }
  }
}
