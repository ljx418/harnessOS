{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v6_7_agent_worker_registry_schema.json",
  "title": "AgentWorkerRegistryEntry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "worker_id",
    "tenant_id",
    "workspace_id",
    "project_id",
    "app_id",
    "explicit_tenant_binding",
    "worker_type",
    "credential_decision_ref",
    "policy_decision_ref",
    "created_at",
    "audit_ref"
  ],
  "properties": {
    "worker_id": { "type": "string", "minLength": 1 },
    "tenant_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "app_id": { "type": "string", "minLength": 1 },
    "explicit_tenant_binding": { "type": "boolean", "const": true },
    "worker_type": { "enum": ["station_worker", "review_worker", "recovery_worker"] },
    "credential_decision_ref": { "type": "string", "minLength": 1 },
    "policy_decision_ref": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "audit_ref": { "type": "string", "minLength": 1 }
  }
}
