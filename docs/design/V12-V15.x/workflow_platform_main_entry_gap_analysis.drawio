  <diagram name="项目里程碑" id="4">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p5_title" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E3A8A;fontColor=#FFFFFF;strokeColor=#1E3A8A;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" value="项目里程碑：已验收基线、当前阶段、后置阶段" vertex="1">
          <mxGeometry x="40" y="30" width="1520" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p5_done1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=15;align=left;verticalAlign=top;spacing=12;" value="&lt;b&gt;WP-M1A-M5A 已验收&lt;/b&gt;&lt;br&gt;PV13 首页&lt;br&gt;画布交互&lt;br&gt;PV21/PV20 parity&lt;br&gt;业务输出摘要&lt;br&gt;bounded review only" vertex="1">
          <mxGeometry x="70" y="130" width="290" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p5_done2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=15;align=left;verticalAlign=top;spacing=12;" value="&lt;b&gt;WP-M5B/PV22 已验收&lt;/b&gt;&lt;br&gt;SDK/template/reference app&lt;br&gt;外部应用契约有界实现&lt;br&gt;不是外部生态完成" vertex="1">
          <mxGeometry x="420" y="130" width="290" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p5_now" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=15;align=left;verticalAlign=top;spacing=12;" value="&lt;b&gt;当前选择：WP-M6-M11&lt;/b&gt;&lt;br&gt;把 PRD 前端功能做成有界完成&lt;br&gt;从正常路径 mock 到真实数据闭环&lt;br&gt;从可审查演示到可审查工作台能力" vertex="1">
          <mxGeometry x="780" y="120" width="360" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p5_later" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=15;align=left;verticalAlign=top;spacing=12;" value="&lt;b&gt;WP-M11 后再选择&lt;/b&gt;&lt;br&gt;Path D 生产治理&lt;br&gt;业务 Pack 产品化&lt;br&gt;开源/商业化准备&lt;br&gt;Video/Meeting 等独立业务阶段" vertex="1">
          <mxGeometry x="1210" y="130" width="300" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p5_exit" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=15;align=left;verticalAlign=top;spacing=12;" value="&lt;b&gt;WP-M11 出门状态&lt;/b&gt;&lt;br&gt;允许：PRD-defined frontend functionality complete for bounded review。&lt;br&gt;必须有：数据源闭环、图编辑保存回读、发布运行人工证据、三业务产物、失败态/a11y/性能、claim-to-evidence matrix。&lt;br&gt;仍不允许：production ready / product-grade frontend complete / complete Workflow Studio ready。" vertex="1">
          <mxGeometry x="110" y="390" width="1380" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p5_risk" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=15;align=left;verticalAlign=top;spacing=12;fontStyle=1;" value="&lt;b&gt;里程碑风险&lt;/b&gt;&lt;br&gt;如果把 Path D 或 PV22 当成当前阶段，会继续绕开用户最关心的首页工作流平台体验。&lt;br&gt;如果把 WP-M6-M11 当成已完成，会形成虚假验收。当前只是文档开发和后续实现计划。" vertex="1">
          <mxGeometry x="110" y="640" width="1380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p5_e1" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#16A34A;endArrow=block;endFill=1;" value="" edge="1" source="p5_done1" target="p5_done2" />
        <mxCell id="p5_e2" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#2563EB;endArrow=block;endFill=1;" value="" edge="1" source="p5_done2" target="p5_now" />
        <mxCell id="p5_e3" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#2563EB;endArrow=block;endFill=1;" value="" edge="1" source="p5_now" target="p5_later" />
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="验收门槛与出门条件" id="5">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="p6_title" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E3A8A;fontColor=#FFFFFF;strokeColor=#1E3A8A;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" value="验收门槛与出门条件：用户能具体用项目做什么" vertex="1">
          <mxGeometry x="40" y="30" width="1520" height="60" as="geometry" />
        </mxCell>
        <mxCell id="p6_min" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=15;align=left;verticalAlign=top;spacing=12;" value="&lt;b&gt;最小工作流平台路径&lt;/b&gt;&lt;br&gt;打开首页 -&amp;gt; 选择场景 -&amp;gt; 拖动画布/节点 -&amp;gt; 连线/取消 -&amp;gt; 配置节点 -&amp;gt; 保存草稿 -&amp;gt; 校验 -&amp;gt; 审查 Diff -&amp;gt; 发布 -&amp;gt; 运行 -&amp;gt; Human Gate -&amp;gt; Evidence Review。&lt;br&gt;出门证据：截图、action log、network log、DTO snapshot、runtime inspect、human action、evidence panel。" vertex="1">
          <mxGeometry x="60" y="120" width="700" height="170" as="geometry" />
        </mxCell>
        <mxCell id="p6_doc" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=15;align=left;verticalAlign=top;spacing=12;" value="&lt;b&gt;业务场景 1：文档/知识总结&lt;/b&gt;&lt;br&gt;用户导入文档或 Markdown 文件夹。&lt;br&gt;平台执行解析、事实抽取、总结、质量检查和人工复核。&lt;br&gt;输出：摘要 artifact、引用 refs、quality refs、human review refs、redaction refs。" vertex="1">
          <mxGeometry x="820" y="120" width="700" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p6_code" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=15;align=left;verticalAlign=top;spacing=12;" value="&lt;b&gt;业务场景 2：代码审查&lt;/b&gt;&lt;br&gt;用户输入 Git diff、PR patch 或代码包。&lt;br&gt;平台执行静态检查、安全/风险审查、汇总报告和合规 Human Gate。&lt;br&gt;输出：审查 artifact、风险列表、测试/审计 refs、审批记录。" vertex="1">
          <mxGeometry x="820" y="300" width="700" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p6_meet" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=15;align=left;verticalAlign=top;spacing=12;" value="&lt;b&gt;业务场景 3：会议/访谈整理&lt;/b&gt;&lt;br&gt;用户输入 transcript 或 audio-derived text。&lt;br&gt;平台执行议题提取、行动项整理、事实核对和人工复核。&lt;br&gt;输出：纪要 artifact、行动项、决策/开放问题、引用证据和复核记录。" vertex="1">
          <mxGeometry x="820" y="480" width="700" height="150" as="geometry" />
        </mxCell>
        <mxCell id="p6_gates" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;align=left;verticalAlign=top;spacing=12;" value="&lt;b&gt;硬验收门槛&lt;/b&gt;&lt;br&gt;WP-M6：normal_path_static_sources == 0。&lt;br&gt;WP-M7：编辑/保存/刷新回读/Diff 全通过。&lt;br&gt;WP-M8：publish/run/human/evidence 同一工作台闭环。&lt;br&gt;WP-M9：三业务产物文件和证据链齐备。&lt;br&gt;WP-M10：失败态/a11y/响应式/性能齐备。&lt;br&gt;WP-M11：WP-FR-1..20 全部映射。" vertex="1">
          <mxGeometry x="60" y="330" width="700" height="190" as="geometry" />
        </mxCell>
        <mxCell id="p6_nogo" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=15;align=left;verticalAlign=top;spacing=12;fontStyle=1;" value="&lt;b&gt;出门失败条件&lt;/b&gt;&lt;br&gt;缺真实 BFF/DTO/browser/action/artifact evidence。&lt;br&gt;正常路径仍依赖本地 mock。&lt;br&gt;只展示未来应用前景。&lt;br&gt;把 bounded review 写成生产/GA/product-grade。" vertex="1">
          <mxGeometry x="60" y="570" width="700" height="140" as="geometry" />
        </mxCell>
        <mxCell id="p6_optional" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=15;align=left;verticalAlign=top;spacing=12;" value="&lt;b&gt;后续应用前景，不作为本阶段完成声明&lt;/b&gt;&lt;br&gt;创意分镜规划、外部工具/MCP 受治理自动化、外部 App 接入、业务 Pack 产品化。&lt;br&gt;这些需要独立 stage 和证据。" vertex="1">
          <mxGeometry x="820" y="660" width="700" height="120" as="geometry" />
        </mxCell>
        <mxCell id="p6_e1" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#2563EB;endArrow=block;endFill=1;" value="" edge="1" source="p6_min" target="p6_gates" />
        <mxCell id="p6_e2" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#D97706;endArrow=block;endFill=1;" value="" edge="1" source="p6_gates" target="p6_nogo" />
      </root>
    </mxGraphModel>
  </diagram>
