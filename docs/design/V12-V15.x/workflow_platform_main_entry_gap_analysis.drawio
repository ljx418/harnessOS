        <mxCell id="e52" style="endArrow=block;html=1;strokeColor=#2563EB;strokeWidth=2;" edge="1" parent="1" source="doc5" target="mvp5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e53" style="endArrow=block;html=1;strokeColor=#2563EB;strokeWidth=2;" edge="1" parent="1" source="mvp5" target="int5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e54" style="endArrow=block;html=1;strokeColor=#2563EB;strokeWidth=2;" edge="1" parent="1" source="int5" target="pv225">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e55" style="endArrow=block;html=1;strokeColor=#2563EB;strokeWidth=2;" edge="1" parent="1" source="pv225" target="pv235">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="guard5" value="里程碑口径&lt;br&gt;&lt;br&gt;WP-M0：文档可支撑实现。&lt;br&gt;WP-M1-M3：可审查 MVP 候选体验。&lt;br&gt;WP-M4：受治理 executor 产品化融合。&lt;br&gt;PV22：外部接入实现。&lt;br&gt;PV23+：生产治理和商业化前置工作。&lt;br&gt;&lt;br&gt;任何阶段均不得提前声明生产可用或 GA。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=16;align=left;spacingLeft=18;" vertex="1" parent="1">
          <mxGeometry x="80" y="570" width="1440" height="170" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="wp-m0-6" name="验收门槛与出门条件">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title6" value="验收门槛、出门条件与用户应用场景" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E3A8A;fontColor=#FFFFFF;strokeColor=#1E3A8A;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="40" width="1440" height="60" as="geometry" />
        </mxCell>
        <mxCell id="g0" value="WP-M0 文档门禁&lt;br&gt;文档齐全、互相一致、drawio 合格、claim scan PASS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="420" height="90" as="geometry" />
        </mxCell>
        <mxCell id="g1" value="WP-M1 用户首屏门禁&lt;br&gt;默认入口、workspace/project、状态、BFF network log、首屏截图" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="590" y="150" width="420" height="90" as="geometry" />
        </mxCell>
        <mxCell id="g2" value="WP-M2 画布门禁&lt;br&gt;缩放、平移、拖拽、连线、取消、箭头、首眼布局全部 PASS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="150" width="420" height="90" as="geometry" />
        </mxCell>
        <mxCell id="g3" value="WP-M3 运行证据门禁&lt;br&gt;WorkflowDiff、publish、run、human gate、evidence panel 可回读" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="300" width="420" height="90" as="geometry" />
        </mxCell>
        <mxCell id="g4" value="WP-M4 Executor 门禁&lt;br&gt;Agent/Tool/Skill/MCP 受治理展示，approval/denial/timeout/cancel 可审" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="590" y="300" width="420" height="90" as="geometry" />
        </mxCell>
        <mxCell id="g5" value="WP-M5 PV22 出门门禁&lt;br&gt;外部接入目标绑定 Workflow Platform，不绕过治理与 BFF boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1100" y="300" width="420" height="90" as="geometry" />
        </mxCell>
        <mxCell id="path6" value="共同最小用户操作路径&lt;br&gt;进入工作流平台首屏 -> 选择 Workspace/Project -> 画布缩放和平移 -> 拖拽 Agent/Tool/Skill/MCP 节点 -> 拖拽节点调整布局 -> 从端口自由连线 -> 取消错误连线 -> 配置节点参数 -> 保存草稿 -> 校验 WorkflowSpecGraph -> 查看 WorkflowDiff -> 人工确认发布 -> 运行工作流 -> 在 Human Gate 审查产物 -> 在 Evidence Panel 回看截图、日志、DTO 和 runtime inspect。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF5;strokeColor=#059669;fontSize=14;fontStyle=1;align=left;spacingLeft=18;" vertex="1" parent="1">
          <mxGeometry x="80" y="430" width="1440" height="95" as="geometry" />
        </mxCell>
        <mxCell id="scenario-docs6" value="场景 A：文档 / 知识总结&lt;br&gt;用户目标：把项目文档、会议材料或知识库整理成可审查摘要。&lt;br&gt;操作路径：1 导入或选择文档集合；2 在画布放置 Input、Retrieval/Read、Summarizer Agent、Human Review、Report Output；3 连接数据流和审查流；4 配置摘要维度、引用要求、脱敏规则；5 运行后审查摘要、引用和缺口；6 通过或退回修改。&lt;br&gt;出门产物：中文摘要、来源引用、缺口列表、人工审查记录。&lt;br&gt;验收证据：上传/选择截图、节点配置 DTO、运行日志、引用 evidence refs、human action report。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#10B981;fontSize=12;align=left;spacingLeft=14;" vertex="1" parent="1">
          <mxGeometry x="80" y="555" width="455" height="275" as="geometry" />
        </mxCell>
        <mxCell id="scenario-code6" value="场景 B：代码审查 / 变更风险检查&lt;br&gt;用户目标：对仓库、PR 或补丁做自动检查，并让人类确认结论。&lt;br&gt;操作路径：1 选择 repo/branch/PR 或粘贴 diff；2 放置 Code Input、Static Scan、Test Runner、Risk Agent、Human Gate、Issue Output；3 连接扫描、测试和风险总结路径；4 配置检查范围、测试命令和阻断规则；5 运行后查看文件级问题、测试输出和建议；6 人工确认 issue、退回或标记通过。&lt;br&gt;出门产物：按文件/行定位的问题、测试结果、风险等级、建议修复清单。&lt;br&gt;验收证据：BFF route log、test output、issue DTO、截图、人工确认记录。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#2563EB;fontSize=12;align=left;spacingLeft=14;" vertex="1" parent="1">
          <mxGeometry x="572" y="555" width="455" height="275" as="geometry" />
        </mxCell>
        <mxCell id="scenario-meeting6" value="场景 C：会议 / 访谈整理&lt;br&gt;用户目标：把原始纪要或访谈记录转成行动项、决策和待确认问题。&lt;br&gt;操作路径：1 导入 transcript 或粘贴访谈文本；2 放置 Transcript Input、Extractor Agent、Decision Classifier、Task Planner、Human Gate、Brief Output；3 连接提取、分类、任务生成和人工审查；4 配置参会人、项目、输出模板和敏感信息规则；5 运行后审查行动项、负责人、截止时间和待追问问题；6 人工确认导出简报。&lt;br&gt;出门产物：会议简报、行动项、决策记录、开放问题。&lt;br&gt;验收证据：输入快照、节点 DTO、run trace、人工编辑记录、导出截图。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#7C3AED;fontSize=12;align=left;spacingLeft=14;" vertex="1" parent="1">
          <mxGeometry x="1065" y="555" width="455" height="275" as="geometry" />
        </mxCell>
        <mxCell id="exit6" value="出门条件&lt;br&gt;必须完整跑通 3 个业务场景：文档/知识总结、代码审查/变更风险检查、会议/访谈整理，且共同最小操作路径全部可见、可操作、可回放。每个场景必须包含真实输入数据、画布截图、edge action log、BFF route log、DTO snapshot、runtime inspect、WorkflowDiff、human action report、evidence panel report。任一场景缺失真实运行证据或人工审查记录即 FAIL，并回到开发计划修订；不允许用静态图或设计稿替代运行证据。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#2563EB;fontSize=13;fontStyle=1;align=left;spacingLeft=16;" vertex="1" parent="1">
          <mxGeometry x="80" y="855" width="700" height="165" as="geometry" />
        </mxCell>
        <mxCell id="future-nogo6" value="应用前景与 No-Go&lt;br&gt;规划中：创意分镜规划、外部工具/MCP 受治理自动化、外部 App 接入。创意分镜只能声明 storyboard spec，不声明真实视频渲染；MCP/Tool 只能声明 allowlisted 受治理执行，不声明 unrestricted automation；PV22 证据前不声明外部接入完成。阻断：Browser 绕过 BFF、UI 模拟 runtime truth、缺少真实 E2E 证据、无法取消连线或回滚 Diff、出现 production ready / complete Studio GA / Agent executor ready / Xpert parity complete。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=13;fontStyle=1;align=left;spacingLeft=16;" vertex="1" parent="1">
          <mxGeometry x="820" y="855" width="700" height="165" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="wp-m0-7" name="接口与证据合约">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title7" value="接口与证据合约：支撑自动化开发和出门验收" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E3A8A;fontColor=#FFFFFF;strokeColor=#1E3A8A;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="40" width="1440" height="60" as="geometry" />
        </mxCell>
        <mxCell id="route7" value="BFF Route Allowlist&lt;br&gt;&lt;br&gt;/bff/pv21/studio/state&lt;br&gt;/bff/pv21/workflows/{id}/graph&lt;br&gt;/bff/pv21/workflows/{id}/diff&lt;br&gt;/bff/pv21/workflows/{id}/versions&lt;br&gt;/bff/pv21/workflows/{id}/runs&lt;br&gt;/bff/pv21/runs/{id}/inspect&lt;br&gt;/bff/pv21/runs/{id}/evidence&lt;br&gt;/bff/pv20/agent-executor/state&lt;br&gt;/bff/pv20/runs/{id}/agent-*" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=15;align=left;spacingLeft=16;" vertex="1" parent="1">
          <mxGeometry x="80" y="145" width="440" height="300" as="geometry" />
        </mxCell>
        <mxCell id="dto7" value="DTO Snapshot Contract&lt;br&gt;&lt;br&gt;workflow_platform.main_entry.v1&lt;br&gt;workspace / workflow / graph&lt;br&gt;run_summary&lt;br&gt;evidence_summary&lt;br&gt;&lt;br&gt;兼容复用：&lt;br&gt;PV21StudioStateDTO&lt;br&gt;PV21WorkflowGraphDTO&lt;br&gt;PV21RunDTO&lt;br&gt;PV21EvidenceSummaryDTO&lt;br&gt;PV20AgentExecution*DTO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=15;align=left;spacingLeft=16;" vertex="1" parent="1">
          <mxGeometry x="580" y="145" width="420" height="300" as="geometry" />
        </mxCell>
        <mxCell id="evidence7" value="Acceptance Runner Outputs&lt;br&gt;&lt;br&gt;acceptance-data.json&lt;br&gt;artifact-manifest.json&lt;br&gt;acceptance-report.html&lt;br&gt;browser-action-log.json&lt;br&gt;browser-network-log.json&lt;br&gt;dto-snapshot.json&lt;br&gt;canvas-edge-quality-report.json&lt;br&gt;runtime-inspect-report.json&lt;br&gt;agent-executor-integration-report.json&lt;br&gt;no-false-green-scan.txt&lt;br&gt;redaction-scan.txt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;align=left;spacingLeft=16;" vertex="1" parent="1">
          <mxGeometry x="1060" y="145" width="460" height="300" as="geometry" />
        </mxCell>
        <mxCell id="deny7" value="Browser Denylist / NO-GO&lt;br&gt;&lt;br&gt;不得直接调用 runtime/store/Gateway internals。&lt;br&gt;不得用 UI 模拟 runtime truth。&lt;br&gt;不得把文档、截图、drawio 写成运行证据。&lt;br&gt;不得声明 production ready、complete Studio GA、Agent executor ready、Xpert parity complete。&lt;br&gt;缺少真实 E2E 或截图时必须 FAIL/BLOCKED。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=16;align=left;spacingLeft=18;" vertex="1" parent="1">
          <mxGeometry x="80" y="520" width="1440" height="145" as="geometry" />
        </mxCell>
        <mxCell id="edge71" style="endArrow=block;html=1;strokeColor=#2563EB;strokeWidth=2;" edge="1" parent="1" source="route7" target="dto7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge72" style="endArrow=block;html=1;strokeColor=#2563EB;strokeWidth=2;" edge="1" parent="1" source="dto7" target="evidence7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
