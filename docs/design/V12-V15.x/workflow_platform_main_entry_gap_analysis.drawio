        <mxCell id="title4" value="开发及验收计划：PV13 首页 + WorkflowPlatformMainEntry 能力不退化" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E3A8A;fontColor=#FFFFFF;strokeColor=#1E3A8A;fontSize=22;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80" y="40" width="1440" height="60" as="geometry" /></mxCell>
        <mxCell id="m0" value="WP-M0 文档对齐&lt;br&gt;PRD / 架构 / 计划 / drawio&lt;br&gt;出门：只允许 implementation review claim" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=15;" vertex="1" parent="1"><mxGeometry x="80" y="160" width="240" height="120" as="geometry" /></mxCell>
        <mxCell id="m1" value="WP-M1A/B PV13 首页切换&lt;br&gt;先验证 /bff/v13/* route ownership&lt;br&gt;再让 root 和 workflow-platform 呈现 V13EditableStudio" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=15;" vertex="1" parent="1"><mxGeometry x="370" y="160" width="260" height="135" as="geometry" /></mxCell>
        <mxCell id="m2" value="WP-M2 PV13 画布硬化&lt;br&gt;缩放 / 平移 / 拖拽 / 连线 / 取消 / 箭头&lt;br&gt;出门：action log + edge quality report" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;" vertex="1" parent="1"><mxGeometry x="680" y="160" width="260" height="120" as="geometry" /></mxCell>
        <mxCell id="m3" value="WP-M3 运行证据融合&lt;br&gt;Diff / publish / rollback / run / human / evidence&lt;br&gt;出门：PV21 parity + 三个业务场景 PASS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=15;" vertex="1" parent="1"><mxGeometry x="990" y="160" width="260" height="135" as="geometry" /></mxCell>
        <mxCell id="m4" value="WP-M4 受治理执行器融合&lt;br&gt;Agent / Tool / Skill / MCP&lt;br&gt;出门：PV20 parity + approval / denial / redaction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1300" y="160" width="220" height="135" as="geometry" /></mxCell>
