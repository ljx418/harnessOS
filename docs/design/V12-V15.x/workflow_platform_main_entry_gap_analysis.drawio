        <mxCell id="acc4" value="每个实现子阶段都必须独立完成&lt;br&gt;&lt;br&gt;1. 子阶段 PRD 检视。&lt;br&gt;2. 目标架构检视。&lt;br&gt;3. Browser E2E 和截图。&lt;br&gt;4. BFF route log 与 DTO snapshot。&lt;br&gt;5. No False Green 与 redaction scan。&lt;br&gt;6. 中文 HTML 验收报告。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=16;align=left;spacingLeft=18;" vertex="1" parent="1">
          <mxGeometry x="80" y="360" width="680" height="250" as="geometry" />
        </mxCell>
        <mxCell id="dev4" value="本阶段开发结束后的目标体验&lt;br&gt;&lt;br&gt;WP-M0 完成后：人类和后续 Agent 能清楚知道后续代码要把“工作流平台”作为首入口。&lt;br&gt;&lt;br&gt;WP-M3 完成后：用户可审查工作流平台 MVP 候选体验。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=16;align=left;spacingLeft=18;" vertex="1" parent="1">
          <mxGeometry x="840" y="360" width="680" height="250" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="wp-m0-5" name="项目里程碑">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
