        <mxCell id="title5" value="项目里程碑：PV13 首页基线优先，PV22 后置" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E3A8A;fontColor=#FFFFFF;strokeColor=#1E3A8A;fontSize=22;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80" y="40" width="1440" height="60" as="geometry" /></mxCell>
        <mxCell id="r0" value="已完成基线&lt;br&gt;V13 / PV19 / PV20 / PV21 bounded evidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=15;" vertex="1" parent="1"><mxGeometry x="80" y="160" width="260" height="95" as="geometry" /></mxCell>
        <mxCell id="r1" value="当前 WP-M0&lt;br&gt;文档改为 PV13 首页基线" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=15;" vertex="1" parent="1"><mxGeometry x="390" y="160" width="240" height="95" as="geometry" /></mxCell>
        <mxCell id="r2" value="下一步 WP-M1A/B&lt;br&gt;V13 BFF compatibility PASS 后&lt;br&gt;默认首页切换到 V13EditableStudio" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=15;" vertex="1" parent="1"><mxGeometry x="680" y="160" width="260" height="115" as="geometry" /></mxCell>
        <mxCell id="r3" value="WP-M2 / WP-M3 / WP-M4&lt;br&gt;画布硬化 -> 运行证据 -> 受治理执行器" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;" vertex="1" parent="1"><mxGeometry x="990" y="160" width="290" height="95" as="geometry" /></mxCell>
        <mxCell id="r4" value="WP-M5 后&lt;br&gt;PV22 external app contract implementation 才进入实现" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1330" y="160" width="190" height="95" as="geometry" /></mxCell>
        <mxCell id="ra1" style="endArrow=block;html=1;strokeColor=#2563EB;strokeWidth=2;" edge="1" parent="1" source="r0" target="r1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ra2" style="endArrow=block;html=1;strokeColor=#2563EB;strokeWidth=2;" edge="1" parent="1" source="r1" target="r2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ra3" style="endArrow=block;html=1;strokeColor=#2563EB;strokeWidth=2;" edge="1" parent="1" source="r2" target="r3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ra4" style="endArrow=block;html=1;strokeColor=#2563EB;strokeWidth=2;" edge="1" parent="1" source="r3" target="r4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="mvp" value="MVP 候选体验出门点：WP-M3&lt;br&gt;用户能在 PV13-based 首页完成基础 Agent 工作流，并跑通文档/知识总结、代码审查、会议/访谈整理三个业务场景。&lt;br&gt;仍不得声明 production ready / complete Workflow Studio GA / product-grade frontend complete。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=16;align=left;spacingLeft=16;" vertex="1" parent="1"><mxGeometry x="180" y="360" width="1240" height="150" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="wp-pv13-6" name="验收门槛与出门条件">
    <mxGraphModel dx="1600" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title6" value="验收门槛与出门条件：用户能具体用平台做什么" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E3A8A;fontColor=#FFFFFF;strokeColor=#1E3A8A;fontSize=22;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80" y="40" width="1440" height="60" as="geometry" /></mxCell>
        <mxCell id="gate1" value="WP-M1A/B 首页门槛&lt;br&gt;先证明 /bff/v13/* route 来源明确；再验收 root / workflow-platform / v13-editable-studio 三条路径；退化入口即 FAIL。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=15;" vertex="1" parent="1"><mxGeometry x="80" y="140" width="450" height="125" as="geometry" /></mxCell>
        <mxCell id="gate2" value="WP-M2 画布门槛&lt;br&gt;缩放、平移、节点拖拽、右侧区域拖拽、端口连线、取消连线、非法连接提示、箭头可见全部 PASS。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;" vertex="1" parent="1"><mxGeometry x="580" y="140" width="450" height="110" as="geometry" /></mxCell>
        <mxCell id="gate3" value="WP-M3/WP-M4 出门门槛&lt;br&gt;运行证据和受治理执行能力必须接入 PV13 工作台；必须输出 capability parity report，证明 WPME 已有 PV21/PV20 能力不退化。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1080" y="140" width="440" height="130" as="geometry" /></mxCell>
        <mxCell id="scenario1" value="基础 Agent 工作流&lt;br&gt;用户操作路径：打开首页 -> 选择工作流场景 -> 拖拽节点 -> 从端口连线 -> 配置 Agent/Tool/Skill/MCP -> 保存草稿 -> 校验 -> 生成 Diff -> 发布 -> 运行 -> Human Gate -> Evidence Review。&lt;br&gt;输出：WorkflowInstance、StationRun、产物、证据面板。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="80" y="310" width="690" height="170" as="geometry" /></mxCell>
        <mxCell id="scenario2" value="文档/知识总结&lt;br&gt;用户操作路径：选择文档/知识场景 -> 导入文档或 Markdown 文件夹 -> 连接输入/解析/事实抽取/总结/质量检查/证据审查节点 -> 运行 -> 人工复核。&lt;br&gt;输出：带 evidence refs 的摘要、引用、质量结果、复核记录。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="830" y="310" width="690" height="150" as="geometry" /></mxCell>
        <mxCell id="scenario3" value="代码审查/变更风险检查&lt;br&gt;用户操作路径：选择代码审查场景 -> 输入 repo/branch/PR/diff -> 编排静态检查、安全审计、测试运行、风险汇总和合规 Human Gate -> 运行并复核。&lt;br&gt;输出：文件级问题、测试输出、风险等级、审批记录。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="80" y="530" width="690" height="150" as="geometry" /></mxCell>
        <mxCell id="scenario4" value="会议/访谈整理&lt;br&gt;用户操作路径：选择会议/访谈场景 -> 导入 transcript 或 audio-derived text -> 编排议题提取、行动项、事实核对、人工复核 -> 运行并审查。&lt;br&gt;输出：纪要、行动项、决策、开放问题、引用证据。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="830" y="530" width="690" height="150" as="geometry" /></mxCell>
        <mxCell id="nogate" value="No-Go 出门条件&lt;br&gt;若只展示未来应用前景、只展示静态画布、只跳转分散 PV 阶段页、缺少真实 E2E 证据、静默丢失 WorkflowPlatformMainEntry 已有 PV21/PV20 能力、出现 forbidden claims，则不得通过。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80" y="745" width="1440" height="95" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
