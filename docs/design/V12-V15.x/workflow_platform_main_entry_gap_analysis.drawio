        <mxCell id="ev1" value="WP-M1A/B 证据&lt;br&gt;v13-route-ownership-report.json&lt;br&gt;pv13-baseline-homepage-report.json&lt;br&gt;browser-network-log.json&lt;br&gt;dto-snapshot.json&lt;br&gt;首页截图" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="100" y="360" width="310" height="170" as="geometry" /></mxCell>
        <mxCell id="ev2" value="WP-M2 证据&lt;br&gt;browser-action-log.json&lt;br&gt;canvas-edge-quality-report.json&lt;br&gt;zoom/drag/connect/cancel screenshots&lt;br&gt;inspector DTO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="460" y="360" width="310" height="150" as="geometry" /></mxCell>
        <mxCell id="ev3" value="WP-M3 证据&lt;br&gt;runtime-inspect-report.json&lt;br&gt;evidence-panel-report.json&lt;br&gt;human-gate report&lt;br&gt;user-scenario-report.json&lt;br&gt;workflow-platform-capability-parity-report.json（PV21）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="820" y="360" width="310" height="180" as="geometry" /></mxCell>
        <mxCell id="ev4" value="WP-M4 证据&lt;br&gt;agent-executor-integration-report.json&lt;br&gt;workflow-platform-capability-parity-report.json（PV20）&lt;br&gt;approval/denial fixtures&lt;br&gt;redaction-scan.txt&lt;br&gt;no-false-green-scan.txt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1"><mxGeometry x="1180" y="360" width="310" height="180" as="geometry" /></mxCell>
        <mxCell id="deny" value="浏览器禁止路径&lt;br&gt;不得直接调用 core/workflows、Gateway internals、runtime store mutation、未授权 artifact content、未治理 MCP/tool invocation。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="100" y="590" width="1390" height="85" as="geometry" /></mxCell>
