        <mxCell id="route2" value="/bff/pv19/*&lt;br&gt;WP-M3 能力来源：runtime publish/run/human/evidence loop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=15;" vertex="1" parent="1"><mxGeometry x="460" y="160" width="310" height="125" as="geometry" /></mxCell>
        <mxCell id="route3" value="/bff/pv20/*&lt;br&gt;WP-M4 能力来源：governed Agent/Tool/Skill/MCP execution evidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=15;" vertex="1" parent="1"><mxGeometry x="820" y="160" width="310" height="125" as="geometry" /></mxCell>
