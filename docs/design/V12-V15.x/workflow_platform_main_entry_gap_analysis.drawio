        <mxCell id="a3" style="endArrow=block;html=1;strokeColor=#2563EB;strokeWidth=2;" edge="1" parent="1" source="m2" target="m3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="a4" style="endArrow=block;html=1;strokeColor=#2563EB;strokeWidth=2;" edge="1" parent="1" source="m3" target="m4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="qa" value="每个子阶段共同验收动作&lt;br&gt;1. 子阶段开始前独立计划和审计。&lt;br&gt;2. 完成后端到端验收。&lt;br&gt;3. PRD 规格检视和目标架构检视。&lt;br&gt;4. Browser screenshot、network log、DTO snapshot、No False Green、redaction scan。&lt;br&gt;5. 失败则打回计划阶段，不能假绿。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=16;align=left;spacingLeft=16;" vertex="1" parent="1"><mxGeometry x="160" y="380" width="560" height="210" as="geometry" /></mxCell>
        <mxCell id="effect" value="开发完成后用户看到的效果&lt;br&gt;PV13 工作流平台成为首页；用户能在同一工作台中体验画布编排、节点审查、Diff、发布/回滚/运行、人工审批、证据回看和受治理资源入口；已在 WorkflowPlatformMainEntry 中出现的 PV21/PV20 闭环能力不得静默丢失。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0E7FF;strokeColor=#4F46E5;fontSize=16;align=left;spacingLeft=16;" vertex="1" parent="1"><mxGeometry x="820" y="380" width="560" height="190" as="geometry" /></mxCell>
