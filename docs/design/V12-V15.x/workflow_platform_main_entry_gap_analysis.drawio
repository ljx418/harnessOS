  <diagram id="wp-pv13-6" name="验收门槛与出门条件">
    <mxGraphModel dx="1600" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title6" value="验收门槛与出门条件：用户能具体用平台做什么" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E3A8A;fontColor=#FFFFFF;strokeColor=#1E3A8A;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="40" width="1440" height="60" as="geometry" />
        </mxCell>
        <mxCell id="gate1" value="WP-M1A/B 首页门槛&lt;br&gt;先证明 /bff/v13/* route 来源明确；再验收 root / workflow-platform / v13-editable-studio 三条路径；退化入口即 FAIL。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="80" y="140" width="450" height="125" as="geometry" />
        </mxCell>
        <mxCell id="gate2" value="WP-M2 画布门槛&lt;br&gt;缩放、平移、节点拖拽、右侧区域拖拽、端口连线、取消连线、非法连接提示、箭头可见全部 PASS。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="580" y="140" width="450" height="110" as="geometry" />
        </mxCell>
        <mxCell id="gate3" value="WP-M3/WP-M4/WP-M5A 出门门槛&lt;br&gt;运行证据和受治理执行能力接入 PV13；WP-M5A 还必须输出业务产物、scenario projection、mock reduction 和 human review refs。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="1080" y="140" width="440" height="140" as="geometry" />
        </mxCell>
        <mxCell id="scenario1" value="基础 Agent 工作流&lt;br&gt;用户操作路径：打开首页 -&gt; 选择工作流场景 -&gt; 拖拽节点 -&gt; 从端口连线 -&gt; 配置 Agent/Tool/Skill/MCP -&gt; 保存草稿 -&gt; 校验 -&gt; 生成 Diff -&gt; 发布 -&gt; 运行 -&gt; Human Gate -&gt; Evidence Review。&lt;br&gt;输出：WorkflowInstance、StationRun、产物、证据面板。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1">
          <mxGeometry x="80" y="310" width="690" height="170" as="geometry" />
        </mxCell>
        <mxCell id="scenario2" value="文档/知识总结&lt;br&gt;用户操作路径：选择文档/知识场景 -&gt; 导入文档或 Markdown 文件夹 -&gt; 连接输入/解析/事实抽取/总结/质量检查/证据审查节点 -&gt; 运行 -&gt; 人工复核。&lt;br&gt;输出：带 evidence refs 的摘要、引用、质量结果、复核记录。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1">
          <mxGeometry x="830" y="310" width="690" height="150" as="geometry" />
        </mxCell>
        <mxCell id="scenario3" value="代码审查/变更风险检查&lt;br&gt;用户操作路径：选择代码审查场景 -&gt; 输入 repo/branch/PR/diff -&gt; 编排静态检查、安全审计、测试运行、风险汇总和合规 Human Gate -&gt; 运行并复核。&lt;br&gt;输出：文件级问题、测试输出、风险等级、审批记录。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1">
          <mxGeometry x="80" y="530" width="690" height="150" as="geometry" />
        </mxCell>
        <mxCell id="scenario4" value="会议/访谈整理&lt;br&gt;用户操作路径：选择会议/访谈场景 -&gt; 导入 transcript 或 audio-derived text -&gt; 编排议题提取、行动项、事实核对、人工复核 -&gt; 运行并审查。&lt;br&gt;输出：纪要、行动项、决策、开放问题、引用证据。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=15;align=left;spacingLeft=14;" vertex="1" parent="1">
          <mxGeometry x="830" y="530" width="690" height="150" as="geometry" />
        </mxCell>
        <mxCell id="nogate" value="No-Go 出门条件&lt;br&gt;若只展示未来应用前景、只展示静态画布、只跳转分散 PV 阶段页、缺少真实 E2E 证据、静默丢失 WorkflowPlatformMainEntry 已有 PV21/PV20 能力、用验收报告冒充业务产物、把 scenarioData 当真实投影、出现 forbidden claims，则不得通过。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEE2E2;strokeColor=#DC2626;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="745" width="1440" height="105" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
