        <mxCell id="title7" value="接口与证据合约：PV13 baseline + bounded route families" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1E3A8A;fontColor=#FFFFFF;strokeColor=#1E3A8A;fontSize=22;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="80" y="40" width="1440" height="60" as="geometry" /></mxCell>
