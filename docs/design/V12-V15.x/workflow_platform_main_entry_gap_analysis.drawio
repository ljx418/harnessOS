          <mxGeometry x="80" y="40" width="1440" height="60" as="geometry" />
        </mxCell>
        <mxCell id="base5" value="已验收 bounded slices&lt;br&gt;PV19 / PV20 / PV21" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DCFCE7;strokeColor=#16A34A;fontSize=17;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="160" width="260" height="85" as="geometry" />
        </mxCell>
        <mxCell id="doc5" value="当前阶段&lt;br&gt;WP-M0 文档对齐&lt;br&gt;只证明文档可支撑实现" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=17;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="160" width="260" height="85" as="geometry" />
        </mxCell>
        <mxCell id="mvp5" value="工作流平台 MVP 候选&lt;br&gt;WP-M1 到 WP-M3&lt;br&gt;首入口 + 画布 + 运行证据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=17;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="160" width="300" height="85" as="geometry" />
        </mxCell>
        <mxCell id="int5" value="受治理 Executor 融合&lt;br&gt;WP-M4&lt;br&gt;Agent / Tool / Skill / MCP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FEF3C7;strokeColor=#D97706;fontSize=17;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1140" y="160" width="260" height="85" as="geometry" />
        </mxCell>
        <mxCell id="pv225" value="PV22 外部接入实现&lt;br&gt;SDK / Template / Reference app&lt;br&gt;必须接到稳定平台入口" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DBEAFE;strokeColor=#2563EB;fontSize=17;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="360" width="320" height="90" as="geometry" />
        </mxCell>
        <mxCell id="pv235" value="PV23+ 后续&lt;br&gt;生产治理 / 业务 Pack / 开源商业化&lt;br&gt;仍属后续阶段" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FAFC;strokeColor=#94A3B8;fontSize=17;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="360" width="360" height="90" as="geometry" />
