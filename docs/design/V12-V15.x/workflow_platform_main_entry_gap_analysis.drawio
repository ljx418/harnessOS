        <mxCell id="qa" value="每个子阶段共同验收动作&lt;br&gt;1. 子阶段开始前独立计划和审计。&lt;br&gt;2. 完成后端到端验收。&lt;br&gt;3. PRD 规格检视和目标架构检视。&lt;br&gt;4. Browser screenshot、network log、DTO snapshot、No False Green、redaction scan。&lt;br&gt;5. 失败则打回计划阶段，不能假绿。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=16;align=left;spacingLeft=16;" vertex="1" parent="1">
          <mxGeometry x="160" y="380" width="560" height="210" as="geometry" />
        </mxCell>
        <mxCell id="effect" value="WP-M5A 完成后用户看到的效果&lt;br&gt;PV13 工作流平台仍是首页；用户不仅能跑通画布、Diff、发布/运行、人工审批和证据回看，还能看到三类业务产物：文档摘要、代码审查报告、会议纪要/行动项；每个产物绑定 artifact、trace、quality、audit、claim、redaction 和 human review refs。PV22 只能在 WP-M5A 后复审。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0E7FF;strokeColor=#4F46E5;fontSize=16;align=left;spacingLeft=16;" vertex="1" parent="1">
          <mxGeometry x="820" y="380" width="560" height="230" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
