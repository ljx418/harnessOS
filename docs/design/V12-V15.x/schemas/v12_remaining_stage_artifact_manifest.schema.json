{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v12_remaining_stage_artifact_manifest.schema.json",
  "title": "V12RemainingStageArtifactManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "stage_id",
    "status",
    "evidence_scope",
    "not_pass_evidence",
    "required_artifacts",
    "blocked_claims",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "v12.remaining_stage_artifact_manifest.v1" },
    "stage_id": {
      "enum": [
        "V12-SD",
        "V12-SI",
        "V12-SQ",
        "V12-SA"
      ]
    },
    "status": {
      "enum": [
        "PLANNED_NOT_EVIDENCE",
        "DRAFT",
        "PASS",
        "FAIL",
        "BLOCKED"
      ]
    },
    "evidence_scope": {
      "enum": [
        "browser_bff_read_model",
        "browser_interaction",
        "product_polish",
        "aggregate_reconciliation"
      ]
    },
    "not_pass_evidence": { "type": "boolean" },
    "required_artifacts": {
      "type": "array",
      "minItems": 11,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_id", "path", "required_for_pass", "status"],
        "properties": {
          "artifact_id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "required_for_pass": { "type": "boolean" },
          "status": { "enum": ["PLANNED", "PRESENT", "MISSING", "NOT_APPLICABLE"] },
          "sha256": { "type": ["string", "null"] }
        }
      }
    },
    "blocked_claims": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
