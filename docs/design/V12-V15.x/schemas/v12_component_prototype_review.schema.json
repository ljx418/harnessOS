{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://harnessos.local/schemas/v12_component_prototype_review.schema.json",
  "title": "V12 Component Prototype Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "stage_id",
    "status",
    "evidence_scope",
    "runtime_backed",
    "browser_implementation_backed",
    "figma_backed",
    "artifact_manifest_ref",
    "components",
    "no_false_green_scan",
    "redaction_scan",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "v12.component_prototype_review.v1"
    },
    "stage_id": {
      "const": "V12-0A"
    },
    "status": {
      "enum": [
        "PASS",
        "PASS_WITH_MINOR_ISSUES",
        "PARTIAL_ACCEPTED",
        "BLOCKED",
        "FAIL"
      ]
    },
    "evidence_scope": {
      "const": "design_only"
    },
    "runtime_backed": {
      "const": false
    },
    "browser_implementation_backed": {
      "const": false
    },
    "figma_backed": {
      "const": false
    },
    "artifact_manifest_ref": {
      "type": "string",
      "minLength": 1
    },
    "components": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "component_id",
          "status",
          "asset_ref",
          "wireframe_ref",
          "visual_artifact_type",
          "visual_artifact_exception_reason",
          "user_goal",
          "accepted_boundaries",
          "open_questions"
        ],
        "properties": {
          "component_id": {
            "enum": [
              "global_top_bar",
              "left_product_navigation",
              "canvas_workbench",
              "agent_station_node_card",
              "right_inspector",
              "chat_workbench_proposal_timeline"
            ]
          },
          "status": {
            "enum": [
              "ACCEPTED",
              "ACCEPTED_WITH_BOUNDED_REVISION",
              "REJECTED",
              "NEEDS_REVISION"
            ]
          },
          "asset_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "wireframe_ref": {
            "type": [
              "string",
              "null"
            ]
          },
          "visual_artifact_type": {
            "enum": [
              "image",
              "wireframe",
              "text_only_exception"
            ]
          },
          "visual_artifact_exception_reason": {
            "type": [
              "string",
              "null"
            ]
          },
          "user_goal": {
            "type": "string",
            "minLength": 1
          },
          "accepted_boundaries": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "open_questions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "visual_artifact_type": {
                  "const": "text_only_exception"
                }
              }
            },
            "then": {
              "properties": {
                "visual_artifact_exception_reason": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        ]
      }
    },
    "no_false_green_scan": {
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "redaction_scan": {
      "enum": [
        "PASS",
        "FAIL"
      ]
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
