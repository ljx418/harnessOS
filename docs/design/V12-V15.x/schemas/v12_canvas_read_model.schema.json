{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v12_canvas_read_model.schema.json",
  "title": "V12CanvasReadModel",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "canvas_read_model_id",
    "workspace_id",
    "project_id",
    "app_id",
    "nodes",
    "edges",
    "read_only",
    "evidence_refs",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "v12.canvas_read_model.v1" },
    "canvas_read_model_id": { "type": "string", "minLength": 1 },
    "workspace_id": { "type": "string", "minLength": 1 },
    "project_id": { "type": "string", "minLength": 1 },
    "app_id": { "type": "string", "minLength": 1 },
    "read_only": { "const": true },
    "nodes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["node_id", "label", "node_kind", "status", "position", "inspector_ref"],
        "properties": {
          "node_id": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "node_kind": { "enum": ["input", "tool", "agent", "reviewer", "output"] },
          "status": { "enum": ["ghost", "pending", "running", "completed", "failed", "waiting_approval", "stale"] },
          "position": {
            "type": "object",
            "additionalProperties": false,
            "required": ["x", "y"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" }
            }
          },
          "inspector_ref": { "type": "string", "minLength": 1 }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["edge_id", "source_node_id", "target_node_id"],
        "properties": {
          "edge_id": { "type": "string", "minLength": 1 },
          "source_node_id": { "type": "string", "minLength": 1 },
          "target_node_id": { "type": "string", "minLength": 1 }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
