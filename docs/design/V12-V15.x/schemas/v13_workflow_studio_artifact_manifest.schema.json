{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v13_workflow_studio_artifact_manifest.schema.json",
  "title": "V13WorkflowStudioArtifactManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "stage_id",
    "status",
    "evidence_scope",
    "not_runtime_execution_evidence",
    "required_artifacts",
    "blocked_claims",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "v13.workflow_studio_artifact_manifest.v1" },
    "stage_id": { "enum": ["V13-R0", "V13-S1", "V13-S2", "V13-S3", "V13-SA"] },
    "status": { "enum": ["PLANNED_NOT_EVIDENCE", "DRAFT", "PASS", "FAIL", "BLOCKED"] },
    "evidence_scope": { "enum": ["readiness", "graph_schema", "editable_canvas", "workflowdiff_confirmation", "aggregate_reconciliation"] },
    "not_runtime_execution_evidence": { "type": "boolean" },
    "required_artifacts": {
      "type": "array",
      "minItems": 17,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_id", "path", "required_for_pass", "status"],
        "properties": {
          "artifact_id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "required_for_pass": { "type": "boolean" },
          "status": { "enum": ["PLANNED", "PRESENT", "MISSING", "NOT_APPLICABLE"] },
          "sha256": { "type": ["string", "null"] }
        }
      }
    },
    "blocked_claims": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
