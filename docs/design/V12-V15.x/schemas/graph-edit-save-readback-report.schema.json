{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/graph-edit-save-readback-report.schema.json",
  "title": "Workflow Platform Graph Edit Save Readback Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "stage",
    "status",
    "actions",
    "before_graph_ref",
    "after_graph_ref",
    "saved_graph_ref",
    "refresh_readback_status",
    "workflow_diff_ref",
    "human_diff_review_status",
    "evidence_refs"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "wp-m7-graph-edit-save-readback.v1" },
    "stage": { "type": "string", "const": "WP-M7" },
    "status": { "type": "string", "enum": ["PASS", "FAIL", "BLOCKED", "NO_GO"] },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["action_id", "kind", "status", "browser_action_ref"],
        "properties": {
          "action_id": { "type": "string", "minLength": 1 },
          "kind": { "type": "string", "enum": ["node_drag", "edge_create", "edge_delete", "edge_cancel", "node_config", "invalid_edge"] },
          "status": { "type": "string", "enum": ["PASS", "FAIL", "BLOCKED"] },
          "browser_action_ref": { "type": "string", "minLength": 1 },
          "visible_reason": { "type": "string" }
        }
      }
    },
    "before_graph_ref": { "type": "string", "minLength": 1 },
    "after_graph_ref": { "type": "string", "minLength": 1 },
    "saved_graph_ref": { "type": "string", "minLength": 1 },
    "refresh_readback_status": { "type": "string", "enum": ["PASS", "FAIL", "BLOCKED"] },
    "workflow_diff_ref": { "type": "string", "minLength": 1 },
    "human_diff_review_status": { "type": "string", "enum": ["approved", "rejected", "blocked", "not_applicable"] },
    "evidence_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
  }
}
