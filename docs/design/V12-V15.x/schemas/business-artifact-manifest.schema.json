{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/business-artifact-manifest.schema.json",
  "title": "Workflow Platform Business Artifact Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "stage", "status", "scenarios"],
  "properties": {
    "schema_version": { "type": "string", "const": "wp-m9-business-artifact-manifest.v1" },
    "stage": { "type": "string", "const": "WP-M9" },
    "status": { "type": "string", "enum": ["PASS", "FAIL", "BLOCKED", "NO_GO"] },
    "scenarios": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "scenario_id",
          "input_hash",
          "artifact_ref",
          "content_snapshot_ref",
          "quality_refs",
          "human_review_refs",
          "redaction_refs"
        ],
        "properties": {
          "scenario_id": { "type": "string", "enum": ["document_summary", "code_review", "meeting_brief"] },
          "input_hash": { "type": "string", "minLength": 1 },
          "artifact_ref": { "type": "string", "minLength": 1 },
          "content_snapshot_ref": { "type": "string", "minLength": 1 },
          "quality_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "human_review_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "redaction_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
          "trace_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } }
        }
      }
    }
  }
}
