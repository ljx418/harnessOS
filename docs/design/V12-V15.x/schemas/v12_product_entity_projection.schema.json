{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v12_product_entity_projection.schema.json",
  "title": "V12ProductEntityProjection",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "workspace",
    "project",
    "app",
    "service_account_ref",
    "evidence_scope",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "v12.product_entity_projection.v1" },
    "workspace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspace_id", "name"],
      "properties": {
        "workspace_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "workspace_id", "name"],
      "properties": {
        "project_id": { "type": "string", "minLength": 1 },
        "workspace_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "app": {
      "type": "object",
      "additionalProperties": false,
      "required": ["app_id", "project_id", "name", "app_kind"],
      "properties": {
        "app_id": { "type": "string", "minLength": 1 },
        "project_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "app_kind": { "enum": ["workflow_app", "agent_app", "studio_app"] }
      }
    },
    "service_account_ref": { "type": "string", "minLength": 1 },
    "evidence_scope": { "enum": ["read_only_canvas_fixture", "browser_e2e", "runtime_backed"] },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
