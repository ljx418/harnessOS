{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/v14_extension_ecosystem_artifact_manifest.schema.json",
  "title": "V14ExtensionEcosystemArtifactManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "stage_id",
    "status",
    "evidence_scope",
    "not_unrestricted_plugin_runtime_evidence",
    "required_artifacts",
    "blocked_claims",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "v14.extension_ecosystem_artifact_manifest.v1" },
    "stage_id": { "enum": ["V14-R0", "V14-S1", "V14-S2", "V14-S3", "V14-SA"] },
    "status": { "enum": ["PLANNED_NOT_EVIDENCE", "DRAFT", "PASS", "FAIL", "BLOCKED"] },
    "evidence_scope": {
      "enum": [
        "readiness",
        "manifest_compatibility",
        "scoped_activation",
        "unsafe_denial",
        "aggregate_reconciliation"
      ]
    },
    "not_unrestricted_plugin_runtime_evidence": { "type": "boolean" },
    "required_artifacts": {
      "type": "array",
      "minItems": 24,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["artifact_id", "path", "required_for_pass", "status"],
        "properties": {
          "artifact_id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "required_for_pass": { "type": "boolean" },
          "status": { "enum": ["PLANNED", "PRESENT", "MISSING", "NOT_APPLICABLE"] },
          "sha256": { "type": ["string", "null"] }
        }
      }
    },
    "blocked_claims": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
