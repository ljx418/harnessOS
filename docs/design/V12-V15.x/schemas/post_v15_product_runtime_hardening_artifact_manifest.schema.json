{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://harnessos.local/schemas/post_v15_product_runtime_hardening_artifact_manifest.schema.json",
  "title": "PostV15ProductRuntimeHardeningArtifactManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "stage_id",
    "status",
    "artifact_root",
    "artifacts",
    "claim_boundary",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "post_v15.product_runtime_hardening_artifact_manifest.v1" },
    "stage_id": { "enum": ["PV16-R0", "PV16-S1", "PV16-S2", "PV16-S3", "PV16-S4", "PV16-SA"] },
    "status": { "enum": ["PASS", "PARTIAL", "FAIL", "BLOCKED"] },
    "artifact_root": { "type": "string", "minLength": 1 },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "kind", "sha256", "evidence_role"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "kind": {
            "enum": [
              "json",
              "markdown",
              "text",
              "png",
              "log",
              "screenshot",
              "report"
            ]
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "evidence_role": { "type": "string", "minLength": 1 }
        }
      }
    },
    "claim_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowed_claim", "forbidden_claims"],
      "properties": {
        "allowed_claim": { "const": "PV16 complete: product-runtime hardening pilot ready for review." },
        "forbidden_claims": {
          "type": "array",
          "minItems": 5,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
