{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pv18_knowledge_opc_artifact_manifest.schema.json",
  "title": "PV18 Knowledge OPC Artifact Manifest",
  "type": "object",
  "required": ["schema_version", "stage_id", "artifacts"],
  "properties": {
    "schema_version": { "const": "pv18.knowledge_opc_artifact_manifest.v1" },
    "stage_id": { "type": "string" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact_id", "path", "kind", "required"],
        "properties": {
          "artifact_id": { "type": "string" },
          "path": { "type": "string" },
          "kind": { "type": "string" },
          "required": { "type": "boolean" },
          "status": { "enum": ["present", "missing", "planned"] },
          "description": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "missing_required_artifacts": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
