{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://harnessos.local/schemas/v12_component_prototype_artifact_manifest.schema.json",
  "title": "V12 Component Prototype Artifact Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "stage_id",
    "status",
    "evidence_scope",
    "not_acceptance_evidence",
    "artifacts",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "const": "v12.component_prototype_artifact_manifest.v1"
    },
    "stage_id": {
      "const": "V12-0A"
    },
    "status": {
      "enum": [
        "PLANNED_NOT_EVIDENCE",
        "DRAFT",
        "PASS",
        "FAIL"
      ]
    },
    "evidence_scope": {
      "const": "design_only"
    },
    "not_acceptance_evidence": {
      "type": "boolean"
    },
    "artifacts": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "component_id",
          "asset_path",
          "wireframe_path",
          "review_status",
          "boundary_tags",
          "sha256",
          "created_at"
        ],
        "properties": {
          "component_id": {
            "enum": [
              "global_top_bar",
              "left_product_navigation",
              "canvas_workbench",
              "agent_station_node_card",
              "right_inspector",
              "chat_workbench_proposal_timeline"
            ]
          },
          "asset_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "wireframe_path": {
            "type": [
              "string",
              "null"
            ]
          },
          "review_status": {
            "enum": [
              "ACCEPTED",
              "ACCEPTED_WITH_BOUNDED_REVISION",
              "REJECTED",
              "NEEDS_REVISION"
            ]
          },
          "boundary_tags": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "sha256": {
            "type": [
              "string",
              "null"
            ]
          },
          "created_at": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
