        <mxCell id="t5" value="PV19 开发及验收计划" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#111827;fontColor=#ffffff;fontSize=28;fontStyle=1;strokeColor=#111827;" vertex="1" parent="1"><mxGeometry x="60" y="40" width="620" height="70" as="geometry"/></mxCell>
        <mxCell id="p0" value="PV19-R0 文档冻结&#xa;PRD / Architecture / Plan / Gate / Gap / DTO / Runner / Task Matrix / Audit / Drawio&#xa;验收：文件存在、drawio 页数、No False Green PASS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=15;" vertex="1" parent="1"><mxGeometry x="70" y="150" width="500" height="130" as="geometry"/></mxCell>
        <mxCell id="p1" value="PV19-S1 工作台入口&#xa;新增 PV19 workbench；根路径不得为空白交付体验。&#xa;验收：screenshot、state DTO、route log、workbench_loads E2E" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=15;" vertex="1" parent="1"><mxGeometry x="630" y="150" width="500" height="130" as="geometry"/></mxCell>
        <mxCell id="p2" value="PV19-S2 Graph Roundtrip&#xa;画布编辑 readback 为 WorkflowSpecGraph，含 human gate station。&#xa;验收：graph-roundtrip report、negative fixtures" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1190" y="150" width="500" height="130" as="geometry"/></mxCell>
        <mxCell id="p3" value="PV19-S3 Publish&#xa;WorkflowDiff 必须确认后发布 WorkflowVersion。&#xa;验收：version publish report、publish-without-confirm denied" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;" vertex="1" parent="1"><mxGeometry x="70" y="360" width="500" height="130" as="geometry"/></mxCell>
        <mxCell id="p4" value="PV19-S4 Runtime Run Inspect&#xa;run 引用 workflow_version_id，产生 WorkflowInstance / StationRun。&#xa;验收：runtime-run-inspect report、browser route denylist" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0e7ff;strokeColor=#4f46e5;fontSize=15;" vertex="1" parent="1"><mxGeometry x="630" y="360" width="500" height="130" as="geometry"/></mxCell>
        <mxCell id="p5" value="PV19-S5 Human Gate&#xa;human action 更新 approval / handoff / workflow state，保留 before/after。&#xa;验收：human-interaction report、human_gate_ui_only_denied" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0e7ff;strokeColor=#4f46e5;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1190" y="360" width="500" height="130" as="geometry"/></mxCell>
        <mxCell id="p6" value="PV19-S6 Evidence Review&#xa;聚合 artifact、trace、quality、audit、claim matrix。&#xa;验收：evidence-review report、claim-to-evidence matrix、redaction scan" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=15;" vertex="1" parent="1"><mxGeometry x="70" y="570" width="500" height="130" as="geometry"/></mxCell>
        <mxCell id="p7" value="PV19-SA Aggregate&#xa;运行聚合验收，写入 artifact-manifest 和 audit-closure。&#xa;验收：acceptance-data、artifact-manifest、audit-closure、allowed claim only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3f4f6;strokeColor=#6b7280;fontSize=15;" vertex="1" parent="1"><mxGeometry x="630" y="570" width="500" height="130" as="geometry"/></mxCell>
        <mxCell id="p8" value="子阶段进入规则&#xa;每个子阶段开始前必须有开发计划、验收标准、审计意见闭环。&#xa;若出现重大规格偏差、虚假验收风险或业务专用平台定制，停止并回到计划阶段。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1190" y="570" width="500" height="130" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="pv19-milestones" name="项目里程碑">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t6" value="PV19 项目里程碑与出门顺序" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#111827;fontColor=#ffffff;fontSize=28;fontStyle=1;strokeColor=#111827;" vertex="1" parent="1"><mxGeometry x="60" y="40" width="720" height="70" as="geometry"/></mxCell>
        <mxCell id="m0" value="M0 Readiness&#xa;文档冻结&#xa;人工审核 drawio" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=15;" vertex="1" parent="1"><mxGeometry x="70" y="170" width="210" height="110" as="geometry"/></mxCell>
        <mxCell id="m1" value="M1 Entry&#xa;真实工作台入口&#xa;不再接受空白首页" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=15;" vertex="1" parent="1"><mxGeometry x="340" y="170" width="210" height="110" as="geometry"/></mxCell>
        <mxCell id="m2" value="M2 Graph&#xa;WorkflowSpecGraph roundtrip&#xa;human gate station 可读回" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;" vertex="1" parent="1"><mxGeometry x="610" y="170" width="230" height="110" as="geometry"/></mxCell>
        <mxCell id="m3" value="M3 Version&#xa;WorkflowDiff 确认&#xa;WorkflowVersion readback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;" vertex="1" parent="1"><mxGeometry x="900" y="170" width="230" height="110" as="geometry"/></mxCell>
        <mxCell id="m4" value="M4 Runtime&#xa;WorkflowInstance / StationRun&#xa;runtime refs 可审计" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0e7ff;strokeColor=#4f46e5;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1190" y="170" width="230" height="110" as="geometry"/></mxCell>
        <mxCell id="m5" value="M5 Human Loop&#xa;approval/handoff 状态转移&#xa;before/after + audit trail" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0e7ff;strokeColor=#4f46e5;fontSize=15;" vertex="1" parent="1"><mxGeometry x="70" y="430" width="250" height="120" as="geometry"/></mxCell>
        <mxCell id="m6" value="M6 Evidence&#xa;artifact / trace / quality / audit&#xa;claim-to-evidence + redaction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=15;" vertex="1" parent="1"><mxGeometry x="390" y="430" width="250" height="120" as="geometry"/></mxCell>
        <mxCell id="m7" value="M7 Generality Review&#xa;Knowledge OPC 主样例&#xa;folder-summary/reference workflow 复用检查&#xa;无业务专用平台核心定制" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=15;" vertex="1" parent="1"><mxGeometry x="710" y="430" width="330" height="120" as="geometry"/></mxCell>
        <mxCell id="m8" value="M8 Exit Review&#xa;acceptance-data / artifact-manifest / audit-closure&#xa;bounded review allowed claim only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3f4f6;strokeColor=#6b7280;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1110" y="430" width="330" height="120" as="geometry"/></mxCell>
        <mxCell id="e1" edge="1" parent="1" source="m0" target="m1" style="endArrow=block;html=1;rounded=0;strokeColor=#6b7280;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" edge="1" parent="1" source="m1" target="m2" style="endArrow=block;html=1;rounded=0;strokeColor=#6b7280;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" edge="1" parent="1" source="m2" target="m3" style="endArrow=block;html=1;rounded=0;strokeColor=#6b7280;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" edge="1" parent="1" source="m3" target="m4" style="endArrow=block;html=1;rounded=0;strokeColor=#6b7280;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" edge="1" parent="1" source="m4" target="m5" style="endArrow=block;html=1;rounded=0;strokeColor=#6b7280;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" edge="1" parent="1" source="m5" target="m6" style="endArrow=block;html=1;rounded=0;strokeColor=#6b7280;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" edge="1" parent="1" source="m6" target="m7" style="endArrow=block;html=1;rounded=0;strokeColor=#dc2626;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" edge="1" parent="1" source="m7" target="m8" style="endArrow=block;html=1;rounded=0;strokeColor=#6b7280;"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="pv19-gates" name="验收门槛与出门条件">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t7" value="PV19 验收门槛、出门条件与审计问题" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#111827;fontColor=#ffffff;fontSize=28;fontStyle=1;strokeColor=#111827;" vertex="1" parent="1"><mxGeometry x="60" y="40" width="820" height="70" as="geometry"/></mxCell>
        <mxCell id="g1" value="用户体验 Gate&#xa;一个浏览器路径内可见：workspace / workflow / canvas / Inspector / WorkflowDiff / version / runtime progress / human gate / evidence。&#xa;空、加载、失败、拒绝状态必须有明确下一步。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=15;" vertex="1" parent="1"><mxGeometry x="70" y="160" width="500" height="170" as="geometry"/></mxCell>
        <mxCell id="g2" value="BFF/DTO Gate&#xa;/bff/pv19/* route log 覆盖 state、graph、validate、diff、publish、run、inspect、human-actions、evidence。&#xa;DTO snapshot 包含 schema_version、scope、redaction_status、audit_refs、evidence_refs。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0e7ff;strokeColor=#4f46e5;fontSize=15;" vertex="1" parent="1"><mxGeometry x="630" y="160" width="520" height="170" as="geometry"/></mxCell>
        <mxCell id="g3" value="Runtime Gate&#xa;run 必须引用已发布 workflow_version_id。&#xa;报告必须包含 WorkflowInstance、StationRun、node status、runtime events、artifact refs、trace refs。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1210" y="160" width="500" height="170" as="geometry"/></mxCell>
        <mxCell id="g4" value="Human / Evidence Gate&#xa;human action 必须更新后端状态并记录 actor、action、before、after、audit ref。&#xa;Evidence 必须来自后端 artifact / trace / quality / audit read model。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=15;" vertex="1" parent="1"><mxGeometry x="70" y="410" width="500" height="170" as="geometry"/></mxCell>
        <mxCell id="g5" value="阻断条件&#xa;根路径仍为空白交付入口。&#xa;UI 模拟 run 或 frontend 构造 runtime truth。&#xa;发布版本和运行版本无法对应。&#xa;human action 只更新 toast。&#xa;业务样例定制 core/Gateway/App shell。&#xa;No False Green、redaction 或 claim matrix FAIL。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=15;" vertex="1" parent="1"><mxGeometry x="630" y="410" width="520" height="240" as="geometry"/></mxCell>
        <mxCell id="g6" value="允许出门声明&#xa;PV19 complete: runtime-backed workflow platform closed loop ready for bounded review.&#xa;&#xa;禁止解释为：production ready、complete Workflow Studio ready、Agent executor ready、Xpert parity complete、业务 Pack 完整产品化。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3f4f6;strokeColor=#6b7280;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1210" y="410" width="500" height="240" as="geometry"/></mxCell>
        <mxCell id="g7" value="核心审计问题&#xa;1 是否真实工作台入口？ 2 Graph 是否可 readback？ 3 Diff 是否确认后 publish？ 4 Run 是否引用 version？ 5 Human gate 是否改后端状态？ 6 Evidence 是否来自后端？ 7 Browser 是否无 direct runtime/store？ 8 是否无业务专用平台定制？ 9 负向 fixtures 是否能 fail？ 10 文档/截图是否未被当作实现证据？" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;" vertex="1" parent="1"><mxGeometry x="70" y="730" width="1640" height="160" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
