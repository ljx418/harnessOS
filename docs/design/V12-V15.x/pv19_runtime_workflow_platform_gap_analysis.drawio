        <mxCell id="a3" value="Browser Client&#xa;apps/workflow-console/src/api/workflowConsoleClient.ts&#xa;PV19 graph / validate / diff / publish / run / inspect / human / evidence DTO methods" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=15;" vertex="1" parent="1"><mxGeometry x="920" y="160" width="390" height="150" as="geometry"/></mxCell>
