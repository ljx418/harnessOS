  <diagram id="pv19-user-flow" name="平台闭环用户路径">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t4" value="PV19 用户可感知的平台闭环" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#111827;fontColor=#ffffff;fontSize=28;fontStyle=1;strokeColor=#111827;" vertex="1" parent="1"><mxGeometry x="60" y="40" width="720" height="70" as="geometry"/></mxCell>
        <mxCell id="u1" value="1 进入工作台&#xa;?studio=pv19-runtime-workflow-platform&#xa;看到 workspace / project / workflow / health" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=15;" vertex="1" parent="1"><mxGeometry x="70" y="160" width="310" height="120" as="geometry"/></mxCell>
        <mxCell id="u2" value="2 编排工作流&#xa;节点库、连线、参数、human gate station&#xa;前端状态必须可由 BFF readback" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=15;" vertex="1" parent="1"><mxGeometry x="430" y="160" width="310" height="120" as="geometry"/></mxCell>
        <mxCell id="u3" value="3 校验与 Diff&#xa;graph validate + WorkflowDiff&#xa;显示 before/after、risk、confirmation boundary" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;" vertex="1" parent="1"><mxGeometry x="790" y="160" width="310" height="120" as="geometry"/></mxCell>
        <mxCell id="u4" value="4 发布版本&#xa;用户确认后 publish WorkflowVersion&#xa;生成 version id、audit ref、readback snapshot" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1150" y="160" width="330" height="120" as="geometry"/></mxCell>
        <mxCell id="u5" value="5 启动运行&#xa;run 引用 workflow_version_id&#xa;创建 WorkflowInstance 和 StationRun" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0e7ff;strokeColor=#4f46e5;fontSize=15;" vertex="1" parent="1"><mxGeometry x="70" y="420" width="310" height="120" as="geometry"/></mxCell>
        <mxCell id="u6" value="6 Inspect Runtime&#xa;查看节点状态、事件、artifact refs、trace refs&#xa;不得由 UI 模拟 runtime truth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0e7ff;strokeColor=#4f46e5;fontSize=15;" vertex="1" parent="1"><mxGeometry x="430" y="420" width="310" height="120" as="geometry"/></mxCell>
        <mxCell id="u7" value="7 处理 Human Gate&#xa;approve / reject / input / retry&#xa;更新 approval、handoff、WorkflowInstance 或 StationRun 状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0e7ff;strokeColor=#4f46e5;fontSize=15;" vertex="1" parent="1"><mxGeometry x="790" y="420" width="340" height="120" as="geometry"/></mxCell>
        <mxCell id="u8" value="8 Evidence Review&#xa;artifact lineage、trace、quality、audit、claim matrix、redaction&#xa;形成 bounded review 证据包" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=15;" vertex="1" parent="1"><mxGeometry x="1190" y="420" width="350" height="120" as="geometry"/></mxCell>
        <mxCell id="v1" value="用户体验结果&#xa;一个业务工作流在通用平台中被编排、发布、运行、人工处理并审查证据。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3f4f6;strokeColor=#6b7280;fontSize=17;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="70" y="700" width="690" height="130" as="geometry"/></mxCell>
        <mxCell id="v2" value="平台证明结果&#xa;PV19 证明 runtime-backed workflow platform closed loop bounded review；仍不证明生产可用、完整 Studio 或完整 Agent executor。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=17;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="850" y="700" width="690" height="130" as="geometry"/></mxCell>
        <mxCell id="e1" edge="1" parent="1" source="u1" target="u2" style="endArrow=block;html=1;rounded=0;strokeColor=#2563eb;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" edge="1" parent="1" source="u2" target="u3" style="endArrow=block;html=1;rounded=0;strokeColor=#2563eb;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" edge="1" parent="1" source="u3" target="u4" style="endArrow=block;html=1;rounded=0;strokeColor=#d97706;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" edge="1" parent="1" source="u4" target="u5" style="endArrow=block;html=1;rounded=0;strokeColor=#4f46e5;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" edge="1" parent="1" source="u5" target="u6" style="endArrow=block;html=1;rounded=0;strokeColor=#4f46e5;"><mxGeometry relative="1" as="geometry"/></mxCell>
