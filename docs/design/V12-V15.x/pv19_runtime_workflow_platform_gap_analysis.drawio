<mxfile host="app.diagrams.net" modified="2026-06-27T00:00:00.000Z" agent="Codex" version="24.7.17" pages="7">
  <diagram id="pv19-overview" name="总览">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t1" value="PV19 Runtime-backed Workflow Studio Closed Loop" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#111827;fontColor=#ffffff;fontSize=28;fontStyle=1;strokeColor=#111827;" vertex="1" parent="1"><mxGeometry x="60" y="40" width="820" height="70" as="geometry"/></mxCell>
        <mxCell id="s1" value="目标体验&#xa;用户在真实工作台完成：编排工作流 -> WorkflowDiff -> 发布 WorkflowVersion -> Runtime 运行 WorkflowInstance -> 处理 human gate -> 审查 evidence。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=18;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="60" y="150" width="760" height="170" as="geometry"/></mxCell>
        <mxCell id="s2" value="当前可复用基线&#xa;V13 editable Studio pilot：画布编辑、graph validation、WorkflowDiff handoff。&#xa;PV17 product closed loop：Product Console、run inspect、evidence review。&#xa;PV18 Knowledge OPC：真实 data_service MCP、citation、quality、evidence。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=16;" vertex="1" parent="1"><mxGeometry x="60" y="360" width="520" height="230" as="geometry"/></mxCell>
        <mxCell id="s3" value="PV19 必须补齐&#xa;真实入口：?studio=pv19-runtime-workflow-platform。&#xa;Graph -> Version -> Run 强关联。&#xa;human gate 用现有 Station approval 字段和 waiting 状态表达。&#xa;Evidence 来自后端 artifact / trace / quality / audit read model。&#xa;Knowledge OPC 为主样例，folder-summary/reference workflow 为通用性复用检查。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0e7ff;strokeColor=#4f46e5;fontSize=16;" vertex="1" parent="1"><mxGeometry x="620" y="360" width="560" height="260" as="geometry"/></mxCell>
        <mxCell id="s4" value="No-Go / 阻断&#xa;不得声明 production ready。&#xa;不得声明 complete Workflow Studio ready。&#xa;不得声明 Agent executor ready。&#xa;不得用 V13/PV17/PV18 route 冒充 PV19 证据。&#xa;不得为业务样例定制 workflow core、Gateway core 或 App shell。&#xa;不得把 drawio、截图、介绍文档当 runtime evidence。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=16;" vertex="1" parent="1"><mxGeometry x="1220" y="150" width="520" height="330" as="geometry"/></mxCell>
        <mxCell id="s5" value="文档阶段结论&#xa;本图定义后续开发和验收方向；不产生 PASS。&#xa;实现完成声明只能是：PV19 complete: runtime-backed workflow platform closed loop ready for bounded review." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3f4f6;strokeColor=#6b7280;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1220" y="520" width="520" height="180" as="geometry"/></mxCell>
        <mxCell id="legend" value="颜色图例：绿色=已实现/可复用；蓝色=PV19 待新增；黄色=需修改/整合；红色=No-Go/阻断；灰色=文档或证据边界。" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f9fafb;strokeColor=#9ca3af;fontSize=15;" vertex="1" parent="1"><mxGeometry x="60" y="1060" width="1680" height="60" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="pv19-gap" name="当前架构与目标差异">
    <mxGraphModel dx="1800" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="t2" value="当前架构与 PV19 目标架构差异" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#111827;fontColor=#ffffff;fontSize=28;fontStyle=1;strokeColor=#111827;" vertex="1" parent="1"><mxGeometry x="60" y="40" width="720" height="70" as="geometry"/></mxCell>
        <mxCell id="c1" value="当前：V13 Studio Pilot&#xa;apps/workflow-console/src/ui/v13/V13EditableStudio.tsx&#xa;支持画布编辑、graph validation、WorkflowDiff handoff；不证明 Runtime run。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=16;" vertex="1" parent="1"><mxGeometry x="70" y="160" width="460" height="150" as="geometry"/></mxCell>
        <mxCell id="c2" value="当前：PV17 Product Closed Loop&#xa;Product Console -> Mission Studio -> run inspect -> evidence。&#xa;证明 bounded 产品闭环；不证明完整 Studio 或 Agent executor。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=16;" vertex="1" parent="1"><mxGeometry x="70" y="350" width="460" height="150" as="geometry"/></mxCell>
        <mxCell id="c3" value="当前：PV18 Knowledge OPC&#xa;packs/knowledge + KnowledgeMcpWorkflowRunner + data_service_mcp。&#xa;证明真实业务样例；不证明通用平台完整闭环。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=16;" vertex="1" parent="1"><mxGeometry x="70" y="540" width="460" height="150" as="geometry"/></mxCell>
        <mxCell id="g1" value="差异 1：入口与工作台体验&#xa;根路径不能继续作为空白交付体验。&#xa;PV19 需要真实 workbench：canvas、节点库、Inspector、版本、运行、evidence 区域同屏可见。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=16;" vertex="1" parent="1"><mxGeometry x="680" y="150" width="480" height="150" as="geometry"/></mxCell>
        <mxCell id="g2" value="差异 2：Graph -> Version -> Run&#xa;V13 graph handoff 必须升级为 WorkflowSpecGraph readback、WorkflowDiff 确认、WorkflowVersion 发布和 WorkflowInstance 运行强关联。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0e7ff;strokeColor=#4f46e5;fontSize=16;" vertex="1" parent="1"><mxGeometry x="680" y="340" width="480" height="170" as="geometry"/></mxCell>
        <mxCell id="g3" value="差异 3：Human Gate&#xa;人工节点必须改变后端受控状态，留下 approval/handoff/audit 记录；不得只是按钮 toast 或前端状态。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0e7ff;strokeColor=#4f46e5;fontSize=16;" vertex="1" parent="1"><mxGeometry x="680" y="550" width="480" height="150" as="geometry"/></mxCell>
        <mxCell id="g4" value="差异 4：Evidence 聚合&#xa;同一 run 必须聚合 artifact lineage、trace refs、quality refs、audit refs、claim-to-evidence matrix 和 redaction 状态。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0e7ff;strokeColor=#4f46e5;fontSize=16;" vertex="1" parent="1"><mxGeometry x="680" y="740" width="480" height="150" as="geometry"/></mxCell>
        <mxCell id="target" value="PV19 目标状态&#xa;浏览器只通过 /bff/pv19/* DTO 与后端交互。&#xa;Runtime 按发布 WorkflowVersion 运行。&#xa;human action 更新 WorkflowInstance / StationRun / approval 状态。&#xa;Evidence panel 只读取后端 read model。&#xa;业务样例不得污染平台核心。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=16;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="1280" y="260" width="430" height="360" as="geometry"/></mxCell>
        <mxCell id="e1" edge="1" parent="1" source="c1" target="g2" style="endArrow=block;html=1;rounded=0;strokeColor=#6b7280;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" edge="1" parent="1" source="c2" target="g1" style="endArrow=block;html=1;rounded=0;strokeColor=#6b7280;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" edge="1" parent="1" source="c2" target="g4" style="endArrow=block;html=1;rounded=0;strokeColor=#6b7280;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" edge="1" parent="1" source="c3" target="g3" style="endArrow=block;html=1;rounded=0;strokeColor=#6b7280;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e5" edge="1" parent="1" source="g1" target="target" style="endArrow=block;html=1;rounded=0;strokeColor=#2563eb;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" edge="1" parent="1" source="g2" target="target" style="endArrow=block;html=1;rounded=0;strokeColor=#2563eb;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" edge="1" parent="1" source="g3" target="target" style="endArrow=block;html=1;rounded=0;strokeColor=#2563eb;"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e8" edge="1" parent="1" source="g4" target="target" style="endArrow=block;html=1;rounded=0;strokeColor=#2563eb;"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
