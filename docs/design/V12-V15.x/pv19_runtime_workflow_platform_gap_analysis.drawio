        <mxCell id="a1" value="Browser Shell&#xa;apps/workflow-console/src/App.tsx&#xa;新增/接入 ui/pv19/PV19RuntimeWorkbench.tsx&#xa;根路径不得作为空白交付入口" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=15;" vertex="1" parent="1"><mxGeometry x="80" y="160" width="360" height="150" as="geometry"/></mxCell>
