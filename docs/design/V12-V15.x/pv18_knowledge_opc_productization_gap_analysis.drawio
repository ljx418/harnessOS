          <mxGeometry x="60" y="50" width="1680" height="70" as="geometry" />
        </mxCell>
        <mxCell id="g1" value="文档 Gate&lt;br&gt;PV18 Markdown / drawio / schemas 存在&lt;br&gt;drawio 页数不超过 8&lt;br&gt;每份文档有用途/对象/边界&lt;br&gt;代码实体路径真实可追踪&lt;br&gt;planned contract 不等于实现证据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3f4f6;strokeColor=#6b7280;fontSize=17;" vertex="1" parent="1">
          <mxGeometry x="90" y="180" width="420" height="230" as="geometry" />
        </mxCell>
        <mxCell id="g2" value="用户体验 Gate&lt;br&gt;能看到 workspace/source/build/query/citation/quality/evidence&lt;br&gt;失败、空状态、审批、citation missing 有明确下一步" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=17;" vertex="1" parent="1">
          <mxGeometry x="560" y="180" width="520" height="230" as="geometry" />
        </mxCell>
        <mxCell id="g3" value="证据 Gate&lt;br&gt;browser screenshot/action log&lt;br&gt;BFF route log&lt;br&gt;DTO snapshots + schema validation&lt;br&gt;artifact lineage&lt;br&gt;trace refs&lt;br&gt;negative fixtures&lt;br&gt;platform generality review&lt;br&gt;claim-to-evidence&lt;br&gt;redaction + No False Green" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=17;" vertex="1" parent="1">
          <mxGeometry x="1130" y="180" width="470" height="300" as="geometry" />
        </mxCell>
        <mxCell id="g4" value="阻断条件&lt;br&gt;browser 直连 /v1/rpc 或 connector runtime&lt;br&gt;无 citation 仍显示已验证答案&lt;br&gt;correction plan 自动改写知识库&lt;br&gt;raw secret/provider/artifact 泄漏&lt;br&gt;Knowledge-only 平台内核定制&lt;br&gt;任何 forbidden positive claim" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=17;" vertex="1" parent="1">
          <mxGeometry x="90" y="570" width="650" height="260" as="geometry" />
        </mxCell>
        <mxCell id="g5" value="文档阶段出门&lt;br&gt;PV18 Knowledge OPC productization development plan ready for implementation review.&lt;br&gt;&lt;br&gt;实现阶段未来出门&lt;br&gt;只能由 real-data evidence package、schema validation 和 acceptance runner 定义 bounded claim；planned contract 不能当作 PASS 证据。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3f4f6;strokeColor=#6b7280;fontSize=18;fontStyle=1;" vertex="1" parent="1">
