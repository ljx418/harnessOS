<mxfile host="app.diagrams.net" modified="2026-06-14T00:00:00.000Z" agent="codex" version="24.7.17" type="device">
  <diagram id="v12-user-state-machine" name="V12 用户态状态机">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="V12 用户态状态机：用户在产品工作台会看到哪些状态" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f172a;strokeColor=#0f172a;fontColor=#ffffff;fontSize=28;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1480" height="70" as="geometry" />
        </mxCell>
        <mxCell id="api" value="API / 环境状态&lt;br&gt;healthy：API 健康&lt;br&gt;degraded：部分服务降级&lt;br&gt;offline：API 不可用&lt;br&gt;misconfigured：前后端配置不一致" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="60" y="150" width="300" height="150" as="geometry" />
        </mxCell>
        <mxCell id="session" value="Session / Chat 状态&lt;br&gt;idle：等待输入&lt;br&gt;composing：用户正在输入&lt;br&gt;thinking：模型/Agent 生成中&lt;br&gt;proposal_ready：提案就绪&lt;br&gt;awaiting_confirmation：等待确认&lt;br&gt;blocked：被策略阻断" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="420" y="150" width="330" height="180" as="geometry" />
        </mxCell>
        <mxCell id="canvas" value="Canvas / Workbench 状态&lt;br&gt;empty：无工作流&lt;br&gt;read_only：只读投影&lt;br&gt;node_hover：悬停节点&lt;br&gt;node_selected：选中节点&lt;br&gt;inspecting：右侧检查器打开&lt;br&gt;action_disabled：动作不可用并显示原因" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="810" y="150" width="330" height="180" as="geometry" />
        </mxCell>
        <mxCell id="evidence" value="Evidence / Audit 状态&lt;br&gt;none：无证据&lt;br&gt;collecting：证据收集中&lt;br&gt;ready：证据可审查&lt;br&gt;redacted：仅展示脱敏引用&lt;br&gt;failed：证据缺失或校验失败" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e8ff;strokeColor=#9333ea;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="1200" y="150" width="300" height="160" as="geometry" />
        </mxCell>
        <mxCell id="run" value="Run / Runtime 状态&lt;br&gt;not_started：未运行&lt;br&gt;queued：已排队&lt;br&gt;running：运行中&lt;br&gt;completed：已完成&lt;br&gt;failed：失败并保留 trace&lt;br&gt;cancelled：已取消&lt;br&gt;requires_review：需要人工审查" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="420" y="430" width="330" height="190" as="geometry" />
        </mxCell>
        <mxCell id="governance" value="Governance / 权限状态&lt;br&gt;allowed：允许&lt;br&gt;denied：拒绝并说明原因&lt;br&gt;disabled：当前阶段不可用&lt;br&gt;needs_confirmation：需要用户确认&lt;br&gt;needs_policy_review：需要策略审查" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="810" y="440" width="330" height="170" as="geometry" />
        </mxCell>
        <mxCell id="ui" value="用户可见反馈规则&lt;br&gt;1. 用户输入后不得 silent wait&lt;br&gt;2. 禁用动作必须显示原因&lt;br&gt;3. failed/blocked 不得被 completed 覆盖&lt;br&gt;4. evidence scope 必须可见&lt;br&gt;5. proposal 不得显示成 runtime execution" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#64748b;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="420" width="300" height="190" as="geometry" />
        </mxCell>
        <mxCell id="e1" value="输入目标" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#64748b;fontSize=14;" edge="1" parent="1" source="api" target="session">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" value="生成提案" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#64748b;fontSize=14;" edge="1" parent="1" source="session" target="canvas">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="选中节点" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#64748b;fontSize=14;" edge="1" parent="1" source="canvas" target="evidence">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" value="确认前" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#dc2626;fontSize=14;dashed=1;" edge="1" parent="1" source="session" target="governance">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="确认后才进入运行链路" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#16a34a;fontSize=14;" edge="1" parent="1" source="governance" target="run">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="颜色说明&lt;br&gt;蓝：环境/API&lt;br&gt;黄：会话/提案&lt;br&gt;绿：画布交互&lt;br&gt;紫：证据审查&lt;br&gt;红：运行态&lt;br&gt;橙：治理/权限" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#cbd5e1;fontSize=16;" vertex="1" parent="1">
          <mxGeometry x="1200" y="440" width="300" height="170" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
