          <mxGeometry x="1210" y="370" width="520" height="260" as="geometry" />
        </mxCell>
        <mxCell id="overview-outcome" value="PV16 目标体验：用户能完成真实产品运行时硬化路径：创建/更新产品实体 → 确认 WorkflowSpec run → 查看 runtime-backed 进度与证据 → 完成本地部署硬化 smoke → 审计全部正向声明。" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#f8fafc;strokeColor=#94a3b8;fontColor=#111827;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;spacing=18;" vertex="1" parent="1">
