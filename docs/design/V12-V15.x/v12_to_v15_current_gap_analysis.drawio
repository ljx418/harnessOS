  <diagram id="acceptance" name="验收门槛">
    <mxGraphModel dx="1900" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="ac-title" value="V12-V15 验收门槛：用户体验 + 架构边界 + 真实证据同时满足" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f172a;strokeColor=#0f172a;fontColor=#ffffff;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1800" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ac-user" value="用户体验门槛&lt;br&gt;1. 浏览器可进入产品入口&lt;br&gt;2. 可创建项目和 Station Agent&lt;br&gt;3. V12 可打开只读画布工作台并选中节点看检查器&lt;br&gt;4. V12 产品质感：视觉层级、节点可读、响应式、组件一致&lt;br&gt;5. V12 交互深度：Inspector 联动、禁用原因、add/layout/history placeholder、有键盘/焦点反馈&lt;br&gt;6. 用户目标 -&gt; proposal -&gt; graph review -&gt; revise/confirm -&gt; run -&gt; evidence 链路可见&lt;br&gt;7. V13 可 add/configure/move/connect/auto-layout 并确认 diff&lt;br&gt;8. 可安装受控 extension&lt;br&gt;9. 可看 trace/metrics/audit&lt;br&gt;10. 可自托管 smoke&lt;br&gt;11. 用户输入、点击、失败、禁用动作都有可见反馈" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="80" y="150" width="520" height="360" as="geometry" />
        </mxCell>
        <mxCell id="ac-arch" value="架构门槛&lt;br&gt;V12 实现前必须接受 schema/DTO、BFF allowlist、browser denylist&lt;br&gt;Browser 只走 BFF/DTO&lt;br&gt;Studio 不能直写 runtime truth&lt;br&gt;WorkflowDiff 未确认不能 publish/run&lt;br&gt;Agent 配置不能暴露 raw credential&lt;br&gt;Plugin install 走 compatibility/scope/policy&lt;br&gt;Observability 只读 runtime truth&lt;br&gt;Deployment smoke 必须含 frontend/API health&lt;br&gt;UX 自动化验收不能替代 runtime evidence 或人工体验审查" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="690" y="150" width="520" height="360" as="geometry" />
        </mxCell>
        <mxCell id="ac-evidence" value="证据门槛&lt;br&gt;Browser E2E screenshots + constrained viewport screenshots&lt;br&gt;Playwright action logs：selection / disabled reason / goal-to-canvas / add-configure-connect&lt;br&gt;DTO snapshots + BFF/API route logs&lt;br&gt;Schema parse + negative fixtures&lt;br&gt;WorkflowSpecGraph round-trip&lt;br&gt;Runtime workflow evidence&lt;br&gt;Product polish review + human UX review&lt;br&gt;Plugin unsafe denial&lt;br&gt;Trace/metrics/audit export&lt;br&gt;Compose smoke output&lt;br&gt;No False Green PASS&lt;br&gt;Redaction PASS&lt;br&gt;Drawio XML valid" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="1300" y="150" width="520" height="360" as="geometry" />
        </mxCell>
        <mxCell id="ac-non" value="不能作为 PASS 的材料&lt;br&gt;Xpert reference screenshot&lt;br&gt;概念图&lt;br&gt;规划文档&lt;br&gt;单纯截图但无 runtime/API/BFF 证据&lt;br&gt;transcript-only / report-only&lt;br&gt;无 health check 的部署说明" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="600" width="820" height="200" as="geometry" />
        </mxCell>
        <mxCell id="ac-final" value="V15 最终通过条件&lt;br&gt;V12/V13/V14/V15 evidence packages 全部存在并 PASS；V12 画布基础与 V13 可编辑 Studio 证据均存在；UX 自动化验收与人工体验审查存在并 PASS；无未接受 FAIL/BLOCKED；用户场景矩阵 PASS 或 accepted bounded PARTIAL；No False Green PASS；Redaction PASS；drawio XML valid；V15 允许声明仅为 frontend interaction baseline ready for review" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="980" y="600" width="840" height="200" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="exit" name="出门条件">
    <mxGraphModel dx="1900" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="ex-title" value="出门条件与 No-Go：防止过度承诺和错误实现路线" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f172a;strokeColor=#0f172a;fontColor=#ffffff;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1800" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ex-v12" value="V12 出门&lt;br&gt;Readiness contracts accepted&lt;br&gt;Product shell + entity + workbench + 只读画布基础 evidence PASS&lt;br&gt;V12-Q 产品质感 hardening PASS&lt;br&gt;V12-I 交互深度 foundation PASS&lt;br&gt;BFF allowlist / browser denylist PASS&lt;br&gt;No raw secret / no runtime claim / no complete Studio claim" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=17;" vertex="1" parent="1">
          <mxGeometry x="90" y="160" width="380" height="150" as="geometry" />
        </mxCell>
        <mxCell id="ex-v13" value="V13 出门&lt;br&gt;V13 readiness accepted&lt;br&gt;Studio graph add/configure/move/connect/auto-layout PASS&lt;br&gt;Graph round-trip PASS&lt;br&gt;WorkflowDiff confirmation transcript PASS&lt;br&gt;No direct runtime/store write" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fed7aa;strokeColor=#ea580c;fontSize=17;" vertex="1" parent="1">
          <mxGeometry x="520" y="160" width="380" height="150" as="geometry" />
        </mxCell>
        <mxCell id="ex-v14" value="V14 出门&lt;br&gt;V14 readiness accepted&lt;br&gt;Approved install PASS&lt;br&gt;Unsafe/incompatible deny PASS&lt;br&gt;Scoped activation + redacted config PASS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fed7aa;strokeColor=#ea580c;fontSize=17;" vertex="1" parent="1">
          <mxGeometry x="950" y="160" width="380" height="150" as="geometry" />
        </mxCell>
        <mxCell id="ex-v15" value="V15 出门&lt;br&gt;V15 readiness accepted&lt;br&gt;Observability + deployment smoke PASS&lt;br&gt;Final scenario matrix PASS&lt;br&gt;Playwright UX checks + human UX review PASS&lt;br&gt;Allowed claim only: Xpert-level frontend interaction baseline ready for review" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=17;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1380" y="160" width="420" height="150" as="geometry" />
        </mxCell>
        <mxCell id="ex-nogo" value="No-Go / Stop Conditions&lt;br&gt;跳过 V12-V14 证据直接做 V15 final；浏览器直连 /v1/rpc 或 internal runtime/store；WorkflowDiff 自动 publish/run；plugin 执行未审代码；raw secret/raw provider payload 泄露；部署 smoke 无实际命令输出；用户输入/点击/失败/禁用动作无可见反馈；缺 UX 自动化验收或人工体验审查；仅工程原型却声称产品级/Xpert级体验；claim 写成 production ready / complete Workflow Studio ready / Xpert parity complete / Agent executor ready" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="90" y="420" width="1710" height="180" as="geometry" />
        </mxCell>
        <mxCell id="ex-next" value="下一步建议&lt;br&gt;先做 V12 implementation readiness audit：冻结 DTO/schema、BFF route allowlist、browser denylist、product shell/workbench evidence contract、用户场景验收矩阵。通过后再进入 V12 实现；不得直接进入 V13/V14/V15 runtime/product implementation。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="90" y="690" width="1710" height="150" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="figma-prototype-gate" name="V12 Figma 原型门禁">
    <mxGraphModel dx="1900" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="fp-title" value="V12 原型门禁：组件草图先行，再 Figma/高保真冻结，再进入浏览器实现" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f172a;strokeColor=#0f172a;fontColor=#ffffff;fontSize=24;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1800" height="70" as="geometry" />
        </mxCell>
        <mxCell id="fp-reference" value="参考输入&lt;br&gt;Xpert 画布体验审计&lt;br&gt;左侧全局导航&lt;br&gt;实体侧栏&lt;br&gt;点阵画布&lt;br&gt;节点检查器&lt;br&gt;添加菜单&lt;br&gt;顶部预览/发布工具栏&lt;br&gt;底部画布工具条&lt;br&gt;&lt;b&gt;只作为 benchmark，不作为 HarnessOS 证据&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e5e7eb;strokeColor=#6b7280;fontSize=17;" vertex="1" parent="1">
          <mxGeometry x="70" y="150" width="330" height="330" as="geometry" />
        </mxCell>
        <mxCell id="fp-design" value="V12-0A 组件草图交付&lt;br&gt;Topbar / Product nav / Entity sidebar&lt;br&gt;Canvas Workbench / Agent Node Card / Edge Port State&lt;br&gt;Right Inspector / Chat Workbench / Proposal Timeline&lt;br&gt;Evidence / Quality / Trace Drawer&lt;br&gt;禁用 / 失败 / 权限拒绝状态&lt;br&gt;imag2 概念图或 HTML wireframe&lt;br&gt;HTML 汇总报告 + 逐组件决策&lt;br&gt;&lt;b&gt;先验收组件方向，不直接冻结整页&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fed7aa;strokeColor=#ea580c;fontSize=17;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="150" width="420" height="330" as="geometry" />
        </mxCell>
        <mxCell id="fp-review" value="V12-0A 人工体验审查&lt;br&gt;每个组件是否有清楚用户目标&lt;br&gt;视觉层级和信息密度是否可接受&lt;br&gt;画布是否接近 Xpert 工作台密度但不照搬&lt;br&gt;节点/Agent/工具/MCP 是否可理解&lt;br&gt;Inspector 是否解释角色、目标、记忆、工具、证据&lt;br&gt;Chat Workbench 是否能表达 proposal timeline&lt;br&gt;目标到 graph review 到 evidence 是否连续&lt;br&gt;禁用动作是否有原因&lt;br&gt;UI 文案是否无过度承诺&lt;br&gt;通过后才进入 Figma/高保真冻结" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=17;" vertex="1" parent="1">
          <mxGeometry x="1020" y="150" width="400" height="330" as="geometry" />
        </mxCell>
        <mxCell id="fp-impl" value="V12 浏览器实现&lt;br&gt;前置：V12-0A 组件草图 PASS + V12-0P Figma/高保真 PASS&lt;br&gt;React/Browser Product Shell&lt;br&gt;shadcn-style component foundation&lt;br&gt;XyFlow read-only canvas&lt;br&gt;BFF route allowlist&lt;br&gt;Browser denylist&lt;br&gt;CanvasReadModel DTO&lt;br&gt;CanvasNodeProjection&lt;br&gt;CanvasInspectorProjection&lt;br&gt;真实 HarnessOS 页面截图&lt;br&gt;Playwright/network/DTO 证据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=17;" vertex="1" parent="1">
          <mxGeometry x="1500" y="150" width="330" height="330" as="geometry" />
        </mxCell>
        <mxCell id="fp-edge-1" value="抽象经验" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeWidth=2;strokeColor=#64748b;" edge="1" parent="1" source="fp-reference" target="fp-design">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="fp-edge-2" value="审核通过" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeWidth=2;strokeColor=#d97706;" edge="1" parent="1" source="fp-design" target="fp-review">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="fp-edge-3" value="才允许实现" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=classic;strokeWidth=2;strokeColor=#2563eb;" edge="1" parent="1" source="fp-review" target="fp-impl">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="fp-gates" value="进入 V12 实现前必须满足&lt;br&gt;1. V12-0A 组件草图 HTML 报告 PASS&lt;br&gt;2. 第一批 6 个核心组件逐项 accepted 或 bounded accepted&lt;br&gt;3. component-prototype-review-data.json 可解析并通过 schema&lt;br&gt;4. artifact-manifest.json 记录真实 asset/wireframe/hash，不是 PLANNED_NOT_EVIDENCE&lt;br&gt;5. 每个组件有 user goal / visible data / actions / disabled states / PASS condition&lt;br&gt;6. 缺图或缺 wireframe 必须记录 visual_artifact_exception_reason&lt;br&gt;7. Figma URL / 高保真原型记录&lt;br&gt;8. 原型截图记录&lt;br&gt;9. 原型审查 PASS&lt;br&gt;10. 组件草图/Figma 不被计为 runtime evidence&lt;br&gt;11. PRD/架构/验收计划和 drawio 已同步&lt;br&gt;12. No False Green + redaction 扫描无违规" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="600" width="820" height="220" as="geometry" />
        </mxCell>
        <mxCell id="fp-stop" value="停止条件&lt;br&gt;跳过组件草图直接做 Figma 或真实开发&lt;br&gt;组件草图被当成真实运行证据&lt;br&gt;Figma 原型被当成真实运行证据&lt;br&gt;原型只是静态截图或 Xpert 截图拼贴&lt;br&gt;原型隐藏 V12 只读画布边界&lt;br&gt;Apply / Publish / Run 没有禁用、proposal-only 或 confirmation 语义&lt;br&gt;出现 Xpert parity complete / product-grade frontend complete / complete Workflow Studio ready / production ready / Agent executor ready 正向声明" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="980" y="600" width="850" height="220" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
