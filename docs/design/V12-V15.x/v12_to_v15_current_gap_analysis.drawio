  <diagram id="plan" name="开发及验收计划">
    <mxGraphModel dx="3981" dy="1001" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="pl-title" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f172a;strokeColor=#0f172a;fontColor=#ffffff;fontSize=24;fontStyle=1;" value="V12-V15 开发及验收计划：每阶段只凭本阶段证据过门" vertex="1">
          <mxGeometry height="70" width="1800" x="40" y="30" as="geometry" />
        </mxCell>
        <mxCell id="pl-v12" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=17;" value="V12 产品实体 + 浏览器 Workbench + 只读画布基础&lt;br&gt;先做 V12-0A：组件拆分、imag2/HTML 草图、HTML 汇总、逐组件人类验收&lt;br&gt;再做 V12-0P：Figma/高保真原型冻结&lt;br&gt;再冻结：readiness、entity/workbench contracts、canvas read-model、BFF/browser boundary、evidence/user acceptance&lt;br&gt;开发：Workspace / Project / StationAgent / BFF / Onboarding / Workbench / Read-only Canvas / Inspector Foundation&lt;br&gt;新增体验硬化：V12-Q 产品质感、V12-I 交互深度、视觉层级、节点可读、Inspector 联动、禁用原因、目标到 proposal 到画布链路&lt;br&gt;验收：schema parse、BFF log、browser screenshots、API health、proposal timeline、selected-node inspector、browser denylist、component build、人类 UX review" vertex="1">
          <mxGeometry height="220" width="1080" x="-610" y="160" as="geometry" />
        </mxCell>
        <mxCell id="pl-v13" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fed7aa;strokeColor=#ea580c;fontSize=17;" value="V13 可编辑 Workflow Studio + Visual DSL&lt;br&gt;先冻结：Studio/DSL readiness、Graph schema、BFF routes、Browser denylist、Graph fixtures&lt;br&gt;开发：Add menu、节点配置、Node/Edge 拖拽连线、端口校验、Inspector、auto-layout、minimap、WorkflowDiff、Versioning、Round-trip&lt;br&gt;验收：Browser E2E、graph action trace、round-trip、no auto publish/run、Studio screenshot、confirmation transcript" vertex="1">
          <mxGeometry height="220" width="390" x="530" y="160" as="geometry" />
        </mxCell>
        <mxCell id="pl-v14" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fed7aa;strokeColor=#ea580c;fontSize=17;" value="V14 Plugin / Skill / Tool / MCP 生态&lt;br&gt;先冻结：Manifest、Compatibility resolver、Scoped activation、Unsafe denial fixtures&lt;br&gt;开发：Manifest、Compatibility、Install Decision、Scoped Activation、Capability Binding&lt;br&gt;验收：approved install PASS、unsafe deny PASS、secret redacted、tool/MCP policy enforced" vertex="1">
          <mxGeometry height="220" width="390" x="980" y="160" as="geometry" />
        </mxCell>
        <mxCell id="pl-v15" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fed7aa;strokeColor=#ea580c;fontSize=17;" value="V15 可观测 + 部署 + 交互基线&lt;br&gt;先冻结：Observability DTO、Deployment smoke、Health diagnostics、Final scenario matrix、Interaction acceptance plan&lt;br&gt;开发：Trace、Metrics、Audit、Incident、Deploy Profile、Health Diagnostics、Final Scenario Matrix、UX evidence package&lt;br&gt;验收：compose smoke、browser/API health、workflow smoke、Playwright UX checks、human UX review、No False Green、redaction、drawio XML" vertex="1">
          <mxGeometry height="220" width="390" x="1430" y="160" as="geometry" />
        </mxCell>
        <mxCell id="pl-scenarios" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=18;" value="关键用户场景验收&lt;br&gt;1. 产品 onboarding 可进入并显示系统状态&lt;br&gt;2. 创建 workspace/project/app&lt;br&gt;3. 打开浏览器画布工作台：实体侧栏 / 只读节点 / 选中检查器&lt;br&gt;4. 用户目标 -&gt; proposal timeline -&gt; graph review -&gt; revise/confirm -&gt; run review -&gt; evidence review&lt;br&gt;5. 创建 Station Agent 并绑定 tool/skill/MCP&lt;br&gt;6. Studio 可视化编辑、add/configure/connect/auto-layout 并 round-trip&lt;br&gt;7. 确认后运行并审查 output/quality/evidence&lt;br&gt;8. 安装插件并看到 scoped activation / unsafe deny&lt;br&gt;9. 自托管 smoke 完成浏览器工作流" vertex="1">
          <mxGeometry height="300" width="840" x="80" y="480" as="geometry" />
        </mxCell>
        <mxCell id="pl-evidence" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=18;" value="证据包结构&lt;br&gt;V12 readiness：schema/DTO、BFF allowlist、browser denylist、用户场景矩阵&lt;br&gt;V13 readiness：Studio/DSL schema、graph fixtures、route boundary&lt;br&gt;V14 readiness：manifest、compatibility、unsafe denial fixtures&lt;br&gt;V15 readiness：observability DTO、deployment smoke、final matrix、interaction acceptance&lt;br&gt;V12-V15 evidence packages：每包必须含测试输出、截图、BFF/API 日志、运行证据、UX 检查、人工体验审查、claim scan、redaction scan" vertex="1">
          <mxGeometry height="300" width="840" x="980" y="480" as="geometry" />
        </mxCell>
