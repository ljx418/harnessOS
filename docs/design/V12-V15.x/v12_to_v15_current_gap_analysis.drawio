  <diagram name="目标架构与当前差异" id="pv16-architecture-gap">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="arch-title" value="目标架构与当前架构差异" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#0f172a;strokeColor=#0f172a;fontColor=#ffffff;fontSize=28;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1720" height="70" as="geometry" />
        </mxCell>
        <mxCell id="arch-current-title" value="当前已验收架构" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#111827;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="140" width="720" height="60" as="geometry" />
        </mxCell>
        <mxCell id="arch-target-title" value="PV16 目标架构" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fef3c7;strokeColor=#d97706;fontColor=#111827;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="1000" y="140" width="720" height="60" as="geometry" />
        </mxCell>
        <mxCell id="arch-current" value="浏览器审查面&lt;br&gt;V12/V13/V14/V15 页面&lt;br&gt;BFF-shaped DTO&lt;br&gt;静态/测试证据包&lt;br&gt;runtime_backed=false&lt;br&gt;handoff / review / smoke 证据" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#f0fdf4;strokeColor=#22c55e;fontColor=#111827;fontSize=17;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1">
          <mxGeometry x="80" y="240" width="720" height="250" as="geometry" />
        </mxCell>
        <mxCell id="arch-target" value="产品运行时硬化链路&lt;br&gt;Browser → BFF-only mutation DTO&lt;br&gt;Durable product entities + audit refs&lt;br&gt;WorkflowSpec confirmation → Controlled Runtime Gateway&lt;br&gt;Runtime events → trace / artifact / quality / evidence refs&lt;br&gt;Deployment health + rollback evidence" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fffbeb;strokeColor=#f59e0b;fontColor=#111827;fontSize=17;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1">
          <mxGeometry x="1000" y="240" width="720" height="250" as="geometry" />
        </mxCell>
        <mxCell id="arch-arrow" edge="1" parent="1" source="arch-current" target="arch-target" style="endArrow=block;html=1;rounded=1;strokeColor=#d97706;strokeWidth=3;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arch-diff1" value="差异 1：数据所有权&lt;br&gt;当前：DTO 投影和审查证据&lt;br&gt;PV16：产品实体可持久化变更，并携带 audit ref、ownership、policy result" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#111827;fontSize=16;align=left;verticalAlign=top;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="90" y="590" width="500" height="150" as="geometry" />
        </mxCell>
        <mxCell id="arch-diff2" value="差异 2：运行证据&lt;br&gt;当前：handoff / smoke / review&lt;br&gt;PV16：受控 runtime 产生 run progress、event log、artifact refs、trace refs" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#111827;fontSize=16;align=left;verticalAlign=top;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="650" y="590" width="500" height="150" as="geometry" />
        </mxCell>
        <mxCell id="arch-diff3" value="差异 3：部署与运维&lt;br&gt;当前：bounded local smoke&lt;br&gt;PV16：命令输出、health report、配置脱敏、rollback notes 与失败态截图" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#111827;fontSize=16;align=left;verticalAlign=top;spacing=14;" vertex="1" parent="1">
          <mxGeometry x="1210" y="590" width="500" height="150" as="geometry" />
        </mxCell>
        <mxCell id="arch-guard" value="架构护栏：浏览器不直连内部 runtime/store；observability 只读 runtime evidence；部署 smoke 不等于生产；所有正向声明必须能映射到 evidence artifact。" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fee2e2;strokeColor=#dc2626;fontColor=#111827;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;spacing=18;" vertex="1" parent="1">
          <mxGeometry x="180" y="840" width="1440" height="110" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="PV16 开发及验收计划" id="pv16-plan">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="plan-title" value="PV16 开发及验收计划" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#0f172a;strokeColor=#0f172a;fontColor=#ffffff;fontSize=28;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1720" height="70" as="geometry" />
        </mxCell>
        <mxCell id="r0" value="PV16-R0&lt;br&gt;范围与审计冻结&lt;br&gt;PRD/架构覆盖、schemas、runner、stop conditions" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fef3c7;strokeColor=#d97706;fontColor=#111827;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="180" width="250" height="140" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="PV16-S1&lt;br&gt;产品实体持久化&lt;br&gt;Workspace / Project / App / Station Agent mutation + audit refs" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#111827;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="370" y="180" width="250" height="140" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="PV16-S2&lt;br&gt;真实运行检视 Pilot&lt;br&gt;确认 WorkflowSpec → runtime events → trace/artifact/evidence refs" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#111827;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="670" y="180" width="250" height="140" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="PV16-S3&lt;br&gt;部署硬化 smoke&lt;br&gt;命令输出 / health report / rollback / 配置脱敏" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#111827;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="970" y="180" width="250" height="140" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="PV16-S4&lt;br&gt;产品旅程硬化&lt;br&gt;setup → Studio → run review → operations" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#111827;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1270" y="180" width="250" height="140" as="geometry" />
        </mxCell>
        <mxCell id="sa" value="PV16-SA&lt;br&gt;聚合验收&lt;br&gt;acceptance-data / manifest / claim-to-evidence / scans" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#111827;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="70" y="430" width="250" height="140" as="geometry" />
        </mxCell>
        <mxCell id="plan-evidence" value="每个子阶段必须输出&lt;br&gt;1. 用户可见结果截图或日志&lt;br&gt;2. BFF route log 与 browser network log&lt;br&gt;3. DTO/schema 验证&lt;br&gt;4. PRD 规格检视与架构检视&lt;br&gt;5. audit closure、No False Green、redaction scan" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#f8fafc;strokeColor=#94a3b8;fontColor=#111827;fontSize=17;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1">
          <mxGeometry x="390" y="420" width="560" height="230" as="geometry" />
        </mxCell>
        <mxCell id="plan-stop" value="高风险停止条件&lt;br&gt;外部密钥或不可逆 runtime action&lt;br&gt;浏览器直连内部 runtime/store&lt;br&gt;无法区分 fixture 与真实 runtime evidence&lt;br&gt;部署 smoke 需要破坏性变更&lt;br&gt;任何过度承诺无法关闭" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fee2e2;strokeColor=#dc2626;fontColor=#111827;fontSize=17;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1">
          <mxGeometry x="1010" y="420" width="560" height="230" as="geometry" />
        </mxCell>
        <mxCell id="plan-outcome" value="本阶段完成后的目标体验：用户不只看到审查页面，而是能在受治理边界内完成产品实体变更、确认运行、查看 runtime-backed 证据、完成部署健康检查，并让审计者追踪每个正向声明。" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#ecfeff;strokeColor=#0891b2;fontColor=#111827;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;spacing=18;" vertex="1" parent="1">
          <mxGeometry x="150" y="800" width="1500" height="120" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
