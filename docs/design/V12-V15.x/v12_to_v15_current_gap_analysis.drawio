  <diagram name="验收门槛" id="pv16-gates">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="gate-title" value="PV16 验收门槛：用户体验与证据要求" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#0f172a;strokeColor=#0f172a;fontColor=#ffffff;fontSize=28;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1720" height="70" as="geometry" />
        </mxCell>
        <mxCell id="gate-user" value="用户体验门槛&lt;br&gt;能创建/更新实体&lt;br&gt;能确认并查看真实运行进度&lt;br&gt;能看到 output / artifact / trace / evidence refs&lt;br&gt;能识别失败、拒绝、加载和权限原因&lt;br&gt;能完成一条连续产品旅程" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#111827;fontSize=17;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1">
          <mxGeometry x="90" y="170" width="500" height="310" as="geometry" />
        </mxCell>
        <mxCell id="gate-arch" value="架构门槛&lt;br&gt;Browser 只走 BFF DTO&lt;br&gt;产品实体不拥有 runtime truth&lt;br&gt;run 由 controlled runtime gateway 触发&lt;br&gt;observability 仅读 runtime evidence&lt;br&gt;deployment smoke 不做破坏性变更" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#111827;fontSize=17;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1">
          <mxGeometry x="650" y="170" width="500" height="310" as="geometry" />
        </mxCell>
        <mxCell id="gate-evidence" value="证据门槛&lt;br&gt;acceptance-data.json&lt;br&gt;artifact-manifest.json&lt;br&gt;entity-crud-report.json&lt;br&gt;runtime-run-inspect-report.json&lt;br&gt;deployment-health-report.json&lt;br&gt;ux-hardening-report.json&lt;br&gt;claim-to-evidence matrix" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#f0fdf4;strokeColor=#16a34a;fontColor=#111827;fontSize=17;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1">
          <mxGeometry x="1210" y="170" width="500" height="310" as="geometry" />
        </mxCell>
        <mxCell id="gate-auto" value="自动化门槛&lt;br&gt;schema validation PASS&lt;br&gt;route denylist PASS&lt;br&gt;browser network log PASS&lt;br&gt;No False Green PASS&lt;br&gt;redaction scan PASS&lt;br&gt;runner 对缺失证据必须 FAIL" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#ecfeff;strokeColor=#0891b2;fontColor=#111827;fontSize=18;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1">
          <mxGeometry x="220" y="600" width="620" height="240" as="geometry" />
        </mxCell>
        <mxCell id="gate-human" value="人工审计门槛&lt;br&gt;PRD 规格检视 PASS&lt;br&gt;目标架构检视 PASS&lt;br&gt;fatal findings = 0&lt;br&gt;major findings = 0&lt;br&gt;高风险流程必须回到用户确认" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fff7ed;strokeColor=#f97316;fontColor=#111827;fontSize=18;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1">
          <mxGeometry x="960" y="600" width="620" height="240" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
