        </mxCell>
        <mxCell id="overview-current" value="当前已能证明&lt;br&gt;1. 浏览器产品壳与画布审查路径&lt;br&gt;2. V13 Pilot 图编辑和 WorkflowDiff handoff&lt;br&gt;3. V14 扩展治理审查&lt;br&gt;4. V15 只读运维与部署 smoke 审查" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#eff6ff;strokeColor=#2563eb;fontColor=#111827;fontSize=17;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1">
