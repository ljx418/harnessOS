  <diagram name="出门条件" id="pv16-exit">
    <mxGraphModel dx="1800" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="exit-title" value="PV16 出门条件与阻断条件" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#0f172a;strokeColor=#0f172a;fontColor=#ffffff;fontSize=28;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="40" y="30" width="1720" height="70" as="geometry" />
        </mxCell>
        <mxCell id="exit-pass" value="允许出门的最小条件&lt;br&gt;1. PV16-S1/S2/S3/S4 全部 PASS&lt;br&gt;2. acceptance runner PASS&lt;br&gt;3. 所有 required artifacts PRESENT&lt;br&gt;4. PRD/架构/audit closure PASS&lt;br&gt;5. claim-to-evidence 全部有证据&lt;br&gt;6. 无 raw secret / raw provider payload" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#dcfce7;strokeColor=#16a34a;fontColor=#111827;fontSize=18;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1">
          <mxGeometry x="90" y="170" width="760" height="330" as="geometry" />
        </mxCell>
        <mxCell id="exit-block" value="必须打回或找人确认&lt;br&gt;1. runtime 证据只有 fixture&lt;br&gt;2. 浏览器绕过 BFF 或 runtime gateway&lt;br&gt;3. 部署 smoke 无命令输出&lt;br&gt;4. 需要外部真实密钥或不可逆动作&lt;br&gt;5. 文档或 UI 出现过度承诺&lt;br&gt;6. fatal/major finding 无法关闭" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fee2e2;strokeColor=#dc2626;fontColor=#111827;fontSize=18;align=left;verticalAlign=top;spacing=18;" vertex="1" parent="1">
          <mxGeometry x="950" y="170" width="760" height="330" as="geometry" />
        </mxCell>
        <mxCell id="exit-claim" value="唯一允许的 PV16 正向声明：&lt;br&gt;PV16 complete: product-runtime hardening pilot ready for review.&lt;br&gt;&lt;br&gt;这不等于生产可用、完整 Studio、执行器就绪、Xpert 等价或产品级前端完成。" style="rounded=1;whiteSpace=wrap;html=1;overflow=hidden;fillColor=#fef3c7;strokeColor=#d97706;fontColor=#111827;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;spacing=18;" vertex="1" parent="1">
          <mxGeometry x="210" y="650" width="1380" height="170" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
