# LLM Configuration
LLM_PROVIDER=minimax
DEEPSEEK_API_KEY=your-deepseek-api-key-here
MINIMAX_API_KEY=your-minimax-api-key-here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
LLM_MODEL=deepseek-chat

# V4-U5E Real LLM Local Document Workflow
# Fill MINIMAX_API_KEY locally in .env or .env.local before running real LLM acceptance.
# Do not commit real API keys.
V4_U5E_LLM_PROVIDER=minimax
V4_U5E_LLM_MODEL=your-minimax-model-ref-here
V4_U5E_REAL_LLM_REQUIRED=false
V4_U5E_FOLDER_PATH=tests/fixtures/desktop/技术分享

# Deep Agents Configuration
DEEP_AGENTS_MODEL=deepseek/deepseek-chat

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Agent Configuration
MAX_CONCURRENT_AGENTS=5
AGENT_TIMEOUT=300

# Memory Configuration
MEMORY_ENABLED=true
MEMORY_STORAGE_PATH=./data/memory.json

# Workspace Configuration
WORKSPACE_PATH=./workspace
